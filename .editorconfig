root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# C# — 4-space indent is idiomatic
[*.{cs,csx,vb,vbx}]
indent_size = 4
# Enforce file-scoped namespaces, var preferences, etc., kept minimal here
csharp_new_line_before_open_brace = all
dotnet_sort_system_directives_first = true

# JSON / YAML / Markdown
[*.{json,yml,yaml,md}]
indent_size = 2

# Makefiles need tabs
[Makefile]
indent_style = tab
