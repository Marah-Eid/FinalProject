# Copy to frontend/.env (or .env.local) for local dev.
# In dev the Vite proxy forwards /api to http://localhost:5080 (the .NET API).

# Base URL the Axios client will hit. Use the relative path in dev so the proxy handles it.
VITE_API_BASE_URL=/api

# Public Leaflet tiles (OpenStreetMap-compatible). Leave default for dev.
VITE_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_TILE_ATTRIBUTION=© OpenStreetMap contributors
