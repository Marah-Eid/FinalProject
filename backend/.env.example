# Copy to backend/.env (or set as real env vars) before running the API.
# Any double-underscore segments map to nested JSON in appsettings.json.

# Database (PostgreSQL 16+ running locally)
ConnectionStrings__Default=Host=localhost;Port=5432;Database=dorm;Username=postgres;Password=0000

# JWT — use a long random string (>= 32 chars) in real environments
Jwt__Secret=REPLACE_WITH_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS_LOCALLY
Jwt__Issuer=Dorm.API
Jwt__Audience=Dorm.Client
Jwt__AccessTokenMinutes=60
Jwt__RefreshTokenDays=7

# CORS — comma separates entries via __0 / __1 indexed keys, or just leave the default
Cors__AllowedOrigins__0=http://localhost:5173

# File storage (local for now). Swap to Cloudinary/Azure Blob later.
Storage__Provider=Local
Storage__LocalRoot=wwwroot/uploads
Storage__PublicBaseUrl=/uploads

# Demo-data seed — set to `true` once to populate fake users / apartments /
# applications / messages, then unset (the seeder is idempotent but slower).
# Default admin: admin@dorm.jo / Admin123! (created automatically at startup).
Dorm__Seed=false
