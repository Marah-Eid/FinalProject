@{
    ViewData["Title"] = "Login";
}

<h1 class="auth-title">Welcome back</h1>
<p class="auth-subtitle mb-4">Log in to find your next campus home.</p>

@if (ViewData["Error"] is string error)
{
    <div class="alert alert-danger" style="border-radius:8px">@error</div>
}

<form method="post" asp-action="Login" asp-controller="Account">
    @Html.AntiForgeryToken()
    @if (ViewData["ReturnUrl"] is string returnUrl)
    {
        <input type="hidden" name="returnUrl" value="@returnUrl" />
    }
    <div class="mb-3">
        <label class="form-label" style="font-size:.85rem;font-weight:600;color:#475569">Email</label>
        <input type="email" class="form-control" name="email" placeholder="you@example.com" value="@ViewData["Email"]" required style="padding:.7rem .9rem;border-radius:8px" />
    </div>
    <div class="mb-4">
        <label class="form-label" style="font-size:.85rem;font-weight:600;color:#475569">Password</label>
        <div style="position:relative">
            <input type="password" class="form-control" name="password" id="pw-input" placeholder="Enter your password" required style="padding:.7rem 2.8rem .7rem .9rem;border-radius:8px" />
            <button type="button" onclick="togglePw()" style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:#94a3b8;cursor:pointer;padding:0;line-height:1" tabindex="-1">
                <i class="bi bi-eye" id="pw-eye"></i>
            </button>
        </div>
    </div>
    <button class="btn btn-primary w-100" type="submit" style="padding:.7rem;border-radius:8px;font-weight:600">Log in</button>
</form>

<div class="text-center mt-4">
    <p style="color:#64748b;font-size:.9rem">Don't have an account? <a href="/Identity/Account/Register">Sign up</a></p>
</div>

@section Scripts {
<script>
function togglePw() {
    var input = document.getElementById('pw-input');
    var icon = document.getElementById('pw-eye');
    if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye-slash'; }
    else { input.type = 'password'; icon.className = 'bi bi-eye'; }
}
</script>
}
