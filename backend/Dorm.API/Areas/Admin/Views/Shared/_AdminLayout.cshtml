<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Dorm Admin</title>

    <link rel="shortcut icon" href="~/property/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f1f5f9; margin: 0; }

        /* Sidebar */
        .admin-sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            top: 0; left: 0;
            background: #1e293b;
            color: #fff;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: transform .3s;
        }
        .admin-sidebar .brand {
            padding: 1.5rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .admin-sidebar .brand a {
            font-size: 1.4rem; font-weight: 700; color: #F97316;
            text-decoration: none;
        }
        .admin-sidebar .brand small {
            display: block; font-size: .75rem; color: #94a3b8;
            font-weight: 400; margin-top: 2px;
        }
        .admin-sidebar .nav-section {
            padding: .75rem 0;
            flex: 1; overflow-y: auto;
        }
        .admin-sidebar .nav-label {
            font-size: .65rem; text-transform: uppercase; letter-spacing: .08em;
            color: #64748b; padding: .5rem 1.25rem; margin-top: .5rem;
        }
        .admin-sidebar .nav-item a {
            display: flex; align-items: center; gap: .75rem;
            padding: .65rem 1.25rem;
            color: #cbd5e1; text-decoration: none;
            font-size: .875rem; font-weight: 500;
            border-left: 3px solid transparent;
            transition: all .15s;
        }
        .admin-sidebar .nav-item a:hover {
            background: rgba(255,255,255,.06);
            color: #fff;
        }
        .admin-sidebar .nav-item a.active {
            background: rgba(249,115,22,.1);
            color: #F97316;
            border-left-color: #F97316;
        }
        .admin-sidebar .nav-item a i { font-size: 1.1rem; width: 20px; text-align: center; }

        /* Main content */
        .admin-main {
            margin-left: 260px;
            min-height: 100vh;
        }

        /* Top bar */
        .admin-topbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: .75rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 100;
        }
        .admin-topbar .page-title { font-weight: 700; font-size: 1.1rem; color: #1e293b; margin: 0; }

        /* Content area */
        .admin-content { padding: 1.5rem; }

        /* Cards */
        .card { border: none; border-radius: .75rem; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
        .card-header { background: transparent; border-bottom: 1px solid #f1f5f9; }

        /* Buttons */
        .btn-dorm { background: #F97316; border-color: #F97316; color: #fff; }
        .btn-dorm:hover { background: #ea6c10; border-color: #ea6c10; color: #fff; }
        .btn-dorm.active { background: #F97316; border-color: #F97316; color: #fff; }

        /* Tables */
        .table th { font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: #64748b; border-bottom-width: 1px; }
        .table td { vertical-align: middle; }

        /* Form focus */
        .form-control:focus, .form-select:focus {
            border-color: #F97316;
            box-shadow: 0 0 0 .2rem rgba(249,115,22,.15);
        }
        .form-check-input:checked { background-color: #F97316; border-color: #F97316; }

        /* Scrollbar */
        .nav-section::-webkit-scrollbar { width: 4px; }
        .nav-section::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }

        /* Mobile */
        .sidebar-toggle { display: none; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 999; }
        @@media (max-width: 991px) {
            .admin-sidebar { transform: translateX(-100%); }
            .admin-sidebar.show { transform: translateX(0); }
            .sidebar-overlay.show { display: block; }
            .admin-main { margin-left: 0; }
            .sidebar-toggle { display: inline-flex; }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>
    <aside class="admin-sidebar" id="admin-sidebar">
        <div class="brand">
            <a href="/">Dorm</a>
            <small>Admin Panel</small>
        </div>
        <div class="nav-section">
            <div class="nav-label">Navigation</div>
            <div class="nav-item">
                <a href="/Admin/Dashboard" data-page="dashboard"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
            </div>
            <div class="nav-item">
                <a href="/Admin/Users" data-page="users"><i class="bi bi-people-fill"></i> Users</a>
            </div>
            <div class="nav-item">
                <a href="/Admin/Listings" data-page="listings"><i class="bi bi-building-fill"></i> Listings</a>
            </div>
            <div class="nav-item">
                <a href="/Admin/Reports" data-page="reports"><i class="bi bi-flag-fill"></i> Reports</a>
            </div>

            <div class="nav-label">Account</div>
            <div class="nav-item">
                <a href="/" ><i class="bi bi-house"></i> Back to site</a>
            </div>
            <div class="nav-item">
                <a href="#" onclick="auth.logout();return false;"><i class="bi bi-box-arrow-left"></i> Logout</a>
            </div>
        </div>
        <div style="padding:1rem 1.25rem;border-top:1px solid rgba(255,255,255,.08)">
            <div class="d-flex align-items-center gap-2">
                <div style="width:32px;height:32px;border-radius:50%;background:#F97316;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:.75rem" id="admin-avatar">A</div>
                <div>
                    <div style="font-size:.8rem;font-weight:600;color:#fff" id="admin-name">Admin</div>
                    <div style="font-size:.7rem;color:#64748b" id="admin-email">admin@dorm.jo</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main -->
    <div class="admin-main">
        <div class="admin-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-light sidebar-toggle" onclick="toggleSidebar()"><i class="bi bi-list fs-5"></i></button>
                <h6 class="page-title" id="topbar-title">@ViewData["Title"]</h6>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-success bg-opacity-10 text-success"><i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i> Online</span>
            </div>
        </div>
        <div class="admin-content">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/utils.js"></script>
    <script src="~/js/api.js"></script>
    <script src="~/js/auth.js"></script>
    <script src="~/js/i18n.js"></script>

    <script>
    // Force English for admin
    i18n.setLocale('en')

    auth.initAuth().then(function () {
        var user = auth.getUser()
        if (!user || user.role !== 2) { window.location.href = '/Dashboard'; return }

        var name = user.fullName || 'Admin'
        document.getElementById('admin-name').textContent = name
        document.getElementById('admin-email').textContent = user.email || ''
        document.getElementById('admin-avatar').textContent = name.charAt(0).toUpperCase()
    })

    // Highlight active nav
    var path = window.location.pathname.toLowerCase()
    document.querySelectorAll('.nav-item a[data-page]').forEach(function (link) {
        var page = link.getAttribute('data-page')
        if (path.indexOf('/admin/' + page) === 0 || (page === 'dashboard' && (path === '/admin' || path === '/admin/'))) {
            link.classList.add('active')
        }
    })

    // Mobile sidebar toggle
    function toggleSidebar() {
        document.getElementById('admin-sidebar').classList.toggle('show')
        document.getElementById('sidebar-overlay').classList.toggle('show')
    }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
