@using Dorm.Domain.Enums
@using Dorm.Application.DTOs.Admin
@using Dorm.Application.DTOs.Reports
@using Dorm.Application.DTOs.Testimonials
@using Dorm.Domain.Entities
@{
    ViewData["Title"] = "Admin Panel";
    var dashboard = (AdminDashboardDto)ViewBag.Dashboard;
    var users = (IReadOnlyList<AdminUserDto>)(ViewBag.Users ?? Array.Empty<AdminUserDto>());
    var listings = (IReadOnlyList<AdminApartmentDto>)(ViewBag.Listings ?? Array.Empty<AdminApartmentDto>());
    var reports = (IReadOnlyList<ReportDto>)(ViewBag.Reports ?? Array.Empty<ReportDto>());
    var testimonials = (IReadOnlyList<TestimonialDto>)(ViewBag.Testimonials ?? Array.Empty<TestimonialDto>());
    var contactMessages = (IReadOnlyList<Notification>)(ViewBag.ContactMessages ?? Array.Empty<Notification>());
    var pendingReviews = testimonials.Count(t => !t.IsApproved);
    var pendingIds = ViewBag.PendingIds as dynamic ?? new List<dynamic>();
}

@section Styles {
<style>
    .admin-tabs {
        display: flex; gap: .5rem; margin-bottom: 1.5rem;
        border-bottom: 2px solid #f1f5f9; padding-bottom: 0;
        overflow-x: auto;
    }
    .admin-tab {
        padding: .55rem 1.1rem; border: none; background: transparent;
        font-size: .85rem; font-weight: 600; color: #94a3b8;
        border-bottom: 2px solid transparent; margin-bottom: -2px;
        cursor: pointer; transition: all .15s; white-space: nowrap;
    }
    .admin-tab:hover { color: #475569; }
    .admin-tab.active { color: #F97316; border-bottom-color: #F97316; }

    .admin-section { display: none; }
    .admin-section.active { display: block; }

    .stat-row { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .admin-stat {
        flex: 1; min-width: 140px; background: #fff; border-radius: 12px;
        border: 1px solid #f1f5f9; padding: 1rem;
        display: flex; align-items: center; gap: .75rem;
    }
    .admin-stat-icon {
        width: 40px; height: 40px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
    }
    .admin-stat .label { font-size: .72rem; color: #94a3b8; font-weight: 500; }
    .admin-stat .value { font-size: 1.15rem; font-weight: 800; color: #1e293b; }

    .admin-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }

    .btn-approve {
        background: rgba(16,185,129,.1); color: #10b981; border: none;
        border-radius: 6px; padding: .35rem .7rem; font-size: .78rem; font-weight: 600;
        cursor: pointer; transition: all .15s;
    }
    .btn-approve:hover { background: rgba(16,185,129,.2); }
    .btn-deny {
        background: rgba(239,68,68,.08); color: #ef4444; border: none;
        border-radius: 6px; padding: .35rem .7rem; font-size: .78rem; font-weight: 600;
        cursor: pointer; transition: all .15s;
    }
    .btn-deny:hover { background: rgba(239,68,68,.15); }

    .badge-role { font-size: .7rem; font-weight: 600; padding: .2rem .5rem; border-radius: 4px; }
    .badge-student { background: rgba(59,130,246,.1); color: #3b82f6; }
    .badge-owner { background: rgba(139,92,246,.1); color: #8b5cf6; }
    .badge-admin-role { background: rgba(249,115,22,.1); color: #F97316; }
    .badge-banned { background: rgba(239,68,68,.1); color: #ef4444; }
    .badge-active { background: rgba(16,185,129,.1); color: #10b981; }
    .badge-suspended { background: rgba(234,179,8,.1); color: #eab308; }
    .badge-pending { background: rgba(234,179,8,.1); color: #eab308; font-size: .7rem; font-weight: 600; padding: .2rem .5rem; border-radius: 4px; }
    .badge-approved { background: rgba(16,185,129,.1); color: #10b981; font-size: .7rem; font-weight: 600; padding: .2rem .5rem; border-radius: 4px; }
    .badge-dismissed { background: rgba(148,163,184,.1); color: #94a3b8; font-size: .7rem; font-weight: 600; padding: .2rem .5rem; border-radius: 4px; }
    .badge-resolved { background: rgba(59,130,246,.1); color: #3b82f6; font-size: .7rem; font-weight: 600; padding: .2rem .5rem; border-radius: 4px; }

    .testi-card {
        background: #fff; border-radius: 12px; border: 1px solid #e2e8f0;
        padding: 1rem 1.25rem; margin-bottom: .75rem;
        display: flex; align-items: flex-start; gap: 1rem;
    }
    .testi-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: #F97316; color: #fff; font-weight: 700; font-size: .7rem;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .testi-body { flex: 1; min-width: 0; }
    .testi-body .name { font-weight: 700; font-size: .85rem; color: #1e293b; }
    .testi-body .role { font-size: .72rem; color: #94a3b8; }
    .testi-body .text { font-size: .85rem; color: #475569; margin: .3rem 0; line-height: 1.6; }
    .testi-stars i { font-size: .75rem; }
    .testi-actions { display: flex; gap: .4rem; flex-shrink: 0; align-self: center; }

    .empty-admin { text-align: center; padding: 3rem 1rem; color: #94a3b8; }
    .empty-admin i { font-size: 2rem; color: #cbd5e1; }
    .empty-admin p { margin-top: .5rem; font-size: .88rem; }

    .revenue-row { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; }
    .revenue-card {
        flex: 1; min-width: 160px; background: #0f172a; border-radius: 12px; padding: 1rem 1.25rem; color: #f8fafc;
    }
    .revenue-card .rev-label { font-size: .72rem; opacity: .6; }
    .revenue-card .rev-value { font-size: 1.3rem; font-weight: 800; }
</style>
}

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success" style="border-radius:8px">@successMsg</div>
}

<div id="admin-content">
    <div class="admin-tabs" id="admin-tabs">
        <button class="admin-tab active" onclick="showTab('dashboard',this)">Dashboard</button>
        <button class="admin-tab" onclick="showTab('users',this)">Users</button>
        <button class="admin-tab" onclick="showTab('listings',this)">Listings</button>
        <button class="admin-tab" onclick="showTab('reports',this)">Reports</button>
        <button class="admin-tab" onclick="showTab('testimonials',this)">Testimonials</button>
        <button class="admin-tab" onclick="showTab('messages',this)">
            Messages
            @if (contactMessages.Count > 0)
            {
                <span style="background:#F97316;color:#fff;border-radius:999px;font-size:.7rem;font-weight:700;padding:1px 7px;margin-left:4px">@contactMessages.Count</span>
            }
        </button>
        <button class="admin-tab" onclick="showTab('verifications',this)">
            Verifications
            @{ var pendingIdCount = 0; foreach (var _ in pendingIds) pendingIdCount++; }
            @if (pendingIdCount > 0)
            {
                <span style="background:#ef4444;color:#fff;border-radius:999px;font-size:.7rem;font-weight:700;padding:1px 7px;margin-left:4px">@pendingIdCount</span>
            }
        </button>
    </div>

    <!-- Dashboard Tab -->
    <div class="admin-section active" id="tab-dashboard">
        <div class="stat-row">
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(59,130,246,.1);color:#3b82f6"><i class="bi bi-people-fill"></i></div>
                <div><div class="label">Total Users</div><div class="value">@dashboard.TotalUsers</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(16,185,129,.1);color:#10b981"><i class="bi bi-building"></i></div>
                <div><div class="label">Active Listings</div><div class="value">@dashboard.ActiveListings</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(234,179,8,.1);color:#eab308"><i class="bi bi-star-fill"></i></div>
                <div><div class="label">Pending Reviews</div><div class="value">@pendingReviews</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6"><i class="bi bi-flag-fill"></i></div>
                <div><div class="label">Pending Reports</div><div class="value">@dashboard.PendingReports</div></div>
            </div>
        </div>
        <div class="stat-row">
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(6,182,212,.1);color:#06b6d4"><i class="bi bi-mortarboard-fill"></i></div>
                <div><div class="label">Students</div><div class="value">@dashboard.TotalStudents</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6"><i class="bi bi-house-door-fill"></i></div>
                <div><div class="label">Owners</div><div class="value">@dashboard.TotalOwners</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(239,68,68,.1);color:#ef4444"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div><div class="label">Suspended</div><div class="value">@dashboard.SuspendedListings</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(16,185,129,.1);color:#10b981"><i class="bi bi-key-fill"></i></div>
                <div><div class="label">Active Tenancies</div><div class="value">@dashboard.ActiveTenancies</div></div>
            </div>
        </div>
        <div class="revenue-row">
            <div class="revenue-card">
                <div class="rev-label">Revenue This Month</div>
                <div class="rev-value">@dashboard.RevenueThisMonthJod JOD</div>
            </div>
            <div class="revenue-card">
                <div class="rev-label">Revenue All Time</div>
                <div class="rev-value">@dashboard.RevenueAllTimeJod JOD</div>
            </div>
            @if (dashboard.RevenueByType != null)
            {
                @foreach (var r in dashboard.RevenueByType)
                {
                    var typeName = r.Type switch { PaymentType.MatchCommission => "Match Commission", PaymentType.ListingFee => "Listing Fee", _ => "Other" };
                    <div class="revenue-card" style="background:#1e293b">
                        <div class="rev-label">@typeName</div>
                        <div class="rev-value">@r.Total JOD <span style="font-size:.7rem;font-weight:400;opacity:.5">(@r.Count)</span></div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Users Tab -->
    <div class="admin-section" id="tab-users">
        <div class="admin-card">
            <div class="table-responsive">
                @if (users.Count == 0)
                {
                    <div class="empty-admin"><i class="bi bi-people"></i><p>No users found.</p></div>
                }
                else
                {
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr style="font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8">
                                <th>User</th><th>Role</th><th>Gender</th><th class="text-center">Verified</th><th class="text-center">Status</th><th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var u in users)
                        {
                            var initials = string.Join("", u.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(n => n[0])).ToUpper();
                            var roleBadge = u.Role switch { UserRole.Student => "badge-student", UserRole.Owner => "badge-owner", _ => "badge-admin-role" };
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:32px;height:32px;border-radius:50%;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.7rem;color:#64748b">@initials</div>
                                        <div>
                                            <span class="fw-semibold" style="font-size:.85rem">@u.FullName</span><br/>
                                            <span style="color:#94a3b8;font-size:.72rem">@u.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td><span class="badge-role @roleBadge">@u.Role</span></td>
                                <td style="font-size:.82rem;color:#64748b">@u.Gender</td>
                                <td class="text-center">
                                    @if (u.IsEmailVerified) { <i class="bi bi-envelope-check-fill text-success" title="Email verified" style="font-size:.8rem"></i> }
                                    @if (u.IsUniversityVerified) { <i class="bi bi-patch-check-fill text-primary" title="University verified" style="font-size:.8rem"></i> }
                                    @if (!u.IsEmailVerified && !u.IsUniversityVerified) { <span style="color:#cbd5e1">—</span> }
                                </td>
                                <td class="text-center">
                                    @if (u.IsBanned)
                                    {
                                        <span class="badge-role badge-banned"><i class="bi bi-slash-circle me-1"></i>Banned</span>
                                    }
                                    else
                                    {
                                        <span class="badge-role badge-active"><i class="bi bi-check-circle me-1"></i>Active</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (u.Role != UserRole.Admin)
                                    {
                                        @if (u.IsBanned)
                                        {
                                            <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="Unban" asp-route-id="@u.Id" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-approve"><i class="bi bi-unlock me-1"></i>Unban</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="Ban" asp-route-id="@u.Id" style="display:inline" onsubmit="return confirm('Ban this user?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn-deny"><i class="bi bi-slash-circle me-1"></i>Ban</button>
                                            </form>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Listings Tab -->
    <div class="admin-section" id="tab-listings">
        <div class="admin-card">
            <div class="table-responsive">
                @if (listings.Count == 0)
                {
                    <div class="empty-admin"><i class="bi bi-building"></i><p>No listings found.</p></div>
                }
                else
                {
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr style="font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8">
                                <th>Listing</th><th>Owner</th><th>City</th><th class="text-center">Spots</th><th class="text-center">Status</th><th class="text-center">Reports</th><th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var a in listings)
                        {
                            <tr>
                                <td>
                                    <div>
                                        <a href="/Apartment/Detail/@a.Id" class="fw-semibold text-decoration-none" style="color:#1e293b;font-size:.85rem">@a.Title</a><br/>
                                        <span style="color:#94a3b8;font-size:.72rem">@a.Neighborhood</span>
                                    </div>
                                </td>
                                <td style="font-size:.82rem;color:#64748b">@a.OwnerName</td>
                                <td style="font-size:.82rem;color:#64748b">@a.City</td>
                                <td class="text-center" style="font-size:.85rem">@a.AvailableSpots / @a.TotalSpots</td>
                                <td class="text-center">
                                    @if (a.IsSuspended)
                                    {
                                        <span class="badge-role badge-suspended"><i class="bi bi-pause-circle me-1"></i>Suspended</span>
                                    }
                                    else if (a.IsActive)
                                    {
                                        <span class="badge-role badge-active"><i class="bi bi-check-circle me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-role" style="background:#f1f5f9;color:#94a3b8">Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (a.PendingReportsCount > 0)
                                    {
                                        <span class="badge-role badge-banned">@a.PendingReportsCount</span>
                                    }
                                    else
                                    {
                                        <span style="color:#cbd5e1">0</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (a.IsSuspended)
                                    {
                                        <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="Activate" asp-route-id="@a.Id" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-approve"><i class="bi bi-play-circle me-1"></i>Activate</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="Suspend" asp-route-id="@a.Id" style="display:inline" onsubmit="return confirm('Suspend this listing?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-deny"><i class="bi bi-pause-circle me-1"></i>Suspend</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Reports Tab -->
    <div class="admin-section" id="tab-reports">
        <div class="admin-card">
            <div class="table-responsive">
                @if (reports.Count == 0)
                {
                    <div class="empty-admin"><i class="bi bi-flag"></i><p>No reports found.</p></div>
                }
                else
                {
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr style="font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8">
                                <th>Apartment</th><th>Reporter</th><th>Reason</th><th>Description</th><th class="text-center">Status</th><th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var r in reports)
                        {
                            var reasonLabel = r.Reason switch { ReportReason.FakeListing => "Fake Listing", ReportReason.MisleadingPhotos => "Misleading Photos", ReportReason.Scam => "Scam", ReportReason.Inappropriate => "Inappropriate", _ => "Other" };
                            var statusBadge = r.Status switch { ReportStatus.Pending => "badge-pending", ReportStatus.Resolved => "badge-resolved", _ => "badge-dismissed" };
                            var statusLabel = r.Status switch { ReportStatus.Pending => "Pending", ReportStatus.Resolved => "Resolved", _ => "Dismissed" };
                            <tr>
                                <td><a href="/Apartment/Detail/@r.ReportedApartmentId" class="fw-semibold text-decoration-none" style="color:#1e293b;font-size:.85rem">@r.ApartmentTitle</a></td>
                                <td style="font-size:.82rem;color:#64748b">@r.ReporterName</td>
                                <td><span class="badge-pending">@reasonLabel</span></td>
                                <td style="font-size:.82rem;color:#64748b;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@(r.Description ?? "—")</td>
                                <td class="text-center"><span class="@statusBadge">@statusLabel</span></td>
                                <td class="text-end">
                                    @if (r.Status == ReportStatus.Pending)
                                    {
                                        <div class="d-flex gap-1 justify-content-end">
                                            <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="Resolve" asp-route-id="@r.Id" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="dismiss" value="false" />
                                                <button type="submit" class="btn-deny"><i class="bi bi-check-lg me-1"></i>Resolve</button>
                                            </form>
                                            <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="Resolve" asp-route-id="@r.Id" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="dismiss" value="true" />
                                                <button type="submit" class="btn-approve"><i class="bi bi-x-lg me-1"></i>Dismiss</button>
                                            </form>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Testimonials Tab -->
    <div class="admin-section" id="tab-testimonials">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 style="font-weight:700;font-size:.95rem;color:#1e293b;margin:0">User Testimonials</h6>
        </div>
        @if (testimonials.Count == 0)
        {
            <div class="empty-admin"><i class="bi bi-chat-square-text"></i><p>No testimonials found.</p></div>
        }
        else
        {
            @foreach (var t in testimonials)
            {
                var initials = string.Join("", t.UserName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(n => n[0])).ToUpper();
                <div class="testi-card">
                    <div class="testi-avatar">@initials</div>
                    <div class="testi-body">
                        <div class="d-flex align-items-center gap-2">
                            <span class="name">@t.UserName</span>
                            <span class="role">@t.UserRole</span>
                            @if (t.IsApproved)
                            {
                                <span class="badge-approved">Approved</span>
                            }
                            else
                            {
                                <span class="badge-pending">Pending</span>
                            }
                        </div>
                        <div class="testi-stars mb-1">
                            @for (var i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= t.Stars ? "bi-star-fill" : "bi-star")" style="color:@(i <= t.Stars ? "#F97316" : "#e2e8f0")"></i>
                            }
                        </div>
                        <div class="text">@t.Text</div>
                    </div>
                    <div class="testi-actions">
                        @if (!t.IsApproved)
                        {
                            <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="ApproveTestimonial" asp-route-id="@t.Id" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-approve"><i class="bi bi-check-lg me-1"></i>Approve</button>
                            </form>
                        }
                        <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="DeleteTestimonial" asp-route-id="@t.Id" style="display:inline" onsubmit="return confirm('Delete this testimonial?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-deny"><i class="bi bi-trash me-1"></i>Delete</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Verifications tab -->
    <div class="admin-section" id="tab-verifications">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 style="font-weight:700;font-size:.95rem;color:#1e293b;margin:0">Owner ID Verifications</h6>
            <span style="font-size:.8rem;color:#94a3b8">@pendingIdCount pending</span>
        </div>
        @if (pendingIdCount == 0)
        {
            <div class="empty-admin"><i class="bi bi-shield-check"></i><p>No pending ID verifications.</p></div>
        }
        else
        {
            @foreach (var owner in pendingIds)
            {
                <div class="testi-card" style="align-items:flex-start;gap:1.25rem">
                    <div class="testi-avatar" style="background:#F97316;flex-shrink:0">
                        @{ var oi = ((string)owner.FullName).Split(' ').Where(n => n.Length > 0).Select(n => n[0].ToString()).Take(2); }
                        @string.Concat(oi).ToUpper()
                    </div>
                    <div class="testi-body" style="flex:1;min-width:0">
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                            <span class="name">@owner.FullName</span>
                            <span class="role">@owner.Email</span>
                        </div>
                        @{ string docUrl = (string)owner.IdDocumentUrl; }
                        @if (docUrl.EndsWith(".pdf"))
                        {
                            <a href="@docUrl" target="_blank" style="font-size:.82rem;color:#F97316;text-decoration:none"><i class="bi bi-file-pdf me-1"></i>View PDF Document</a>
                        }
                        else
                        {
                            <a href="@docUrl" target="_blank">
                                <img src="@docUrl" alt="ID" style="max-width:180px;max-height:120px;border-radius:8px;border:1px solid #e2e8f0;object-fit:cover;display:block;margin-top:.3rem" />
                            </a>
                        }
                    </div>
                    <div class="testi-actions" style="align-self:center">
                        <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="VerifyId" asp-route-id="@owner.Id" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-approve"><i class="bi bi-shield-check me-1"></i>Verify</button>
                        </form>
                        <form method="post" asp-area="Admin" asp-controller="Admin" asp-action="RejectId" asp-route-id="@owner.Id" style="display:inline" onsubmit="return confirm('Reject and remove this document?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-deny"><i class="bi bi-x-lg me-1"></i>Reject</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Messages tab -->
    <div class="admin-section" id="tab-messages">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 style="font-weight:700;font-size:.95rem;color:#1e293b;margin:0">Contact Messages</h6>
            <span style="font-size:.8rem;color:#94a3b8">@contactMessages.Count message@(contactMessages.Count != 1 ? "s" : "")</span>
        </div>
        @if (contactMessages.Count == 0)
        {
            <div class="empty-admin"><i class="bi bi-envelope"></i><p>No messages yet.</p></div>
        }
        else
        {
            @foreach (var msg in contactMessages)
            {
                @* Title format: "Contact: {subject} — {name}"  Content: "From: {name} ({email})\n\n{body}" *@
                var titlePart = msg.Title.StartsWith("Contact: ") ? msg.Title["Contact: ".Length..] : msg.Title;
                var dashIdx = titlePart.LastIndexOf(" — ");
                var subject = dashIdx > 0 ? titlePart[..dashIdx] : titlePart;
                var senderName = dashIdx > 0 ? titlePart[(dashIdx + 3)..] : "";
                var initials2 = string.Join("", senderName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(n => n[0])).ToUpper();
                if (string.IsNullOrEmpty(initials2)) initials2 = "?";

                var lines = msg.Content.Split('\n');
                var fromLine = lines.FirstOrDefault(l => l.StartsWith("From: ")) ?? "";
                var bodyLines = msg.Content.Split(new[] { "\n\n" }, 2, StringSplitOptions.None);
                var body = bodyLines.Length > 1 ? bodyLines[1] : msg.Content;

                <div class="testi-card">
                    <div class="testi-avatar" style="background:#3b82f6">@initials2</div>
                    <div class="testi-body">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <span class="name">@(string.IsNullOrEmpty(senderName) ? "Unknown" : senderName)</span>
                            <span class="badge-role badge-student">@subject</span>
                        </div>
                        @if (!string.IsNullOrEmpty(fromLine))
                        {
                            <div style="font-size:.74rem;color:#94a3b8;margin:.2rem 0 .4rem">@fromLine</div>
                        }
                        <div class="text" style="white-space:pre-wrap">@body</div>
                    </div>
                    <div style="font-size:.74rem;color:#94a3b8;white-space:nowrap;flex-shrink:0;align-self:flex-start;padding-top:.15rem">
                        @msg.CreatedAt.ToString("MMM d, yyyy")<br/>
                        <span style="font-size:.7rem">@msg.CreatedAt.ToString("h:mm tt")</span>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
<script>
function showTab(name, btn) {
    document.querySelectorAll('.admin-section').forEach(function (s) { s.classList.remove('active'); });
    document.querySelectorAll('#admin-tabs .admin-tab').forEach(function (t) { t.classList.remove('active'); });
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
}

var hash = window.location.hash.replace('#','');
if (hash) {
    var btn = document.querySelector('#admin-tabs .admin-tab[onclick*="' + hash + '"]');
    if (btn) showTab(hash, btn);
}
</script>
}
