@{
    ViewData["Title"] = "Dashboard";
}

<div id="stats-row" class="row g-3 mb-4">
    <div class="col-6 col-lg-3"><div class="card p-3"><div class="placeholder-glow"><span class="placeholder col-8"></span><br/><span class="placeholder col-5"></span></div></div></div>
    <div class="col-6 col-lg-3"><div class="card p-3"><div class="placeholder-glow"><span class="placeholder col-8"></span><br/><span class="placeholder col-5"></span></div></div></div>
    <div class="col-6 col-lg-3"><div class="card p-3"><div class="placeholder-glow"><span class="placeholder col-8"></span><br/><span class="placeholder col-5"></span></div></div></div>
    <div class="col-6 col-lg-3"><div class="card p-3"><div class="placeholder-glow"><span class="placeholder col-8"></span><br/><span class="placeholder col-5"></span></div></div></div>
</div>

<div class="row g-4">
    <!-- Revenue chart -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold">Revenue by Type</h6>
            </div>
            <div class="card-body" id="rev-chart">
                <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
            </div>
        </div>
    </div>
    <!-- Quick overview -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="mb-0 fw-bold">At a Glance</h6>
            </div>
            <div class="card-body p-0" id="overview-panel">
                <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
auth.initAuth().then(function () {
    var user = auth.getUser()
    if (!user || user.role !== 2) { window.location.href = '/Dashboard'; return }
    loadDashboard()
})

async function loadDashboard() {
    try {
        var data = await api.get('/admin/dashboard')

        document.getElementById('stats-row').innerHTML =
            statCard('bi-people-fill', data.totalUsers || 0, 'Total Users', '#F97316', 'rgba(249,115,22,.12)') +
            statCard('bi-building-fill', data.activeListings || 0, 'Active Listings', '#22c55e', 'rgba(34,197,94,.12)') +
            statCard('bi-flag-fill', data.pendingReports || 0, 'Pending Reports', '#ef4444', 'rgba(239,68,68,.12)') +
            statCard('bi-cash-coin', (data.revenueThisMonth || 0) + ' JOD', 'Revenue This Month', '#8B5CF6', 'rgba(139,92,246,.12)')

        renderRevenueChart(data)
        renderOverview(data)
    } catch (e) {
        document.getElementById('stats-row').innerHTML = '<div class="col-12"><div class="alert alert-danger">Failed to load dashboard data.</div></div>'
    }
}

function renderOverview(data) {
    var panel = document.getElementById('overview-panel')
    var items = [
        { icon: 'bi-mortarboard-fill', label: 'Students', value: data.totalStudents || 0, color: '#3b82f6' },
        { icon: 'bi-person-badge-fill', label: 'Owners', value: data.totalOwners || 0, color: '#8B5CF6' },
        { icon: 'bi-slash-circle-fill', label: 'Suspended Listings', value: data.suspendedListings || 0, color: '#ef4444' },
        { icon: 'bi-house-check-fill', label: 'Active Tenancies', value: data.activeTenancies || 0, color: '#22c55e' }
    ]
    panel.innerHTML = items.map(function (item) {
        return '<div class="d-flex align-items-center justify-content-between px-3 py-3 border-bottom">' +
            '<div class="d-flex align-items-center gap-3">' +
            '<div style="width:38px;height:38px;border-radius:10px;background:' + item.color + '15;display:flex;align-items:center;justify-content:center">' +
            '<i class="bi ' + item.icon + '" style="color:' + item.color + '"></i></div>' +
            '<span class="text-muted small">' + item.label + '</span></div>' +
            '<span class="fw-bold">' + item.value + '</span></div>'
    }).join('')
}

function renderRevenueChart(data) {
    var chart = document.getElementById('rev-chart')
    var byType = data.revenueByType || []
    if (byType.length === 0 && !data.revenueAllTime) {
        chart.innerHTML = '<div class="text-center py-4"><i class="bi bi-bar-chart text-muted" style="font-size:2.5rem"></i><p class="text-muted mt-2">No revenue data yet.</p></div>'
        return
    }

    var typeLabels = { 0: 'Match Commission', 1: 'Featured Listing', 2: 'Verified Badge' }
    var typeIcons = { 0: 'bi-people-fill', 1: 'bi-star-fill', 2: 'bi-patch-check-fill' }
    var typeColors = { 0: '#F97316', 1: '#8B5CF6', 2: '#06B6D4' }
    var maxAmount = Math.max.apply(null, byType.map(function (r) { return r.totalAmount || 0 }).concat([1]))

    chart.innerHTML =
        byType.map(function (r) {
            var label = typeLabels[r.type] || 'Other'
            var icon = typeIcons[r.type] || 'bi-credit-card'
            var color = typeColors[r.type] || '#6B7280'
            var pct = Math.max(Math.round(((r.totalAmount || 0) / maxAmount) * 100), 5)
            return '<div class="mb-4">' +
                '<div class="d-flex align-items-center justify-content-between mb-2">' +
                '<div class="d-flex align-items-center gap-2">' +
                '<i class="bi ' + icon + '" style="color:' + color + '"></i>' +
                '<span class="fw-semibold">' + label + '</span></div>' +
                '<div><span class="fw-bold" style="color:' + color + '">' + (r.totalAmount || 0) + ' JOD</span>' +
                '<span class="text-muted small ms-2">(' + (r.count || 0) + ' txn)</span></div></div>' +
                '<div class="progress" style="height:12px;border-radius:6px;background:#f1f5f9"><div class="progress-bar" role="progressbar" style="width:' + pct + '%;background:' + color + ';border-radius:6px"></div></div></div>'
        }).join('') +
        '<div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">' +
        '<span class="text-muted">All-time Revenue</span>' +
        '<span class="fw-bold fs-5" style="color:#F97316">' + (data.revenueAllTime || 0) + ' JOD</span></div>'
}

function statCard(icon, value, label, color, bg) {
    return '<div class="col-6 col-lg-3"><div class="card border-0" style="overflow:hidden">' +
        '<div class="card-body p-3">' +
        '<div class="d-flex align-items-center gap-3">' +
        '<div style="width:48px;height:48px;border-radius:12px;background:' + bg + ';display:flex;align-items:center;justify-content:center;flex-shrink:0">' +
        '<i class="bi ' + icon + '" style="font-size:1.3rem;color:' + color + '"></i></div>' +
        '<div><p class="text-muted small mb-1">' + label + '</p>' +
        '<h4 class="fw-bold mb-0">' + value + '</h4></div>' +
        '</div></div></div></div>'
}
</script>
}
