@{
    ViewData["Title"] = "Listings";
}

<div class="card">
    <div class="card-header d-flex flex-wrap gap-2 align-items-center">
        <div class="position-relative flex-grow-1" style="max-width:360px">
            <i class="bi bi-search position-absolute" style="top:50%;transform:translateY(-50%);left:12px;color:#94a3b8"></i>
            <input type="text" class="form-control form-control-sm" placeholder="Search listings…" id="listing-search" style="padding-left:2.2rem" />
        </div>
        <div class="btn-group btn-group-sm" id="status-btns">
            <button class="btn btn-dorm active" onclick="setStatusFilter('',this)">All</button>
            <button class="btn btn-outline-secondary" onclick="setStatusFilter('active',this)">Active</button>
            <button class="btn btn-outline-secondary" onclick="setStatusFilter('suspended',this)">Suspended</button>
        </div>
        <span class="badge bg-light text-dark border ms-auto" id="listing-count"></span>
    </div>
    <div class="card-body p-0" id="listings-list">
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    </div>
</div>

@section Scripts {
<script>
var listingsSearch = ''
var listingsFilter = ''

auth.initAuth().then(function () {
    var user = auth.getUser()
    if (!user || user.role !== 2) { window.location.href = '/Dashboard'; return }
    doListingSearch()
})

document.getElementById('listing-search').addEventListener('input', debounce(function (e) {
    listingsSearch = e.target.value
    doListingSearch()
}, 400))

function setStatusFilter(status, btn) {
    listingsFilter = status
    document.querySelectorAll('#status-btns .btn').forEach(function (b) {
        b.className = 'btn btn-sm ' + (b === btn ? 'btn-dorm active' : 'btn-outline-secondary')
    })
    doListingSearch()
}

async function doListingSearch() {
    var list = document.getElementById('listings-list')
    list.innerHTML = '<div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>'
    try {
        var q = '/admin/listings?'
        if (listingsSearch) q += 'search=' + encodeURIComponent(listingsSearch) + '&'
        if (listingsFilter) q += 'status=' + encodeURIComponent(listingsFilter)
        var data = await api.get(q)
        var items = data.items || data || []

        document.getElementById('listing-count').textContent = items.length + ' listings'

        if (items.length === 0) {
            list.innerHTML = '<div class="text-center py-5"><i class="bi bi-building-slash text-muted" style="font-size:2.5rem"></i>' +
                '<h5 class="fw-bold mt-3">No listings found</h5>' +
                '<p class="text-muted">Try adjusting your search or filter.</p></div>'
            return
        }

        list.innerHTML = '<div class="table-responsive"><table class="table table-hover align-middle mb-0">' +
            '<thead class="table-light"><tr>' +
            '<th>Title</th>' +
            '<th>Location</th>' +
            '<th class="text-center">Rent</th>' +
            '<th class="text-center">Status</th>' +
            '<th class="text-center"><i class="bi bi-flag" title="Reports"></i></th>' +
            '<th class="text-end">Actions</th>' +
            '</tr></thead><tbody>' +
            items.map(function (apt) {
                var statusBadge = apt.isSuspended
                    ? '<span class="badge bg-danger"><i class="bi bi-slash-circle me-1"></i>Suspended</span>'
                    : '<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Active</span>'
                var reportsCell = apt.pendingReportsCount > 0
                    ? '<span class="badge bg-danger rounded-pill">' + apt.pendingReportsCount + '</span>'
                    : '<span class="text-muted">0</span>'
                return '<tr' + (apt.isSuspended ? ' class="table-danger bg-opacity-10"' : '') + '>' +
                    '<td><div class="d-flex align-items-center gap-2">' +
                    '<div style="width:44px;height:44px;border-radius:10px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex-shrink:0"><i class="bi bi-building text-muted"></i></div>' +
                    '<span class="fw-semibold">' + escapeHtml(apt.title || '') + '</span></div></td>' +
                    '<td class="text-muted small">' + escapeHtml(apt.neighborhood || '') + '</td>' +
                    '<td class="text-center"><span class="fw-bold" style="color:#F97316">' + (apt.fullRent || 0) + ' JOD</span></td>' +
                    '<td class="text-center">' + statusBadge + '</td>' +
                    '<td class="text-center">' + reportsCell + '</td>' +
                    '<td class="text-end">' +
                    '<div class="btn-group btn-group-sm">' +
                    '<a href="/Apartment/Detail/' + apt.id + '" class="btn btn-outline-secondary" title="View"><i class="bi bi-eye"></i></a>' +
                    (apt.isSuspended
                        ? '<button class="btn btn-success" onclick="activateListing(' + apt.id + ',this)" title="Activate"><i class="bi bi-check-lg"></i></button>'
                        : '<button class="btn btn-outline-danger" onclick="suspendListing(' + apt.id + ',this)" title="Suspend"><i class="bi bi-slash-circle"></i></button>') +
                    '</div></td></tr>'
            }).join('') +
            '</tbody></table></div>'
    } catch (e) {
        list.innerHTML = '<div class="text-center py-5"><p class="text-danger">Failed to load listings.</p></div>'
    }
}

async function suspendListing(id, btn) {
    btn.disabled = true
    try { await api.put('/admin/listings/' + id + '/suspend'); doListingSearch() } catch (e) { btn.disabled = false }
}
async function activateListing(id, btn) {
    btn.disabled = true
    try { await api.put('/admin/listings/' + id + '/activate'); doListingSearch() } catch (e) { btn.disabled = false }
}

function debounce(fn, ms) {
    var timer
    return function () {
        var ctx = this, args = arguments
        clearTimeout(timer)
        timer = setTimeout(function () { fn.apply(ctx, args) }, ms)
    }
}
</script>
}
