@using System.Security.Claims
@using Dorm.Application.DTOs.Messages
@{
    Layout = User.FindFirstValue(ClaimTypes.Role) == "Student" ? "_BrowseLayout" : "_DashboardLayout";
    ViewData["Title"] = "Messages";
    var conversations = (IReadOnlyList<ConversationDto>)(ViewBag.Conversations ?? Array.Empty<ConversationDto>());
    var messages = (IReadOnlyList<MessageDto>)(ViewBag.Messages ?? Array.Empty<MessageDto>());
    var currentUserId = (Guid)ViewBag.CurrentUserId;
    var convoId = ViewData["ConversationId"]?.ToString();
    var activeConvo = conversations.FirstOrDefault(c => c.Id.ToString() == convoId);
}

@section Styles {
<style>
    .msg-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; }
    .msg-panel { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }
    .convo-list { max-height: 70vh; overflow-y: auto; }
    .convo-item {
        display: flex; align-items: center; gap: .75rem;
        padding: .85rem 1rem; border-bottom: 1px solid #f8fafc;
        text-decoration: none; color: #1e293b; transition: background .15s;
    }
    .convo-item:hover { background: #f8fafc; color: #1e293b; }
    .convo-item.active { background: rgba(249,115,22,.04); border-left: 3px solid #F97316; }
    .convo-avatar {
        width: 38px; height: 38px; border-radius: 50%; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .8rem; color: #64748b; flex-shrink: 0;
    }
    .convo-name { font-weight: 600; font-size: .88rem; }
    .convo-preview { font-size: .78rem; color: #94a3b8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .unread-dot { width: 8px; height: 8px; border-radius: 50%; background: #F97316; flex-shrink: 0; }

    .chat-area { min-height: 50vh; display: flex; flex-direction: column; }
    .chat-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #94a3b8; }
    .chat-empty i { font-size: 2.5rem; color: #cbd5e1; }

    #msg-list { flex: 1; max-height: 55vh; overflow-y: auto; padding: 1rem; }
    .bubble {
        max-width: 70%; padding: .6rem 1rem; border-radius: 14px;
        font-size: .88rem; line-height: 1.5; margin-bottom: .4rem;
        word-wrap: break-word;
    }
    .bubble-mine { background: #0f172a; color: #f8fafc; border-bottom-right-radius: 4px; }
    .bubble-other { background: #f1f5f9; color: #1e293b; border-bottom-left-radius: 4px; }

    .send-bar { padding: .75rem 1rem; border-top: 1px solid #f1f5f9; display: flex; gap: .5rem; }
    .send-bar input {
        flex: 1; border: 1px solid #e2e8f0; border-radius: 10px;
        padding: .55rem .85rem; font-size: .88rem; outline: none;
        transition: border-color .2s;
    }
    .send-bar input:focus { border-color: #F97316; }
    .btn-send {
        background: #F97316; color: #fff; border: none; border-radius: 10px;
        width: 40px; display: flex; align-items: center; justify-content: center;
        transition: background .2s;
    }
    .btn-send:hover { background: #ea6c10; }
</style>
}

<div class="msg-header mb-4">
    <h3>Messages</h3>
</div>
<div>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="msg-panel convo-list">
                @if (conversations.Count == 0)
                {
                    <div class="p-4 text-center">
                        <i class="bi bi-chat-dots" style="font-size:1.5rem;color:#cbd5e1"></i>
                        <p style="color:#94a3b8;font-size:.85rem;margin-top:.5rem">No conversations yet.</p>
                    </div>
                }
                else
                {
                    @foreach (var c in conversations)
                    {
                        var init = !string.IsNullOrEmpty(c.OtherUserName) ? c.OtherUserName[0].ToString().ToUpper() : "U";
                        var isActive = c.Id.ToString() == convoId;
                        <a href="/Chat/@c.Id" class="convo-item @(isActive ? "active" : "")">
                            <div class="convo-avatar">@init</div>
                            <div class="flex-grow-1" style="min-width:0">
                                <div class="convo-name">@c.OtherUserName</div>
                                <div class="convo-preview">@(c.LastMessageContent ?? "No messages yet")</div>
                            </div>
                            @if (c.UnreadCount > 0 && !isActive)
                            {
                                <div class="unread-dot"></div>
                            }
                        </a>
                    }
                }
            </div>
        </div>
        <div class="col-md-8">
            <div class="msg-panel chat-area">
                @if (activeConvo != null)
                {
                    <div style="padding:.75rem 1rem;border-bottom:1px solid #f1f5f9;font-weight:600;font-size:.9rem;color:#1e293b">
                        @activeConvo.OtherUserName
                        <span style="font-size:.78rem;color:#94a3b8;font-weight:400;margin-left:.5rem">@activeConvo.ApartmentTitle</span>
                    </div>
                }
                <div id="msg-list">
                    @foreach (var m in messages)
                    {
                        var mine = m.SenderId == currentUserId;
                        <div class="d-flex mb-2 @(mine ? "justify-content-end" : "justify-content-start")">
                            <div class="bubble @(mine ? "bubble-mine" : "bubble-other")">@m.Content</div>
                        </div>
                    }
                    @if (messages.Count == 0 && activeConvo != null)
                    {
                        <div class="chat-empty">
                            <p style="font-size:.85rem">No messages yet. Start the conversation!</p>
                        </div>
                    }
                </div>
                @if (activeConvo != null)
                {
                    <form method="post" action="/Chat/@convoId/Send" class="send-bar">
                        @Html.AntiForgeryToken()
                        <input type="text" name="content" placeholder="Type a message…" id="msg-input" autocomplete="off" required />
                        <button type="submit" class="btn-send"><i class="bi bi-send"></i></button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var msgList = document.getElementById('msg-list');
if (msgList) msgList.scrollTop = msgList.scrollHeight;
var msgInput = document.getElementById('msg-input');
if (msgInput) msgInput.focus();
</script>
}
