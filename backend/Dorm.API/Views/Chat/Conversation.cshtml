@using System.Security.Claims
@using Dorm.Application.DTOs.Messages
@{
    Layout = User.FindFirstValue(ClaimTypes.Role) == "Student" ? "_BrowseLayout" : "_DashboardLayout";
    ViewData["Title"] = "Messages";
    var conversations = (IReadOnlyList<ConversationDto>)(ViewBag.Conversations ?? Array.Empty<ConversationDto>());
    var messages = (IReadOnlyList<MessageDto>)(ViewBag.Messages ?? Array.Empty<MessageDto>());
    var currentUserId = (Guid)ViewBag.CurrentUserId;
    var convoId = ViewData["ConversationId"]?.ToString();
    var activeConvo = conversations.FirstOrDefault(c => c.Id.ToString() == convoId);
}

@section Styles {
<style>
    .chat-layout { display: flex; gap: 1rem; max-width: 1000px; margin: 1.5rem auto; padding: 0 1rem; min-height: 70vh; }

    /* ── Sidebar ── */
    .chat-sidebar {
        width: 300px; flex-shrink: 0;
        background: #fff; border-radius: 16px; border: 1px solid #e2e8f0;
        overflow: hidden; display: flex; flex-direction: column;
    }
    .chat-sidebar-header {
        padding: .85rem 1rem; border-bottom: 1px solid #f1f5f9;
        font-weight: 800; font-size: .95rem; color: #1e293b;
        display: flex; align-items: center; gap: .5rem;
    }
    .sidebar-scroll { flex: 1; overflow-y: auto; }
    .sidebar-scroll::-webkit-scrollbar { width: 3px; }
    .sidebar-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 3px; }

    .sb-item {
        display: flex; align-items: center; gap: .75rem;
        padding: .8rem 1rem; border-bottom: 1px solid #f8fafc;
        text-decoration: none; color: #1e293b; transition: all .15s;
    }
    .sb-item:last-child { border-bottom: none; }
    .sb-item:hover { background: #f8fafc; }
    .sb-item.active { background: rgba(249,115,22,.04); border-left: 3px solid #F97316; }
    .sb-item.unread { background: rgba(249,115,22,.02); }

    .sb-avatar {
        width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0; position: relative;
    }
    .sb-avatar-circle {
        width: 100%; height: 100%; border-radius: 50%;
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .78rem; color: #64748b;
    }
    .sb-item.unread .sb-avatar-circle {
        background: linear-gradient(135deg, #F97316, #fb923c); color: #fff;
    }
    .sb-unread-badge {
        position: absolute; top: -2px; right: -2px;
        min-width: 16px; height: 16px; border-radius: 50%;
        background: #F97316; color: #fff; font-size: .55rem; font-weight: 800;
        display: flex; align-items: center; justify-content: center;
        border: 2px solid #fff; padding: 0 3px;
    }

    .sb-body { flex: 1; min-width: 0; }
    .sb-top { display: flex; justify-content: space-between; align-items: baseline; }
    .sb-name { font-weight: 600; font-size: .82rem; color: #1e293b; }
    .sb-item.unread .sb-name { font-weight: 800; color: #0f172a; }
    .sb-time { font-size: .65rem; color: #cbd5e1; }
    .sb-preview {
        font-size: .75rem; color: #94a3b8; white-space: nowrap;
        overflow: hidden; text-overflow: ellipsis; margin-top: .1rem;
    }
    .sb-item.unread .sb-preview { color: #475569; font-weight: 500; }

    /* ── Main Chat ── */
    .chat-main {
        flex: 1; background: #fff; border-radius: 16px; border: 1px solid #e2e8f0;
        display: flex; flex-direction: column; overflow: hidden;
    }
    .chat-top {
        padding: .75rem 1.25rem; border-bottom: 1px solid #f1f5f9;
        display: flex; align-items: center; justify-content: space-between;
    }
    .chat-top-user { display: flex; align-items: center; gap: .65rem; }
    .chat-top-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: linear-gradient(135deg, #F97316, #fb923c);
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-weight: 700; font-size: .75rem;
    }
    .chat-top-name { font-weight: 700; font-size: .9rem; color: #1e293b; }
    .chat-top-apt { font-size: .75rem; color: #94a3b8; }
    .btn-view-listing {
        font-size: .78rem; color: #F97316; font-weight: 600; text-decoration: none;
        display: flex; align-items: center; gap: .25rem;
        padding: .35rem .75rem; border: 1px solid rgba(249,115,22,.2); border-radius: 8px;
        transition: all .15s;
    }
    .btn-view-listing:hover { background: rgba(249,115,22,.06); color: #ea6c10; }

    .msg-scroll {
        flex: 1; overflow-y: auto; padding: 1.25rem;
        background: #fafbfc;
    }
    .msg-scroll::-webkit-scrollbar { width: 4px; }
    .msg-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }

    .msg-group { margin-bottom: 1rem; }
    .msg-date {
        text-align: center; margin: 1rem 0;
        font-size: .7rem; font-weight: 600; color: #94a3b8;
    }
    .msg-date span {
        background: #fff; padding: .2rem .6rem; border-radius: 6px;
        border: 1px solid #f1f5f9;
    }

    .bubble-row { display: flex; margin-bottom: .35rem; align-items: flex-end; gap: .35rem; }
    .bubble-row.mine { justify-content: flex-end; }
    .bubble-row.other { justify-content: flex-start; }
    .bubble {
        max-width: 65%; padding: .6rem 1rem; border-radius: 16px;
        font-size: .88rem; line-height: 1.55; word-wrap: break-word;
        position: relative;
    }
    .bubble-mine {
        background: #0f172a; color: #f8fafc;
        border-bottom-right-radius: 4px;
    }
    .bubble-other {
        background: #fff; color: #1e293b; border: 1px solid #f1f5f9;
        border-bottom-left-radius: 4px;
    }
    .bubble-time {
        font-size: .62rem; color: #94a3b8; margin-top: .2rem;
    }
    .bubble-mine .bubble-time { text-align: right; color: rgba(248,250,252,.4); }
    .bubble-read {
        font-size: .6rem; color: rgba(248,250,252,.35);
        display: flex; align-items: center; gap: .15rem; justify-content: flex-end;
    }
    .bubble-read.is-read { color: #10b981; }

    .chat-empty-msg {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; justify-content: center; color: #94a3b8;
        background: #fafbfc;
    }
    .chat-empty-msg i { font-size: 2rem; color: #e2e8f0; margin-bottom: .5rem; }

    .send-bar {
        padding: .75rem 1rem; border-top: 1px solid #f1f5f9;
        display: flex; gap: .5rem; background: #fff;
    }
    .send-bar input {
        flex: 1; border: 1px solid #e2e8f0; border-radius: 12px;
        padding: .6rem 1rem; font-size: .88rem; outline: none;
        font-family: 'Inter', sans-serif; transition: border-color .2s;
    }
    .send-bar input:focus { border-color: #F97316; box-shadow: 0 0 0 3px rgba(249,115,22,.08); }
    .btn-send {
        background: #F97316; color: #fff; border: none; border-radius: 12px;
        width: 44px; display: flex; align-items: center; justify-content: center;
        transition: all .2s; cursor: pointer;
    }
    .btn-send:hover { background: #ea6c10; transform: scale(1.05); }

    @@media (max-width: 767px) {
        .chat-layout { flex-direction: column; }
        .chat-sidebar { width: 100%; max-height: 200px; }
    }
</style>
}

<div class="chat-layout">
    <div class="chat-sidebar">
        <div class="chat-sidebar-header"><i class="bi bi-chat-dots" style="color:#F97316"></i> Chats</div>
        <div class="sidebar-scroll">
            @if (conversations.Count == 0)
            {
                <div class="p-4 text-center">
                    <p style="color:#94a3b8;font-size:.82rem">No conversations.</p>
                </div>
            }
            else
            {
                @foreach (var c in conversations)
                {
                    var init = string.Join("", (c.OtherUserName ?? "U").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(n => n[0])).ToUpper();
                    if (init.Length == 0) init = "U";
                    var isActive = c.Id.ToString() == convoId;
                    var hasUnread = c.UnreadCount > 0 && !isActive;
                    var timeAgo = (DateTime.UtcNow - c.LastMessageAt).TotalMinutes < 60
                        ? $"{Math.Max(1, (int)(DateTime.UtcNow - c.LastMessageAt).TotalMinutes)}m"
                        : (DateTime.UtcNow - c.LastMessageAt).TotalHours < 24
                            ? $"{(int)(DateTime.UtcNow - c.LastMessageAt).TotalHours}h"
                            : c.LastMessageAt.ToString("MMM d");
                    <a href="/Chat/@c.Id" class="sb-item @(isActive ? "active" : "") @(hasUnread ? "unread" : "")">
                        <div class="sb-avatar">
                            <div class="sb-avatar-circle">@init</div>
                            @if (hasUnread)
                            {
                                <div class="sb-unread-badge">@c.UnreadCount</div>
                            }
                        </div>
                        <div class="sb-body">
                            <div class="sb-top">
                                <span class="sb-name">@c.OtherUserName</span>
                                <span class="sb-time">@timeAgo</span>
                            </div>
                            <div class="sb-preview">@(c.LastMessageContent ?? "No messages yet")</div>
                        </div>
                    </a>
                }
            }
        </div>
    </div>

    <div class="chat-main">
        @if (activeConvo != null)
        {
            var topInit = string.Join("", (activeConvo.OtherUserName ?? "U").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(n => n[0])).ToUpper();
            <div class="chat-top">
                <div class="chat-top-user">
                    <div class="chat-top-avatar">@topInit</div>
                    <div>
                        <div class="chat-top-name">@activeConvo.OtherUserName</div>
                        <div class="chat-top-apt"><i class="bi bi-building me-1"></i>@activeConvo.ApartmentTitle</div>
                    </div>
                </div>
                <a href="/Apartment/Detail/@activeConvo.ApartmentId" class="btn-view-listing"><i class="bi bi-house-door"></i> View Listing</a>
            </div>

            <div class="msg-scroll" id="msg-list">
                @if (messages.Count == 0)
                {
                    <div class="chat-empty-msg">
                        <i class="bi bi-chat-text"></i>
                        <p style="font-size: .85rem">No messages yet. Say hello!</p>
                    </div>
                }
                else
                {
                    var lastDate = "";
                    @foreach (var m in messages)
                    {
                        var mine = m.SenderId == currentUserId;
                        var msgDate = m.SentAt.ToString("MMM d, yyyy");
                        if (msgDate != lastDate)
                        {
                            lastDate = msgDate;
                            <div class="msg-date"><span>@msgDate</span></div>
                        }
                        <div class="bubble-row @(mine ? "mine" : "other")">
                            <div>
                                <div class="bubble @(mine ? "bubble-mine" : "bubble-other")">@m.Content</div>
                                <div class="bubble-time">
                                    @m.SentAt.ToString("h:mm tt")
                                    @if (mine)
                                    {
                                        <span class="bubble-read @(m.IsRead ? "is-read" : "")">
                                            <i class="bi @(m.IsRead ? "bi-check-all" : "bi-check")"></i>
                                            @(m.IsRead ? "Read" : "Sent")
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <form method="post" action="/Chat/@convoId/Send" class="send-bar">
                @Html.AntiForgeryToken()
                <input type="text" name="content" placeholder="Type a message…" id="msg-input" autocomplete="off" required />
                <button type="submit" class="btn-send"><i class="bi bi-send-fill"></i></button>
            </form>
        }
        else
        {
            <div class="chat-empty-msg" style="min-height:60vh">
                <i class="bi bi-chat-dots" style="font-size:2.5rem;color:#e2e8f0"></i>
                <p style="font-size:.9rem;color:#94a3b8;margin-top:.75rem">Select a conversation to start chatting</p>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
var msgList = document.getElementById('msg-list');
if (msgList) msgList.scrollTop = msgList.scrollHeight;
var msgInput = document.getElementById('msg-input');
if (msgInput) msgInput.focus();
</script>
}
