@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "Messages";
}

@section Styles {
<style>
    .msg-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; }
    .msg-panel { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }
    .convo-list { max-height: 70vh; overflow-y: auto; }
    .convo-item {
        display: block; padding: .85rem 1rem; border-bottom: 1px solid #f8fafc;
        text-decoration: none; color: #1e293b; transition: background .15s; cursor: pointer;
    }
    .convo-item:hover { background: #f8fafc; color: #1e293b; }
    .convo-item.active { background: rgba(249,115,22,.04); border-left: 3px solid #F97316; }
    .convo-avatar {
        width: 38px; height: 38px; border-radius: 50%; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .8rem; color: #64748b; flex-shrink: 0;
    }
    .convo-name { font-weight: 600; font-size: .88rem; }
    .convo-preview { font-size: .78rem; color: #94a3b8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .unread-dot { width: 8px; height: 8px; border-radius: 50%; background: #F97316; flex-shrink: 0; }

    .chat-area { min-height: 50vh; display: flex; flex-direction: column; }
    .chat-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #94a3b8; }
    .chat-empty i { font-size: 2.5rem; color: #cbd5e1; }

    #msg-list { flex: 1; max-height: 55vh; overflow-y: auto; padding: 1rem; }
    .bubble {
        max-width: 70%; padding: .6rem 1rem; border-radius: 14px;
        font-size: .88rem; line-height: 1.5; margin-bottom: .4rem;
    }
    .bubble-mine { background: #0f172a; color: #f8fafc; border-bottom-right-radius: 4px; }
    .bubble-other { background: #f1f5f9; color: #1e293b; border-bottom-left-radius: 4px; }

    .send-bar { padding: .75rem 1rem; border-top: 1px solid #f1f5f9; display: flex; gap: .5rem; }
    .send-bar input {
        flex: 1; border: 1px solid #e2e8f0; border-radius: 10px;
        padding: .55rem .85rem; font-size: .88rem; outline: none;
        transition: border-color .2s;
    }
    .send-bar input:focus { border-color: #F97316; }
    .btn-send {
        background: #F97316; color: #fff; border: none; border-radius: 10px;
        width: 40px; display: flex; align-items: center; justify-content: center;
        transition: background .2s;
    }
    .btn-send:hover { background: #ea6c10; }
</style>
}

<div class="container" style="max-width:1100px;padding:2.5rem 1rem">
    <div class="msg-header mb-4">
        <h3>Messages</h3>
    </div>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="msg-panel convo-list" id="convo-list">
                <div class="text-center py-4"><div class="spinner-border spinner-border-sm" style="color:#94a3b8"></div></div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="msg-panel chat-area" id="convo-area">
                <div class="chat-empty">
                    <i class="bi bi-chat-dots"></i>
                    <p class="mt-2" style="font-size:.9rem">Pick a conversation to start messaging.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var activeConvoId = null
var pollInterval = null

auth.initAuth().then(loadConversations)

async function loadConversations() {
    var list = document.getElementById('convo-list')
    try {
        var convos = await api.get('/conversations')
        convos = convos || []
        if (convos.length === 0) {
            list.innerHTML = '<div class="p-4 text-center"><i class="bi bi-chat-dots" style="font-size:1.5rem;color:#cbd5e1"></i><p style="color:#94a3b8;font-size:.85rem;margin-top:.5rem">No conversations yet.</p></div>'
            return
        }
        list.innerHTML = convos.map(function (c) {
            var init = (c.otherPartyName || 'U').charAt(0).toUpperCase()
            return '<div class="convo-item d-flex align-items-center gap-3' + (c.id === activeConvoId ? ' active' : '') + '" onclick="openConvo(\'' + c.id + '\')">' +
                '<div class="convo-avatar">' + init + '</div>' +
                '<div class="flex-grow-1" style="min-width:0">' +
                '<div class="convo-name">' + escapeHtml(c.otherPartyName || '') + '</div>' +
                '<div class="convo-preview">' + escapeHtml(c.lastMessageText || 'No messages yet') + '</div></div>' +
                (c.unreadCount > 0 ? '<div class="unread-dot"></div>' : '') +
                '</div>'
        }).join('')
    } catch (e) {
        list.innerHTML = '<div class="p-4"><p style="color:#ef4444;font-size:.85rem">Failed to load conversations.</p></div>'
    }
}

async function openConvo(id) {
    activeConvoId = id
    loadConversations()
    if (pollInterval) clearInterval(pollInterval)
    var area = document.getElementById('convo-area')
    area.innerHTML = '<div class="text-center py-5"><div class="spinner-border" style="color:#94a3b8"></div></div>'
    try {
        await api.put('/conversations/' + id + '/read')
        await loadMessages()
        pollInterval = setInterval(loadMessages, 10000)
    } catch (e) {
        area.innerHTML = '<div class="chat-empty"><p style="color:#ef4444">Failed to load messages.</p></div>'
    }
}

async function loadMessages() {
    if (!activeConvoId) return
    var area = document.getElementById('convo-area')
    var messages = await api.get('/conversations/' + activeConvoId + '/messages')
    messages = messages || []
    var user = auth.getUser()

    area.innerHTML =
        '<div id="msg-list">' +
        messages.map(function (m) {
            var mine = m.senderId === user.id
            return '<div class="d-flex mb-2 ' + (mine ? 'justify-content-end' : 'justify-content-start') + '">' +
                '<div class="bubble ' + (mine ? 'bubble-mine' : 'bubble-other') + '">' + escapeHtml(m.text) + '</div></div>'
        }).join('') +
        '</div>' +
        '<div class="send-bar"><input type="text" placeholder="Type a message…" id="msg-input" />' +
        '<button class="btn-send" onclick="sendMsg()"><i class="bi bi-send"></i></button></div>'

    var list = document.getElementById('msg-list')
    if (list) list.scrollTop = list.scrollHeight

    document.getElementById('msg-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') sendMsg() })
}

async function sendMsg() {
    var input = document.getElementById('msg-input')
    var text = input.value.trim()
    if (!text) return
    input.value = ''
    try {
        await api.post('/conversations/' + activeConvoId + '/messages', { body: { text: text } })
        await loadMessages()
        loadConversations()
    } catch (err) {}
}
</script>
}
