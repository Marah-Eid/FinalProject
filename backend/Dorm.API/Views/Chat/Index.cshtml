@using Dorm.Application.DTOs.Messages
@{
    Layout = User.FindFirstValue(ClaimTypes.Role) == "Student" ? "_BrowseLayout" : "_DashboardLayout";
    ViewData["Title"] = "Messages";
    var conversations = (IReadOnlyList<ConversationDto>)(ViewBag.Conversations ?? Array.Empty<ConversationDto>());
}

@section Styles {
<style>
    .msg-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; }
    .msg-panel { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }
    .convo-list { max-height: 70vh; overflow-y: auto; }
    .convo-item {
        display: flex; align-items: center; gap: .75rem;
        padding: .85rem 1rem; border-bottom: 1px solid #f8fafc;
        text-decoration: none; color: #1e293b; transition: background .15s;
    }
    .convo-item:hover { background: #f8fafc; color: #1e293b; }
    .convo-avatar {
        width: 38px; height: 38px; border-radius: 50%; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .8rem; color: #64748b; flex-shrink: 0;
    }
    .convo-name { font-weight: 600; font-size: .88rem; }
    .convo-preview { font-size: .78rem; color: #94a3b8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .unread-dot { width: 8px; height: 8px; border-radius: 50%; background: #F97316; flex-shrink: 0; }

    .chat-empty { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #94a3b8; padding: 3rem 1rem; }
    .chat-empty i { font-size: 2.5rem; color: #cbd5e1; }
</style>
}

<div class="msg-header mb-4">
    <h3>Messages</h3>
</div>

<div class="msg-panel convo-list">
    @if (conversations.Count == 0)
    {
        <div class="chat-empty">
            <i class="bi bi-chat-dots"></i>
            <p class="mt-2" style="font-size:.9rem">No conversations yet.</p>
        </div>
    }
    else
    {
        @foreach (var c in conversations)
        {
            var init = !string.IsNullOrEmpty(c.OtherUserName) ? c.OtherUserName[0].ToString().ToUpper() : "U";
            <a href="/Chat/@c.Id" class="convo-item">
                <div class="convo-avatar">@init</div>
                <div class="flex-grow-1" style="min-width:0">
                    <div class="convo-name">@c.OtherUserName</div>
                    <div class="convo-preview">@(c.LastMessageContent ?? "No messages yet")</div>
                </div>
                @if (c.UnreadCount > 0)
                {
                    <div class="unread-dot"></div>
                }
            </a>
        }
    }
</div>
