@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Admin Panel";
}

@section Styles {
<style>
    .admin-tabs {
        display: flex; gap: .5rem; margin-bottom: 1.5rem;
        border-bottom: 2px solid #f1f5f9; padding-bottom: 0;
    }
    .admin-tab {
        padding: .55rem 1.1rem; border: none; background: transparent;
        font-size: .85rem; font-weight: 600; color: #94a3b8;
        border-bottom: 2px solid transparent; margin-bottom: -2px;
        cursor: pointer; transition: all .15s;
    }
    .admin-tab:hover { color: #475569; }
    .admin-tab.active { color: #F97316; border-bottom-color: #F97316; }

    .admin-section { display: none; }
    .admin-section.active { display: block; }

    .testi-card {
        background: #fff; border-radius: 12px; border: 1px solid #e2e8f0;
        padding: 1rem 1.25rem; margin-bottom: .75rem;
        display: flex; align-items: flex-start; gap: 1rem;
    }
    .testi-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: #F97316; color: #fff; font-weight: 700; font-size: .7rem;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .testi-body { flex: 1; min-width: 0; }
    .testi-body .name { font-weight: 700; font-size: .85rem; color: #1e293b; }
    .testi-body .role { font-size: .72rem; color: #94a3b8; }
    .testi-body .text { font-size: .85rem; color: #475569; margin: .3rem 0; line-height: 1.6; }
    .testi-stars i { font-size: .75rem; }
    .testi-actions { display: flex; gap: .4rem; flex-shrink: 0; align-self: center; }
    .btn-approve {
        background: rgba(16,185,129,.1); color: #10b981; border: none;
        border-radius: 6px; padding: .35rem .7rem; font-size: .78rem; font-weight: 600;
        cursor: pointer; transition: all .15s;
    }
    .btn-approve:hover { background: rgba(16,185,129,.2); }
    .btn-deny {
        background: rgba(239,68,68,.08); color: #ef4444; border: none;
        border-radius: 6px; padding: .35rem .7rem; font-size: .78rem; font-weight: 600;
        cursor: pointer; transition: all .15s;
    }
    .btn-deny:hover { background: rgba(239,68,68,.15); }

    .badge-pending { background: rgba(234,179,8,.1); color: #eab308; font-size: .7rem; font-weight: 600; padding: .2rem .5rem; border-radius: 4px; }
    .badge-approved { background: rgba(16,185,129,.1); color: #10b981; font-size: .7rem; font-weight: 600; padding: .2rem .5rem; border-radius: 4px; }

    .stat-row { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .admin-stat {
        flex: 1; min-width: 140px; background: #fff; border-radius: 12px;
        border: 1px solid #f1f5f9; padding: 1rem;
        display: flex; align-items: center; gap: .75rem;
    }
    .admin-stat-icon {
        width: 40px; height: 40px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
    }
    .admin-stat .label { font-size: .72rem; color: #94a3b8; font-weight: 500; }
    .admin-stat .value { font-size: 1.15rem; font-weight: 800; color: #1e293b; }

    .empty-admin { text-align: center; padding: 3rem 1rem; color: #94a3b8; }
    .empty-admin i { font-size: 2rem; color: #cbd5e1; }
    .empty-admin p { margin-top: .5rem; font-size: .88rem; }
</style>
}

<div id="admin-content">
    <div class="admin-tabs">
        <button class="admin-tab active" onclick="showTab('dashboard')">Dashboard</button>
        <button class="admin-tab" onclick="showTab('testimonials')">Testimonials</button>
    </div>

    <!-- Dashboard Tab -->
    <div class="admin-section active" id="tab-dashboard">
        <div class="stat-row" id="admin-stats">
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(59,130,246,.1);color:#3b82f6"><i class="bi bi-people-fill"></i></div>
                <div><div class="label">Total Users</div><div class="value" id="stat-users">—</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(16,185,129,.1);color:#10b981"><i class="bi bi-building"></i></div>
                <div><div class="label">Active Listings</div><div class="value" id="stat-listings">—</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(234,179,8,.1);color:#eab308"><i class="bi bi-star-fill"></i></div>
                <div><div class="label">Pending Reviews</div><div class="value" id="stat-pending-reviews">—</div></div>
            </div>
            <div class="admin-stat">
                <div class="admin-stat-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6"><i class="bi bi-flag-fill"></i></div>
                <div><div class="label">Pending Reports</div><div class="value" id="stat-reports">—</div></div>
            </div>
        </div>
    </div>

    <!-- Testimonials Tab -->
    <div class="admin-section" id="tab-testimonials">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 style="font-weight:700;font-size:.95rem;color:#1e293b;margin:0">User Testimonials</h6>
            <div style="display:flex;gap:.5rem">
                <button class="admin-tab active" style="font-size:.78rem;padding:.3rem .7rem" id="filter-all" onclick="filterTestimonials('all')">All</button>
                <button class="admin-tab" style="font-size:.78rem;padding:.3rem .7rem" id="filter-pending" onclick="filterTestimonials('pending')">Pending</button>
                <button class="admin-tab" style="font-size:.78rem;padding:.3rem .7rem" id="filter-approved" onclick="filterTestimonials('approved')">Approved</button>
            </div>
        </div>
        <div id="testi-admin-list">
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm" style="color:#94a3b8"></div></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var allTestimonials = []
var currentFilter = 'all'

auth.initAuth().then(function () {
    var user = auth.getUser()
    if (!user || user.role !== 2) { window.location.href = '/'; return }
    loadAdminStats()
    loadAdminTestimonials()
})

function showTab(name) {
    document.querySelectorAll('.admin-section').forEach(function (s) { s.classList.remove('active') })
    document.querySelectorAll('.admin-tabs .admin-tab').forEach(function (t) { t.classList.remove('active') })
    document.getElementById('tab-' + name).classList.add('active')
    event.target.classList.add('active')
}

function loadAdminStats() {
    api.get('/admin/dashboard').then(function (d) {
        document.getElementById('stat-users').textContent = d.totalUsers || 0
        document.getElementById('stat-listings').textContent = d.activeListings || 0
        document.getElementById('stat-reports').textContent = d.pendingReports || 0
    }).catch(function () {})

    api.get('/testimonials/all').then(function (list) {
        var pending = (list || []).filter(function (t) { return !t.isApproved }).length
        document.getElementById('stat-pending-reviews').textContent = pending
    }).catch(function () {})
}

function loadAdminTestimonials() {
    api.get('/testimonials/all').then(function (list) {
        allTestimonials = list || []
        renderTestimonials()
    }).catch(function () {
        document.getElementById('testi-admin-list').innerHTML = '<div class="empty-admin"><i class="bi bi-exclamation-circle"></i><p>Failed to load testimonials.</p></div>'
    })
}

function filterTestimonials(filter) {
    currentFilter = filter
    document.querySelectorAll('#tab-testimonials .admin-tab').forEach(function (t) { t.classList.remove('active') })
    document.getElementById('filter-' + filter).classList.add('active')
    renderTestimonials()
}

function renderTestimonials() {
    var list = allTestimonials
    if (currentFilter === 'pending') list = list.filter(function (t) { return !t.isApproved })
    if (currentFilter === 'approved') list = list.filter(function (t) { return t.isApproved })

    var container = document.getElementById('testi-admin-list')
    if (list.length === 0) {
        container.innerHTML = '<div class="empty-admin"><i class="bi bi-chat-square-text"></i><p>No testimonials found.</p></div>'
        return
    }

    container.innerHTML = list.map(function (t) {
        var initials = (t.userName || 'U').split(' ').map(function(n){return n[0]}).join('').substring(0,2).toUpperCase()
        var stars = ''
        for (var i = 1; i <= 5; i++) {
            stars += '<i class="bi ' + (i <= t.stars ? 'bi-star-fill' : 'bi-star') + '" style="color:' + (i <= t.stars ? '#F97316' : '#e2e8f0') + '"></i>'
        }
        var statusBadge = t.isApproved
            ? '<span class="badge-approved">Approved</span>'
            : '<span class="badge-pending">Pending</span>'
        var actions = ''
        if (!t.isApproved) {
            actions += '<button class="btn-approve" onclick="approveTestimonial(\'' + t.id + '\')"><i class="bi bi-check-lg me-1"></i>Approve</button>'
        }
        actions += '<button class="btn-deny" onclick="deleteTestimonial(\'' + t.id + '\')"><i class="bi bi-trash me-1"></i>Delete</button>'

        return '<div class="testi-card">' +
            '<div class="testi-avatar">' + escapeHtml(initials) + '</div>' +
            '<div class="testi-body">' +
            '<div class="d-flex align-items-center gap-2"><span class="name">' + escapeHtml(t.userName || 'User') + '</span>' +
            '<span class="role">' + escapeHtml(t.userRole || '') + '</span>' + statusBadge + '</div>' +
            '<div class="testi-stars mb-1">' + stars + '</div>' +
            '<div class="text">' + escapeHtml(t.text) + '</div></div>' +
            '<div class="testi-actions">' + actions + '</div></div>'
    }).join('')
}

function approveTestimonial(id) {
    api.put('/testimonials/' + id + '/approve').then(function () {
        loadAdminTestimonials()
        loadAdminStats()
    }).catch(function (err) {
        alert(err.message || 'Failed to approve.')
    })
}

function deleteTestimonial(id) {
    if (!confirm('Delete this testimonial?')) return
    api.delete('/testimonials/' + id).then(function () {
        loadAdminTestimonials()
        loadAdminStats()
    }).catch(function (err) {
        alert(err.message || 'Failed to delete.')
    })
}
</script>
}
