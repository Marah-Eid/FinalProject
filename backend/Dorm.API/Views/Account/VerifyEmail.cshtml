@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Verify Email";
    var success = ViewData["Success"] as string;
    var error = ViewData["Error"] as string;
}

<div class="text-center">
    @if (!string.IsNullOrEmpty(success))
    {
        <i class="bi bi-check-circle-fill" style="font-size:3rem;color:#10b981"></i>
        <h1 class="auth-title mt-3">@success</h1>
        <a href="/" class="btn btn-primary mt-3">Continue</a>
    }
    else if (!string.IsNullOrEmpty(error))
    {
        <i class="bi bi-x-circle-fill" style="font-size:3rem;color:#ef4444"></i>
        <h1 class="auth-title mt-3">@error</h1>
        <a href="/Account/Login" class="btn btn-outline-secondary mt-3">Back to login</a>
    }
    else
    {
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <h1 class="auth-title">Verifying your email...</h1>
    }
</div>
