@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
    var success = ViewData["Success"] as string;
}

<h1 class="auth-title">Reset your password</h1>
<p class="auth-subtitle mb-4">Enter your email and we'll send you a reset link.</p>

@if (!string.IsNullOrEmpty(success))
{
    <div class="alert alert-success">@success</div>
}
else
{
    <form method="post" asp-action="ForgotPasswordPost" asp-controller="Account">
        @Html.AntiForgeryToken()
        <div class="form-group position-relative has-icon-left mb-4">
            <input type="email" class="form-control form-control-xl" placeholder="Email" name="email" required />
            <div class="form-control-icon"><i class="bi bi-envelope"></i></div>
        </div>
        <button class="btn btn-primary btn-block btn-lg shadow-lg mt-3 w-100" type="submit">Send reset link</button>
    </form>
}

<div class="text-center mt-4">
    <p><a href="/Account/Login">Back to login</a></p>
</div>
