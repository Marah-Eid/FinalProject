@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}

<h1 class="auth-title">Reset your password</h1>
<p class="auth-subtitle mb-4">Enter your email and we'll send you a reset link.</p>

<div class="alert alert-success d-none" id="forgot-success"></div>
<div class="alert alert-danger d-none" id="forgot-error"></div>

<form id="forgot-form" novalidate>
    <div class="form-group position-relative has-icon-left mb-4">
        <input type="email" class="form-control form-control-xl" placeholder="Email" id="forgot-email" required />
        <div class="form-control-icon"><i class="bi bi-envelope"></i></div>
    </div>
    <button class="btn btn-primary btn-block btn-lg shadow-lg mt-3 w-100" type="submit" id="forgot-btn">Send reset link</button>
</form>

<div class="text-center mt-4">
    <p><a href="/Account/Login">Back to login</a></p>
</div>

@section Scripts {
<script>
document.getElementById('forgot-form').addEventListener('submit', async function (e) {
    e.preventDefault()
    var email = document.getElementById('forgot-email').value.trim()
    if (!email) return

    var btn = document.getElementById('forgot-btn')
    btn.disabled = true

    try {
        await api.post('/auth/forgot-password', { body: { email: email } })
        document.getElementById('forgot-success').textContent = 'Check your inbox — we sent a reset link.'
        document.getElementById('forgot-success').classList.remove('d-none')
        document.getElementById('forgot-form').classList.add('d-none')
    } catch (err) {
        document.getElementById('forgot-error').textContent = err.message || 'Something went wrong. Please try again.'
        document.getElementById('forgot-error').classList.remove('d-none')
        btn.disabled = false
    }
})
</script>
}
