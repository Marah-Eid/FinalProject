<!-- Nearby Apartments (logged-in students with university set) -->
@if (ViewBag.NearbyApartments is IReadOnlyList<Dorm.Application.DTOs.Apartments.ApartmentListItemDto> nearby && nearby.Count > 0)
{
    var uni = (Dorm.Domain.Enums.University)ViewBag.StudentUniversity;
    <section class="nearby-section">
        <div class="container">
            <div class="nearby-header reveal">
                <div>
                    <div class="section-label"><span><i class="bi bi-mortarboard me-1"></i> Near Your Campus</span></div>
                    <h2 class="section-title">Apartments near @uni</h2>
                    <p class="nearby-subtitle">Handpicked listings closest to your university, filtered by your gender.</p>
                </div>
                <a href="/Browse?university=@((int)uni)" class="btn-view-all-nearby">View all <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="nearby-grid">
                @foreach (var apt in nearby)
                {
                    var genderLabel = apt.GenderType switch { Dorm.Domain.Enums.GenderType.MaleOnly => "Male", Dorm.Domain.Enums.GenderType.FemaleOnly => "Female", _ => "Mixed" };
                    <a href="/Apartment/Detail/@apt.Id" class="text-decoration-none">
                        <div class="nearby-card">
                            <div class="nearby-card-img">
                                @if (!string.IsNullOrEmpty(apt.MainPhotoUrl))
                                {
                                    <img src="@apt.MainPhotoUrl" alt="@apt.Title" />
                                }
                                else
                                {
                                    <i class="bi bi-building"></i>
                                }
                                <div class="nearby-card-spots"><i class="bi bi-people"></i> @apt.AvailableSpots spot@(apt.AvailableSpots != 1 ? "s" : "")</div>
                                @if (apt.CompatibilityScore is int score && score > 0)
                                {
                                    <div class="nearby-card-match"><i class="bi bi-heart-fill"></i> @score%</div>
                                }
                            </div>
                            <div class="nearby-card-body">
                                <span class="nearby-card-title">@apt.Title</span>
                                <div class="nearby-card-meta"><i class="bi bi-geo-alt"></i> @apt.Neighborhood, @apt.City</div>
                                <div class="nearby-card-bottom">
                                    <div class="nearby-card-price">@Math.Round(apt.PricePerPerson) JOD <span>/person/mo</span></div>
                                    <div class="nearby-card-tags">
                                        @if (apt.IsFurnished) { <span class="nearby-tag"><i class="bi bi-lamp"></i> Furnished</span> }
                                        <span class="nearby-tag"><i class="bi bi-person"></i> @genderLabel</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
}

