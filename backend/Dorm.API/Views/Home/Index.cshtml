@section Scripts {
<script>
// ---- Scroll reveal (Intersection Observer) ----
(function () {
    var reveals = document.querySelectorAll('.reveal, .reveal-left, .reveal-right')
    if (!('IntersectionObserver' in window)) {
        reveals.forEach(function (el) { el.classList.add('visible') })
        return
    }
    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible')
                observer.unobserve(entry.target)
            }
        })
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' })

    reveals.forEach(function (el) { observer.observe(el) })
})();

// ---- Counter animation for stat numbers ----
(function () {
    var counted = false
    var counters = document.querySelectorAll('.num[data-count]')
    if (!counters.length) return

    function animateCounters() {
        if (counted) return
        counted = true
        counters.forEach(function (el) {
            var target = parseInt(el.getAttribute('data-count'))
            var suffix = el.getAttribute('data-suffix') || ''
            var duration = 1600
            var start = 0
            var startTime = null

            function step(timestamp) {
                if (!startTime) startTime = timestamp
                var progress = Math.min((timestamp - startTime) / duration, 1)
                var eased = 1 - Math.pow(1 - progress, 3)
                var current = Math.round(eased * target)
                el.textContent = current + suffix
                if (progress < 1) requestAnimationFrame(step)
            }
            requestAnimationFrame(step)
        })
    }

    if (!('IntersectionObserver' in window)) { animateCounters(); return }
    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) { animateCounters(); observer.disconnect() }
        })
    }, { threshold: 0.3 })

    var statsSection = document.querySelector('.stats-section')
    if (statsSection) observer.observe(statsSection)
})();

// ---- Tilt on feature cards (subtle) ----
(function () {
    document.querySelectorAll('.feat-card').forEach(function (card) {
        card.addEventListener('mousemove', function (e) {
            var rect = card.getBoundingClientRect()
            var x = e.clientX - rect.left
            var y = e.clientY - rect.top
            var cx = rect.width / 2
            var cy = rect.height / 2
            var rotateX = ((y - cy) / cy) * -4
            var rotateY = ((x - cx) / cx) * 4
            card.style.transform = 'translateY(-6px) perspective(600px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg)'
        })
        card.addEventListener('mouseleave', function () {
            card.style.transform = ''
        })
    })
})();

// ---- Testimonials ----
function loadTestimonials() {
    api.get('/testimonials/approved').then(function (list) {
        document.getElementById('testimonials-loading').classList.add('d-none')
        if (!list || list.length === 0) {
            document.getElementById('testimonials-empty').classList.remove('d-none')
            return
        }
        var track = document.getElementById('testimonials-track')
        track.classList.remove('d-none')
        track.innerHTML = list.map(function (t) {
            var stars = ''
            for (var i = 1; i <= 5; i++) {
                stars += '<i class="bi ' + (i <= t.stars ? 'bi-star-fill' : 'bi-star') + '" style="color:' + (i <= t.stars ? '#F97316' : '#e2e8f0') + '"></i>'
            }
            var initials = escapeHtml((t.userName || 'U').split(' ').map(function(n){return n[0]}).join('').substring(0,2).toUpperCase())
            var roleDot = t.userRole ? '<span style="width:4px;height:4px;border-radius:50%;background:#cbd5e1;display:inline-block"></span> ' : ''
            return '<div class="testi-card">' +
                '<i class="bi bi-quote testi-quote-icon"></i>' +
                '<div class="testi-user">' +
                '<div class="testi-avatar">' + initials + '</div>' +
                '<div>' +
                '<div class="testi-user-name">' + escapeHtml(t.userName || 'User') + '</div>' +
                '<div class="testi-user-role">' + roleDot + escapeHtml(t.userRole || '') + '</div>' +
                '</div></div>' +
                '<div class="testi-stars">' + stars + '</div>' +
                '<p class="testi-text">"' + escapeHtml(t.text) + '"</p>' +
                '</div>'
        }).join('')
    }).catch(function () {
        document.getElementById('testimonials-loading').classList.add('d-none')
        document.getElementById('testimonials-empty').classList.remove('d-none')
    })
}
loadTestimonials()

// ---- Suggested apartments + testimonial form for logged-in users ----
auth.initAuth().then(function () {
    var user = auth.getUser()
    if (!user || user.role !== 0 || user.university == null) return
    api.get('/apartments', { query: { university: user.university, pageSize: 4, sort: 'newest' } }).then(function (data) {
        var items = (data.items || data || []).slice(0, 4)
        if (items.length === 0) return
        document.getElementById('home-suggested').classList.remove('d-none')
        document.getElementById('home-suggested-list').innerHTML = items.map(function (apt, idx) {
            var photo = apt.mainPhotoUrl ? apt.mainPhotoUrl : '/property/images/img_' + ((idx % 8) + 1) + '.jpg'
            var matchHtml = ''
            if (apt.compatibilityScore != null) {
                matchHtml = '<div style="width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:800;border:2px solid ' +
                    (apt.compatibilityScore >= 75 ? '#10b981' : apt.compatibilityScore >= 50 ? '#eab308' : '#94a3b8') + ';color:' +
                    (apt.compatibilityScore >= 75 ? '#10b981' : apt.compatibilityScore >= 50 ? '#eab308' : '#94a3b8') + '">' + apt.compatibilityScore + '%</div>'
            }
            return '<div class="col-md-6 col-xl-3">' +
                '<a href="/Apartment/Detail/' + apt.id + '" style="text-decoration:none">' +
                '<div style="background:#1e293b;border-radius:14px;overflow:hidden;transition:transform .3s,box-shadow .3s;border:1px solid rgba(255,255,255,.06)" onmouseenter="this.style.transform=\'translateY(-4px)\';this.style.boxShadow=\'0 12px 30px rgba(0,0,0,.3)\'" onmouseleave="this.style.transform=\'\';this.style.boxShadow=\'\'">' +
                '<img src="' + photo + '" alt="' + escapeHtml(apt.title) + '" style="width:100%;height:160px;object-fit:cover;display:block" />' +
                '<div style="padding:.85rem 1rem">' +
                '<div style="font-weight:700;font-size:.9rem;color:#f8fafc;margin-bottom:.2rem">' + escapeHtml(apt.title) + '</div>' +
                '<div style="font-size:.78rem;color:#64748b;margin-bottom:.5rem"><i class="bi bi-geo-alt-fill"></i> ' + escapeHtml(apt.neighborhood || '') + '</div>' +
                '<div style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid rgba(255,255,255,.06);padding-top:.6rem">' +
                '<div style="font-size:1rem;font-weight:800;color:#f8fafc">' + apt.fullRent + ' <span style="font-size:.72rem;font-weight:400;color:#64748b">JOD/mo</span></div>' +
                matchHtml +
                '</div></div></div></a></div>'
        }).join('')
    }).catch(function () {})
});
</script>
}
