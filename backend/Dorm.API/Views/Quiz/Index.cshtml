@using Dorm.Domain.Enums
@using Dorm.Application.DTOs.Quiz
@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "Lifestyle Quiz";
    var questionsDto = (QuizQuestionsDto)ViewBag.Questions;
    var myAnswersDto = (QuizMyAnswersDto)ViewBag.MyAnswers;
    var questions = questionsDto.Questions;
    var existingAnswers = myAnswersDto.Answers;
    var isFirstTime = existingAnswers.Count == 0;
}

@section Styles {
<style>
    .quiz-page { max-width: 640px; margin: 0 auto; padding: 2.5rem 1rem 4rem; }

    .quiz-welcome {
        text-align: center; padding: 2.5rem 1.5rem; margin-bottom: 2rem;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        border-radius: 16px; color: #f8fafc;
    }
    .quiz-welcome-icon {
        width: 64px; height: 64px; border-radius: 16px;
        background: rgba(249,115,22,.15); color: #F97316;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 1.8rem; margin-bottom: 1rem;
    }
    .quiz-welcome h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: .5rem; }
    .quiz-welcome p { color: #94a3b8; font-size: .9rem; margin: 0 auto; max-width: 420px; line-height: 1.6; }
    .btn-start-quiz {
        margin-top: 1.25rem; background: #F97316; color: #fff; border: none;
        border-radius: 10px; padding: .7rem 2rem; font-weight: 700; font-size: .95rem;
        cursor: pointer; transition: all .2s; display: inline-flex; align-items: center; gap: .4rem;
    }
    .btn-start-quiz:hover { background: #ea6c10; transform: translateY(-1px); }

    .quiz-card {
        background: #fff; border-radius: 16px; border: 1px solid #e2e8f0;
        box-shadow: 0 4px 16px rgba(0,0,0,.04); overflow: hidden;
    }
    .quiz-card-body { padding: 2rem; }

    .progress-wrap { margin-bottom: 1.75rem; }
    .progress-bar-bg { height: 6px; background: #f1f5f9; border-radius: 10px; overflow: hidden; }
    .progress-bar-fill {
        height: 100%; background: linear-gradient(90deg, #F97316, #fb923c);
        border-radius: 10px; transition: width .4s cubic-bezier(.22,1,.36,1);
    }
    .progress-text { display: flex; justify-content: space-between; align-items: center; margin-top: .6rem; }
    .progress-text span { font-size: .75rem; font-weight: 600; color: #94a3b8; }
    .progress-dots { display: flex; gap: .4rem; }
    .progress-dot {
        width: 8px; height: 8px; border-radius: 50%; background: #e2e8f0;
        transition: background .3s, transform .3s;
    }
    .progress-dot.done { background: #F97316; }
    .progress-dot.active { background: #F97316; transform: scale(1.4); }

    .q-icon-wrap {
        width: 48px; height: 48px; border-radius: 12px;
        background: rgba(249,115,22,.08); color: #F97316;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; margin-bottom: 1rem;
    }
    .q-title { font-size: 1.2rem; font-weight: 800; color: #1e293b; margin-bottom: .25rem; }
    .q-help { font-size: .88rem; color: #64748b; margin-bottom: 1.5rem; line-height: 1.5; }

    .q-slide { animation: slideIn .35s cubic-bezier(.22,1,.36,1); }
    @@keyframes slideIn {
        from { opacity: 0; transform: translateX(30px); }
        to   { opacity: 1; transform: translateX(0); }
    }

    .opt-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; }
    .opt-card {
        background: #f8fafc; border: 2px solid #e2e8f0; border-radius: 14px;
        padding: 1.25rem 1rem; text-align: center; cursor: pointer;
        transition: all .25s cubic-bezier(.22,1,.36,1);
    }
    .opt-card:hover {
        border-color: #cbd5e1; background: #fff;
        transform: translateY(-3px); box-shadow: 0 6px 16px rgba(0,0,0,.06);
    }
    .opt-card.selected {
        border-color: #F97316; background: rgba(249,115,22,.04);
        box-shadow: 0 0 0 3px rgba(249,115,22,.1);
    }
    .opt-card .opt-check {
        width: 22px; height: 22px; border-radius: 50%; border: 2px solid #e2e8f0;
        display: inline-flex; align-items: center; justify-content: center;
        margin-bottom: .6rem; transition: all .2s;
    }
    .opt-card.selected .opt-check {
        background: #F97316; border-color: #F97316; color: #fff;
    }
    .opt-card .opt-label { font-weight: 700; font-size: .88rem; color: #1e293b; }

    .quiz-nav { display: flex; justify-content: space-between; margin-top: 2rem; }
    .btn-quiz-prev {
        background: #f1f5f9; color: #475569; border: none; border-radius: 10px;
        padding: .65rem 1.5rem; font-weight: 600; font-size: .88rem;
        display: inline-flex; align-items: center; gap: .3rem;
        cursor: pointer; transition: all .2s;
    }
    .btn-quiz-prev:hover { background: #e2e8f0; }
    .btn-quiz-next {
        background: #0f172a; color: #fff; border: none; border-radius: 10px;
        padding: .65rem 1.5rem; font-weight: 600; font-size: .88rem;
        display: inline-flex; align-items: center; gap: .3rem;
        cursor: pointer; transition: all .2s;
    }
    .btn-quiz-next:hover { background: #1e293b; transform: translateY(-1px); }
    .btn-quiz-next:disabled { opacity: .4; cursor: not-allowed; transform: none; }
    .btn-quiz-submit {
        background: #F97316; color: #fff; border: none; border-radius: 10px;
        padding: .65rem 1.5rem; font-weight: 700; font-size: .95rem;
        display: inline-flex; align-items: center; gap: .4rem;
        cursor: pointer; transition: all .2s;
    }
    .btn-quiz-submit:hover { background: #ea6c10; transform: translateY(-1px); }
    .btn-quiz-submit:disabled { opacity: .4; cursor: not-allowed; transform: none; }

    .quiz-success {
        text-align: center; padding: 2rem 1rem; animation: slideIn .4s ease;
    }
    .quiz-success-icon {
        width: 56px; height: 56px; border-radius: 50%;
        background: rgba(16,185,129,.1); color: #10b981;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 1.5rem; margin-bottom: 1rem;
    }

    @@media (max-width: 575px) {
        .opt-grid { grid-template-columns: 1fr; }
        .quiz-card-body { padding: 1.25rem; }
    }
</style>
}

<div class="quiz-page">
    <div id="quiz-welcome" style="display:@(isFirstTime ? "block" : "none")">
        <div class="quiz-welcome">
            <div class="quiz-welcome-icon"><i class="bi bi-clipboard-check"></i></div>
            <h2>Find Your Perfect Roommate</h2>
            <p>Answer 8 quick questions about your lifestyle. We'll use your answers to calculate compatibility scores with potential roommates — so you find people you'll actually get along with.</p>
            <button class="btn-start-quiz" onclick="startQuiz()"><i class="bi bi-arrow-right"></i> Let's Go</button>
        </div>
        <div class="text-center" style="margin-top:1rem">
            <p style="color:#94a3b8;font-size:.82rem"><i class="bi bi-shield-check me-1"></i> Your answers are private and only used for matching.</p>
        </div>
    </div>

    <div id="quiz-main" style="display:@(isFirstTime ? "none" : "block")">
        <div class="quiz-card">
            <div class="quiz-card-body">
                @Html.AntiForgeryToken()
                <div id="quiz-progress" class="progress-wrap"></div>
                <div id="quiz-content"></div>
                <div class="quiz-nav" id="quiz-nav" style="display:none"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
var Q_KEY_NAMES = ['SleepSchedule','Cleanliness','Smoking','StudyHabits','SocialStyle','Guests','Cooking','PetTolerance'];

var questions = [
@foreach (var q in questions)
{
    <text>{ key: '@q.Key', options: [@Html.Raw(string.Join(",", q.Options.Select(o => $"'{o}'")))] },</text>
}
];

var answers = {};
@foreach (var a in existingAnswers)
{
    <text>answers['@a.QuestionKey'] = '@a.AnswerValue';</text>
}

var currentQ = 0;
var isFirstTime = @(isFirstTime ? "true" : "false");

var Q_TITLES = {
    SleepSchedule: 'Sleep Schedule', Cleanliness: 'Cleanliness', Smoking: 'Smoking',
    StudyHabits: 'Study Habits', SocialStyle: 'Social Style', Guests: 'Guests',
    Cooking: 'Cooking', PetTolerance: 'Pet Tolerance'
};
var Q_HELP = {
    SleepSchedule: 'When do you usually go to bed and wake up?',
    Cleanliness: 'How tidy do you keep shared spaces?',
    Smoking: 'Do you smoke?',
    StudyHabits: 'Where do you prefer to study?',
    SocialStyle: 'How social are you at home?',
    Guests: 'How often do you have visitors?',
    Cooking: 'How often do you cook at home?',
    PetTolerance: 'How do you feel about pets?'
};
var OPT_LABELS = {
    SleepSchedule: { EarlyBird: 'Early Bird', NightOwl: 'Night Owl', Flexible: 'Flexible' },
    Cleanliness: { VeryTidy: 'Very Tidy', Average: 'Average', Relaxed: 'Relaxed' },
    Smoking: { Yes: 'Yes', No: 'No', Outside: 'Outside Only' },
    StudyHabits: { QuietAtHome: 'Quiet at Home', Library: 'Library', GroupAtHome: 'Group at Home' },
    SocialStyle: { Introvert: 'Introvert', Extrovert: 'Extrovert', Balanced: 'Balanced' },
    Guests: { Often: 'Often', Rarely: 'Rarely', Sometimes: 'Sometimes' },
    Cooking: { CookALot: 'Cook a Lot', MostlyEatOut: 'Mostly Eat Out', CookSometimes: 'Cook Sometimes' },
    PetTolerance: { LovePets: 'Love Pets', PreferNoPets: 'No Pets', Tolerate: 'Tolerate' }
};
var Q_ICONS = {
    SleepSchedule: 'bi-moon-stars', Cleanliness: 'bi-sparkle', Smoking: 'bi-wind',
    StudyHabits: 'bi-book', SocialStyle: 'bi-people', Guests: 'bi-person-plus',
    Cooking: 'bi-cup-hot', PetTolerance: 'bi-emoji-smile'
};

if (!isFirstTime) renderQuestion();

function startQuiz() {
    document.getElementById('quiz-welcome').style.display = 'none';
    document.getElementById('quiz-main').style.display = 'block';
    renderQuestion();
}

function renderQuestion() {
    if (questions.length === 0) return;
    var q = questions[currentQ];
    var qKey = q.key;
    var opts = q.options;

    var pct = ((currentQ + 1) / questions.length * 100);
    var dots = questions.map(function(_, i) {
        var cls = i < currentQ ? 'done' : i === currentQ ? 'active' : '';
        return '<div class="progress-dot ' + cls + '"></div>';
    }).join('');
    document.getElementById('quiz-progress').innerHTML =
        '<div class="progress-bar-bg"><div class="progress-bar-fill" style="width:' + pct + '%"></div></div>' +
        '<div class="progress-text"><span>Question ' + (currentQ+1) + ' of ' + questions.length + '</span>' +
        '<div class="progress-dots">' + dots + '</div></div>';

    var content = document.getElementById('quiz-content');
    var labels = OPT_LABELS[qKey] || {};
    content.innerHTML =
        '<div class="q-slide">' +
        '<div class="q-icon-wrap"><i class="bi ' + (Q_ICONS[qKey]||'bi-question-circle') + '"></i></div>' +
        '<h4 class="q-title">' + (Q_TITLES[qKey]||qKey) + '</h4>' +
        '<p class="q-help">' + (Q_HELP[qKey]||'') + '</p>' +
        '<div class="opt-grid">' +
        opts.map(function (opt) {
            var sel = answers[qKey] === opt;
            return '<div class="opt-card' + (sel?' selected':'') + '" onclick="selectAnswer(\'' + qKey + '\',\'' + opt + '\')">' +
                '<div class="opt-check">' + (sel?'<i class="bi bi-check2" style="font-size:.7rem"></i>':'') + '</div>' +
                '<div class="opt-label">' + (labels[opt]||opt) + '</div></div>';
        }).join('') +
        '</div></div>';

    var nav = document.getElementById('quiz-nav');
    nav.style.display = 'flex';
    var prevBtn = currentQ > 0
        ? '<button class="btn-quiz-prev" onclick="prevQ()"><i class="bi bi-chevron-left"></i> Back</button>'
        : '<span></span>';
    var nextBtn = currentQ < questions.length - 1
        ? '<button class="btn-quiz-next" onclick="nextQ()" ' + (!answers[qKey]?'disabled':'') + '>Next <i class="bi bi-chevron-right"></i></button>'
        : '<button class="btn-quiz-submit" onclick="submitQuiz()" ' + (!answers[qKey]?'disabled':'') + '><i class="bi bi-check2-circle"></i> Submit Quiz</button>';
    nav.innerHTML = prevBtn + nextBtn;
}

function selectAnswer(qKey, opt) { answers[qKey] = opt; renderQuestion(); }
function nextQ() { if (currentQ < questions.length - 1) { currentQ++; renderQuestion(); } }
function prevQ() { if (currentQ > 0) { currentQ--; renderQuestion(); } }

async function submitQuiz() {
    var btn = document.querySelector('.btn-quiz-submit');
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving...'; }

    var payload = Object.keys(answers).map(function (k) {
        var idx = Q_KEY_NAMES.indexOf(k);
        return { questionKey: idx >= 0 ? idx : 0, answerValue: answers[k] };
    });
    try {
        var res = await fetch('/Quiz/Save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
            body: JSON.stringify({ answers: payload })
        });
        if (!res.ok) {
            var err = await res.json().catch(function () { return {}; });
            throw new Error(err.error?.message || 'Something went wrong.');
        }

        var content = document.getElementById('quiz-content');
        document.getElementById('quiz-progress').style.display = 'none';
        document.getElementById('quiz-nav').style.display = 'none';
        content.innerHTML =
            '<div class="quiz-success">' +
            '<div class="quiz-success-icon"><i class="bi bi-check-lg"></i></div>' +
            '<h4 style="font-weight:800;color:#1e293b;margin-bottom:.25rem">Quiz Complete!</h4>' +
            '<p style="color:#64748b;font-size:.9rem;margin-bottom:1.25rem">Your lifestyle profile is saved. Now browse apartments and see your compatibility scores.</p>' +
            '<a href="/Browse" style="background:#F97316;color:#fff;border:none;border-radius:10px;padding:.65rem 2rem;font-weight:700;font-size:.9rem;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem"><i class="bi bi-search"></i> Browse Apartments</a>' +
            '</div>';
    } catch (err) {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-check2-circle"></i> Submit Quiz'; }
        document.getElementById('quiz-content').insertAdjacentHTML('afterbegin',
            '<div class="alert alert-danger" style="border-radius:10px">' + (err.message || 'Something went wrong.') + '</div>');
    }
}
</script>
}
