@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "My Applications";
    var apps = (IReadOnlyList<Dorm.Application.DTOs.Applications.ApplicationDto>)(ViewBag.Applications ?? Array.Empty<Dorm.Application.DTOs.Applications.ApplicationDto>());
    var pending = apps.Count(a => a.Status == Dorm.Domain.Enums.ApplicationStatus.Pending);
    var accepted = apps.Count(a => a.Status == Dorm.Domain.Enums.ApplicationStatus.Accepted);
}

@section Styles {
<style>
    .sa-page { max-width: 880px; margin: 0 auto; padding: 2rem 1rem 4rem; }

    .sa-header { margin-bottom: 1.5rem; }
    .sa-header h2 { font-size: 1.5rem; font-weight: 800; color: #1e293b; margin-bottom: .25rem; }
    .sa-header p { color: #64748b; font-size: .9rem; margin: 0; }

    .sa-stats { display: flex; gap: .75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .sa-stat {
        background: #fff; border-radius: 12px; border: 1px solid #f1f5f9;
        padding: .75rem 1.25rem; display: flex; align-items: center; gap: .65rem;
        min-width: 140px;
    }
    .sa-stat-icon {
        width: 36px; height: 36px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0;
    }
    .sa-stat-label { font-size: .72rem; color: #94a3b8; font-weight: 500; }
    .sa-stat-value { font-size: 1.1rem; font-weight: 800; color: #1e293b; }

    .sa-card {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 1.25rem; margin-bottom: .75rem;
        display: flex; align-items: center; gap: 1rem;
        transition: box-shadow .2s, transform .15s;
    }
    .sa-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.05); transform: translateY(-1px); }

    .sa-card-icon {
        width: 48px; height: 48px; border-radius: 12px; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        font-size: 1.1rem; color: #94a3b8;
    }
    .sa-card-body { flex: 1; min-width: 0; }
    .sa-card-title {
        font-weight: 700; font-size: .92rem; color: #1e293b;
        text-decoration: none; display: block;
    }
    .sa-card-title:hover { color: #F97316; }
    .sa-card-meta { font-size: .78rem; color: #94a3b8; margin-top: .15rem; }
    .sa-card-msg { font-size: .78rem; color: #94a3b8; font-style: italic; margin-top: .2rem; }

    .sa-card-right { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }

    .match-ring {
        width: 42px; height: 42px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: .72rem; font-weight: 800;
    }
    .match-ring.high { border: 2.5px solid #10b981; color: #10b981; background: rgba(16,185,129,.06); }
    .match-ring.mid  { border: 2.5px solid #eab308; color: #eab308; background: rgba(234,179,8,.06); }
    .match-ring.low  { border: 2.5px solid #94a3b8; color: #94a3b8; background: rgba(148,163,184,.06); }

    .status-badge {
        font-size: .72rem; font-weight: 600; padding: .3rem .7rem; border-radius: 6px;
        display: inline-flex; align-items: center; gap: .25rem; white-space: nowrap;
    }
    .status-pending { background: rgba(234,179,8,.1); color: #eab308; }
    .status-accepted { background: rgba(16,185,129,.1); color: #10b981; }
    .status-rejected { background: rgba(239,68,68,.1); color: #ef4444; }
    .status-withdrawn { background: rgba(148,163,184,.1); color: #94a3b8; }

    .btn-withdraw {
        background: #fff; color: #ef4444; border: 1px solid #fecaca; border-radius: 8px;
        padding: .35rem .75rem; font-size: .78rem; font-weight: 600;
        cursor: pointer; transition: all .15s;
    }
    .btn-withdraw:hover { background: #fef2f2; border-color: #ef4444; }
    .btn-msg {
        background: #0f172a; color: #fff; border: none; border-radius: 8px;
        padding: .35rem .75rem; font-size: .78rem; font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center; gap: .25rem;
        transition: all .15s;
    }
    .btn-msg:hover { background: #1e293b; color: #fff; }

    .empty-apps {
        text-align: center; padding: 4rem 1rem;
        background: #fff; border-radius: 16px; border: 1px solid #e2e8f0;
    }
    .empty-apps-icon {
        width: 64px; height: 64px; border-radius: 50%; background: #f1f5f9;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 1.8rem; color: #cbd5e1; margin-bottom: 1rem;
    }
    .empty-apps h5 { font-weight: 800; color: #1e293b; margin-bottom: .25rem; }
    .empty-apps p { color: #94a3b8; font-size: .88rem; max-width: 320px; margin: 0 auto; }
    .btn-browse {
        margin-top: 1rem; background: #F97316; color: #fff; border: none; border-radius: 10px;
        padding: .6rem 1.5rem; font-weight: 600; font-size: .88rem;
        text-decoration: none; display: inline-flex; align-items: center; gap: .3rem;
    }
    .btn-browse:hover { background: #ea6c10; color: #fff; }

    .checklist {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 1.25rem; margin-bottom: .75rem; margin-top: -.25rem;
        border-top: 3px solid #F97316;
    }
    .checklist-header {
        display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;
    }
    .checklist-header h6 { font-weight: 800; font-size: .9rem; color: #1e293b; margin: 0; }
    .checklist-progress {
        display: flex; align-items: center; gap: .5rem;
    }
    .checklist-progress-bar {
        width: 100px; height: 6px; background: #f1f5f9; border-radius: 10px; overflow: hidden;
    }
    .checklist-progress-fill {
        height: 100%; background: linear-gradient(90deg, #F97316, #10b981); border-radius: 10px;
        transition: width .4s;
    }
    .checklist-progress-text { font-size: .72rem; font-weight: 700; color: #64748b; }

    .cl-step {
        display: flex; align-items: flex-start; gap: .75rem; padding: .6rem 0;
        position: relative;
    }
    .cl-step:not(:last-child)::after {
        content: ''; position: absolute; left: 13px; top: 34px;
        width: 2px; height: calc(100% - 14px); background: #f1f5f9;
    }
    .cl-step.done:not(:last-child)::after { background: #10b981; }
    .cl-step-dot {
        width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: .7rem; z-index: 1;
    }
    .cl-step.done .cl-step-dot { background: #10b981; color: #fff; }
    .cl-step.current .cl-step-dot { background: #F97316; color: #fff; animation: pulse 2s infinite; }
    .cl-step.upcoming .cl-step-dot { background: #f1f5f9; color: #cbd5e1; }
    @@keyframes pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(249,115,22,.3); } 50% { box-shadow: 0 0 0 6px rgba(249,115,22,0); } }
    .cl-step-body { flex: 1; min-width: 0; padding-top: .2rem; }
    .cl-step-title { font-weight: 600; font-size: .85rem; color: #1e293b; }
    .cl-step.upcoming .cl-step-title { color: #94a3b8; }
    .cl-step-desc { font-size: .78rem; color: #94a3b8; margin-top: .1rem; }
    .cl-step-action { margin-top: .4rem; }
    .btn-cl-action {
        background: #F97316; color: #fff; border: none; border-radius: 8px;
        padding: .35rem .85rem; font-size: .78rem; font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center; gap: .25rem;
        cursor: pointer; transition: all .15s;
    }
    .btn-cl-action:hover { background: #ea6c10; color: #fff; }
    .btn-cl-secondary {
        background: #f1f5f9; color: #475569; border: none; border-radius: 8px;
        padding: .35rem .85rem; font-size: .78rem; font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center; gap: .25rem;
        cursor: pointer; transition: all .15s;
    }
    .btn-cl-secondary:hover { background: #e2e8f0; }

    @@media (max-width: 575px) {
        .sa-card { flex-direction: column; align-items: flex-start; gap: .75rem; }
        .sa-card-right { width: 100%; justify-content: space-between; }
    }
</style>
}

<div class="sa-page">
    <div class="sa-header">
        <h2>My Applications</h2>
        <p>Track the status of apartments you've applied to.</p>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success" style="border-radius:10px">@success</div>
    }

    @if (apps.Count > 0)
    {
        <div class="sa-stats">
            <div class="sa-stat">
                <div class="sa-stat-icon" style="background:rgba(59,130,246,.08);color:#3b82f6"><i class="bi bi-file-text"></i></div>
                <div><div class="sa-stat-label">Total</div><div class="sa-stat-value">@apps.Count</div></div>
            </div>
            <div class="sa-stat">
                <div class="sa-stat-icon" style="background:rgba(234,179,8,.08);color:#eab308"><i class="bi bi-clock"></i></div>
                <div><div class="sa-stat-label">Pending</div><div class="sa-stat-value">@pending</div></div>
            </div>
            <div class="sa-stat">
                <div class="sa-stat-icon" style="background:rgba(16,185,129,.08);color:#10b981"><i class="bi bi-check-circle"></i></div>
                <div><div class="sa-stat-label">Accepted</div><div class="sa-stat-value">@accepted</div></div>
            </div>
            <div class="sa-stat" style="margin-left:auto">
                <a href="/Browse" style="color:#F97316;font-weight:600;font-size:.85rem;text-decoration:none;display:flex;align-items:center;gap:.3rem"><i class="bi bi-search"></i> Browse more</a>
            </div>
        </div>

        @foreach (var app in apps)
        {
            var statusText = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "Pending", Dorm.Domain.Enums.ApplicationStatus.Accepted => "Accepted", Dorm.Domain.Enums.ApplicationStatus.Rejected => "Rejected", Dorm.Domain.Enums.ApplicationStatus.Withdrawn => "Withdrawn", _ => "Pending" };
            var statusCls = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "status-pending", Dorm.Domain.Enums.ApplicationStatus.Accepted => "status-accepted", Dorm.Domain.Enums.ApplicationStatus.Rejected => "status-rejected", _ => "status-withdrawn" };
            var statusIcon = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "bi-clock", Dorm.Domain.Enums.ApplicationStatus.Accepted => "bi-check-circle-fill", Dorm.Domain.Enums.ApplicationStatus.Rejected => "bi-x-circle-fill", Dorm.Domain.Enums.ApplicationStatus.Withdrawn => "bi-arrow-return-left", _ => "bi-clock" };
            var matchCls = app.CompatibilityScore >= 75 ? "high" : app.CompatibilityScore >= 50 ? "mid" : "low";

            <div class="sa-card">
                <div class="sa-card-icon"><i class="bi bi-building"></i></div>
                <div class="sa-card-body">
                    <a href="/Apartment/Detail/@app.ApartmentId" class="sa-card-title">@app.ApartmentTitle</a>
                    <div class="sa-card-meta">Applied @app.CreatedAt.ToString("MMM d, yyyy")</div>
                    @if (!string.IsNullOrEmpty(app.Message))
                    {
                        <div class="sa-card-msg">"@(app.Message.Length > 60 ? app.Message.Substring(0, 60) + "..." : app.Message)"</div>
                    }
                </div>
                <div class="sa-card-right">
                    @if (app.CompatibilityScore > 0)
                    {
                        <div class="match-ring @matchCls">@(app.CompatibilityScore)%</div>
                    }
                    <span class="status-badge @statusCls"><i class="bi @statusIcon"></i> @statusText</span>
                    @if (app.Status == Dorm.Domain.Enums.ApplicationStatus.Pending)
                    {
                        <form method="post" asp-action="Withdraw" asp-controller="StudentApps" style="margin:0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@app.Id" />
                            <button type="submit" class="btn-withdraw"><i class="bi bi-x-lg"></i></button>
                        </form>
                    }
                    @if (app.Status == Dorm.Domain.Enums.ApplicationStatus.Accepted)
                    {
                        <a href="/Chat" class="btn-msg"><i class="bi bi-chat-dots"></i> Chat</a>
                    }
                </div>
            </div>

            @if (app.Status == Dorm.Domain.Enums.ApplicationStatus.Accepted && app.Checklist != null)
            {
                var cl = app.Checklist;
                var pct = (int)Math.Round((double)cl.CompletedSteps / cl.TotalSteps * 100);
                <div class="checklist">
                    <div class="checklist-header">
                        <h6><i class="bi bi-clipboard-check me-2" style="color:#F97316"></i>Move-In Checklist</h6>
                        <div class="checklist-progress">
                            <div class="checklist-progress-bar"><div class="checklist-progress-fill" style="width:@(pct)%"></div></div>
                            <span class="checklist-progress-text">@cl.CompletedSteps / @cl.TotalSteps</span>
                        </div>
                    </div>

                    @{ var stepNum = 0; }

                    @{ var s1 = cl.ApplicationAccepted; stepNum++; var s1State = s1 ? "done" : "current"; }
                    <div class="cl-step @s1State">
                        <div class="cl-step-dot"><i class="bi @(s1 ? "bi-check" : "bi-1-circle")"></i></div>
                        <div class="cl-step-body">
                            <div class="cl-step-title">Application Accepted</div>
                            <div class="cl-step-desc">Your application has been approved by the owner.</div>
                        </div>
                    </div>

                    @{ var s2 = cl.OwnerContacted; stepNum++; var s2State = s2 ? "done" : "current"; }
                    <div class="cl-step @s2State">
                        <div class="cl-step-dot"><i class="bi @(s2 ? "bi-check" : "bi-chat-dots")"></i></div>
                        <div class="cl-step-body">
                            <div class="cl-step-title">Message the Owner</div>
                            <div class="cl-step-desc">@(s2 ? "You've been in touch with the owner." : "Send a message to coordinate your move-in details.")</div>
                            @if (!s2)
                            {
                                <div class="cl-step-action">
                                    <a href="/Chat" class="btn-cl-action"><i class="bi bi-chat-dots"></i> Send Message</a>
                                </div>
                            }
                        </div>
                    </div>


                    @{ var s4 = cl.CommissionPaid; stepNum++; var s4State = s4 ? "done" : "current"; }
                    <div class="cl-step @s4State">
                        <div class="cl-step-dot"><i class="bi @(s4 ? "bi-check" : "bi-credit-card")"></i></div>
                        <div class="cl-step-body">
                            <div class="cl-step-title">Pay Platform Fee (15 JOD)</div>
                            <div class="cl-step-desc">@(s4 ? "Platform fee paid. Thank you!" : "Pay the Dorm platform fee to confirm your spot.")</div>
                            @if (!s4)
                            {
                                <div class="cl-step-action">
                                    <form method="post" asp-action="Checkout" asp-controller="Payment" style="margin:0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="type" value="@((int)Dorm.Domain.Enums.PaymentType.MatchCommission)" />
                                        <input type="hidden" name="relatedEntityId" value="@app.ApartmentId" />
                                        <button type="submit" class="btn-cl-action"><i class="bi bi-credit-card"></i> Pay 15 JOD</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>

                    @{ var s5 = cl.PlannedMoveInDate != null; stepNum++; var s5State = s5 ? "done" : !s4 ? "upcoming" : "current"; }
                    <div class="cl-step @s5State">
                        <div class="cl-step-dot"><i class="bi @(s5 ? "bi-check" : "bi-calendar")"></i></div>
                        <div class="cl-step-body">
                            <div class="cl-step-title">Set Move-In Date</div>
                            <div class="cl-step-desc">@(s5 ? $"Planned: {cl.PlannedMoveInDate!.Value:MMM d, yyyy}" : "Pick a date to move into your new apartment.")</div>
                            @if (!s5 && s4)
                            {
                                <div class="cl-step-action">
                                    <form method="post" asp-action="SetMoveInDate" asp-controller="StudentApps" style="display:flex;gap:.4rem;align-items:center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="apartmentId" value="@app.ApartmentId" />
                                        <input type="date" name="moveInDate" required class="form-control form-control-sm" style="width:auto;border-radius:8px;font-size:.82rem" />
                                        <button type="submit" class="btn-cl-action"><i class="bi bi-check"></i> Set</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>

                    @{ var s6 = cl.MovedIn; stepNum++; var s6State = s6 ? "done" : !s5 ? "upcoming" : "current"; }
                    <div class="cl-step @s6State">
                        <div class="cl-step-dot"><i class="bi @(s6 ? "bi-check" : "bi-house-door")"></i></div>
                        <div class="cl-step-body">
                            <div class="cl-step-title">Moved In</div>
                            <div class="cl-step-desc">@(s6 ? "Welcome to your new home!" : "Confirm once you've moved in.")</div>
                            @if (!s6 && s5)
                            {
                                <div class="cl-step-action">
                                    <form method="post" asp-action="ConfirmMoveIn" asp-controller="StudentApps" style="margin:0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="apartmentId" value="@app.ApartmentId" />
                                        <button type="submit" class="btn-cl-action"><i class="bi bi-house-check"></i> I've Moved In</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>

                    @{ var s7 = cl.ExperienceRated; stepNum++; var s7State = s7 ? "done" : !s6 ? "upcoming" : "current"; }
                    <div class="cl-step @s7State">
                        <div class="cl-step-dot"><i class="bi @(s7 ? "bi-check" : "bi-star")"></i></div>
                        <div class="cl-step-body">
                            <div class="cl-step-title">Rate Your Experience</div>
                            <div class="cl-step-desc">@(s7 ? "Thanks for your feedback!" : "Help future students by rating the owner.")</div>
                            @if (!s7 && s6)
                            {
                                <div class="cl-step-action">
                                    <a href="/WriteReview" class="btn-cl-action"><i class="bi bi-pencil-square"></i> Write Review</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    }
    else
    {
        <div class="empty-apps">
            <div class="empty-apps-icon"><i class="bi bi-inbox"></i></div>
            <h5>No applications yet</h5>
            <p>Browse apartments and apply to find your next home with compatible roommates.</p>
            <a href="/Browse" class="btn-browse"><i class="bi bi-search"></i> Browse Apartments</a>
        </div>
    }
</div>
