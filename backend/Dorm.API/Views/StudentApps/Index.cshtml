@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "My Applications";
    var apps = (IReadOnlyList<Dorm.Application.DTOs.Applications.ApplicationDto>)(ViewBag.Applications ?? Array.Empty<Dorm.Application.DTOs.Applications.ApplicationDto>());
}

@section Styles {
<style>
    .apps-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .apps-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: .15rem; }
    .apps-header p { color: #64748b; font-size: .9rem; margin: 0; }
    .btn-browse-sm {
        background: #0f172a; color: #fff; border: none; border-radius: 8px;
        padding: .5rem 1rem; font-weight: 600; font-size: .82rem;
        text-decoration: none; display: inline-flex; align-items: center; gap: .3rem;
    }
    .btn-browse-sm:hover { background: #1e293b; color: #fff; }
    .apps-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }
    .match-ring {
        width: 38px; height: 38px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: .7rem; font-weight: 800;
    }
    .match-ring.high { border: 2.5px solid #10b981; color: #10b981; background: rgba(16,185,129,.06); }
    .match-ring.mid  { border: 2.5px solid #eab308; color: #eab308; background: rgba(234,179,8,.06); }
    .match-ring.low  { border: 2.5px solid #94a3b8; color: #94a3b8; background: rgba(148,163,184,.06); }
    .btn-withdraw {
        background: #fff; color: #ef4444; border: 1px solid #fecaca; border-radius: 6px;
        padding: .3rem .7rem; font-size: .78rem; font-weight: 600;
    }
    .btn-withdraw:hover { background: #fef2f2; border-color: #ef4444; }
    .empty-apps { text-align: center; padding: 3.5rem 1rem; }
    .empty-apps i { font-size: 2.5rem; color: #cbd5e1; }
    .empty-apps h5 { font-weight: 700; color: #1e293b; margin-top: .75rem; }
    .empty-apps p { color: #94a3b8; font-size: .88rem; }
</style>
}

<div class="apps-header">
    <div>
        <h3>My Applications</h3>
        <p>Track the status of apartments you've applied to.</p>
    </div>
    <a href="/Browse" class="btn-browse-sm"><i class="bi bi-search"></i> Browse</a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="border-radius:8px">@success</div>
}

<div class="apps-card">
    @if (apps.Count == 0)
    {
        <div class="empty-apps">
            <i class="bi bi-inbox"></i>
            <h5>No applications</h5>
            <p>Browse apartments and apply to get started.</p>
            <a href="/Browse" class="btn-browse-sm">Browse apartments</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8">
                        <th>Apartment</th><th>Date</th><th class="text-center">Match</th><th class="text-center">Status</th><th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var app in apps)
                {
                    var statusText = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "Pending", Dorm.Domain.Enums.ApplicationStatus.Accepted => "Accepted", Dorm.Domain.Enums.ApplicationStatus.Rejected => "Rejected", Dorm.Domain.Enums.ApplicationStatus.Withdrawn => "Withdrawn", _ => "Pending" };
                    var statusColor = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "warning", Dorm.Domain.Enums.ApplicationStatus.Accepted => "success", Dorm.Domain.Enums.ApplicationStatus.Rejected => "danger", Dorm.Domain.Enums.ApplicationStatus.Withdrawn => "secondary", _ => "secondary" };
                    var statusIcon = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "bi-clock", Dorm.Domain.Enums.ApplicationStatus.Accepted => "bi-check-circle-fill", Dorm.Domain.Enums.ApplicationStatus.Rejected => "bi-x-circle-fill", Dorm.Domain.Enums.ApplicationStatus.Withdrawn => "bi-arrow-return-left", _ => "bi-clock" };
                    var matchCls = app.CompatibilityScore >= 75 ? "high" : app.CompatibilityScore >= 50 ? "mid" : "low";
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:36px;height:36px;border-radius:8px;background:#f1f5f9;display:flex;align-items:center;justify-content:center"><i class="bi bi-building" style="color:#94a3b8;font-size:.85rem"></i></div>
                                <div>
                                    <a href="/Apartment/Detail/@app.ApartmentId" class="fw-semibold text-decoration-none" style="color:#1e293b;font-size:.88rem">@app.ApartmentTitle</a>
                                    @if (!string.IsNullOrEmpty(app.Message))
                                    {
                                        <br /><span style="color:#94a3b8;font-size:.75rem;font-style:italic">"@(app.Message.Length > 50 ? app.Message.Substring(0, 50) + "..." : app.Message)"</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td style="color:#94a3b8;font-size:.82rem">@app.CreatedAt.ToString("MMM d, yyyy")</td>
                        <td class="text-center">
                            @if (app.CompatibilityScore > 0)
                            {
                                <div class="match-ring @matchCls">@(app.CompatibilityScore)%</div>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge bg-@statusColor bg-opacity-10 text-@statusColor" style="font-size:.72rem"><i class="bi @statusIcon me-1"></i>@statusText</span>
                        </td>
                        <td class="text-end">
                            @if (app.Status == Dorm.Domain.Enums.ApplicationStatus.Pending)
                            {
                                <form method="post" asp-action="Withdraw" asp-controller="StudentApps" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@app.Id" />
                                    <button type="submit" class="btn-withdraw"><i class="bi bi-x-lg me-1"></i>Withdraw</button>
                                </form>
                            }
                            @if (app.Status == Dorm.Domain.Enums.ApplicationStatus.Accepted)
                            {
                                <a href="/Chat" class="btn-browse-sm" style="font-size:.78rem;padding:.3rem .7rem"><i class="bi bi-chat-dots me-1"></i>Message</a>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
