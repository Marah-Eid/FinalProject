@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "Payment Successful";
    var payment = ViewBag.Payment as Dorm.Application.DTOs.Payments.PaymentDto;
}

@section Styles {
<style>
    .success-card {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 3rem 2rem; text-align: center; max-width: 500px; margin: 3rem auto;
    }
    .success-icon {
        width: 64px; height: 64px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; margin: 0 auto 1.25rem;
    }
</style>
}

<form style="display:none">@Html.AntiForgeryToken()</form>
<div class="container">
    <div class="success-card">
        @if (payment != null)
        {
            <div class="success-icon" style="background:rgba(16,185,129,.1);color:#10b981"><i class="bi bi-check-lg"></i></div>
            <h4 class="fw-bold" style="color:#1e293b">Payment Successful!</h4>
            <p style="color:#64748b;font-size:.9rem">Your payment of <strong>@payment.Amount JOD</strong> has been confirmed.</p>
            <div id="pending-listing-status" class="mt-3" style="display:none">
                <div class="d-flex align-items-center justify-content-center gap-2" style="color:#F97316;font-size:.9rem">
                    <span class="spinner-border spinner-border-sm"></span> Creating your listing...
                </div>
            </div>
            <div id="success-links" class="d-flex justify-content-center gap-2 mt-3">
                <a href="/Payment" class="btn btn-outline-secondary">View Payments</a>
                <a href="/" class="btn" style="background:#0f172a;color:#fff">Home</a>
            </div>
        }
        else
        {
            <div class="success-icon" style="background:rgba(239,68,68,.1);color:#ef4444"><i class="bi bi-exclamation-triangle"></i></div>
            <h4 class="fw-bold" style="color:#1e293b">Invalid Session</h4>
            <p style="color:#64748b">No payment session found or verification failed.</p>
            <a href="/Payment" class="btn btn-outline-secondary mt-3">Go to Payments</a>
        }
    </div>
</div>

@section Scripts {
<script>
(async function () {
    var pending = sessionStorage.getItem('pendingListing');
    if (!pending) return;
    sessionStorage.removeItem('pendingListing');

    var statusEl = document.getElementById('pending-listing-status');
    var linksEl = document.getElementById('success-links');
    if (statusEl) statusEl.style.display = 'block';
    if (linksEl) linksEl.style.display = 'none';

    try {
        var csrfEl = document.querySelector('input[name="__RequestVerificationToken"]');
        var csrfToken = csrfEl ? csrfEl.value : '';
        var body = JSON.parse(pending);

        var res = await fetch('/OwnerListings/Create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
            body: JSON.stringify(body)
        });

        if (res.ok) {
            var result = await res.json();
            window.location.href = '/Apartment/Detail/' + result.id;
            return;
        }
    } catch (e) {}

    if (statusEl) statusEl.innerHTML = '<p style="color:#64748b;font-size:.9rem">Listing fee paid. <a href="/OwnerListings/New" style="color:#F97316;font-weight:600">Create your listing now</a></p>';
    if (linksEl) linksEl.style.display = 'flex';
})();
</script>
}
