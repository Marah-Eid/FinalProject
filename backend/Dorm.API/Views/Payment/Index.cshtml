@using Dorm.Domain.Enums
@{
    Layout = User.FindFirstValue(ClaimTypes.Role) == "Student" ? "_BrowseLayout" : "_DashboardLayout";
    ViewData["Title"] = "Payments";
    var payments = (IReadOnlyList<Dorm.Application.DTOs.Payments.PaymentDto>)(ViewBag.Payments ?? Array.Empty<Dorm.Application.DTOs.Payments.PaymentDto>());
    var completed = payments.Where(p => p.Status == PaymentStatus.Completed).ToList();
    var total = completed.Sum(p => p.Amount);
}

@section Styles {
<style>
    .pay-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; }
    .pay-header p { color: #64748b; font-size: .9rem; }

    .pay-summary {
        background: #0f172a; border-radius: 14px; padding: 1.25rem 1.5rem;
        display: flex; align-items: center; gap: 1rem; color: #f8fafc; margin-bottom: 1.25rem;
    }
    .pay-summary-icon {
        width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,.1);
        display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
    }
    .pay-summary .label { font-size: .82rem; opacity: .6; }
    .pay-summary .amount { font-size: 1.5rem; font-weight: 800; }

    .pay-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }
    .pay-type-icon {
        width: 36px; height: 36px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center; font-size: .9rem;
    }
</style>
}

<div class="pay-header mb-4">
    <h3>Payments</h3>
    <p>Match commissions, listing fees and verified badge. Powered by Stripe.</p>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="border-radius:8px">@success</div>
}

@if (total > 0)
{
    <div class="pay-summary">
        <div class="pay-summary-icon"><i class="bi bi-wallet2"></i></div>
        <div><div class="label">Total Paid</div><div class="amount">@total JOD</div></div>
    </div>
}

<div class="pay-card">
    @if (payments.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-credit-card" style="font-size:2.5rem;color:#cbd5e1"></i>
            <h5 class="fw-bold mt-3" style="color:#1e293b">No payments yet</h5>
            <p style="color:#94a3b8;font-size:.88rem">Your payment history will appear here.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8">
                        <th>Type</th><th>Date</th><th>Reference</th><th class="text-center">Status</th><th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in payments)
                {
                    var typeLabel = p.Type switch { PaymentType.MatchCommission => "Match Commission", PaymentType.ListingFee => "Listing Fee", PaymentType.VerifiedBadge => "Verified Badge", _ => "Payment" };
                    var typeIcon = p.Type switch { PaymentType.MatchCommission => "bi-people-fill", PaymentType.ListingFee => "bi-building", PaymentType.VerifiedBadge => "bi-patch-check-fill", _ => "bi-credit-card" };
                    var typeColor = p.Type switch { PaymentType.MatchCommission => "#3b82f6", PaymentType.ListingFee => "#8B5CF6", PaymentType.VerifiedBadge => "#06B6D4", _ => "#64748b" };
                    var typeBg = p.Type switch { PaymentType.MatchCommission => "rgba(59,130,246,.1)", PaymentType.ListingFee => "rgba(139,92,246,.1)", PaymentType.VerifiedBadge => "rgba(6,182,212,.1)", _ => "#f1f5f9" };
                    var statusLabel = p.Status switch { PaymentStatus.Pending => "Pending", PaymentStatus.Completed => "Completed", PaymentStatus.Failed => "Failed", _ => "Pending" };
                    var statusColor = p.Status switch { PaymentStatus.Pending => "warning", PaymentStatus.Completed => "success", PaymentStatus.Failed => "danger", _ => "secondary" };
                    var statusIcon = p.Status switch { PaymentStatus.Pending => "bi-clock", PaymentStatus.Completed => "bi-check-circle", PaymentStatus.Failed => "bi-x-circle", _ => "bi-clock" };

                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="pay-type-icon" style="background:@typeBg;color:@typeColor"><i class="bi @typeIcon"></i></div>
                                <span class="fw-semibold" style="font-size:.88rem">@typeLabel</span>
                            </div>
                        </td>
                        <td style="color:#94a3b8;font-size:.82rem">@p.CreatedAt.ToString("MMM d, yyyy")</td>
                        <td style="color:#94a3b8;font-size:.82rem;font-family:monospace">@(p.TransactionRef ?? "—")</td>
                        <td class="text-center">
                            <span class="badge bg-@statusColor bg-opacity-10 text-@statusColor" style="font-size:.72rem"><i class="bi @statusIcon me-1"></i>@statusLabel</span>
                        </td>
                        <td class="text-end"><span class="fw-bold" style="font-size:.92rem;color:#1e293b">@p.Amount JOD</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
