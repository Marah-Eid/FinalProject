@using Dorm.Domain.Enums
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "New Listing";
    var requiresFee = (bool)(ViewBag.RequiresListingFee ?? false);
}

@section Styles {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    .nl-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: .15rem; }
    .nl-header p { color: #64748b; font-size: .9rem; }

    .nl-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; padding: 1.5rem; }
    .nl-section { font-size: .85rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #94a3b8; margin-bottom: 1rem; padding-bottom: .5rem; border-bottom: 1px solid #f1f5f9; }

    .nl-card .form-label { font-size: .82rem; font-weight: 600; color: #475569; }
    .nl-card .form-control, .nl-card .form-select {
        border-radius: 8px; border-color: #e2e8f0; font-size: .88rem;
    }
    .nl-card .form-control:focus, .nl-card .form-select:focus {
        border-color: #F97316; box-shadow: 0 0 0 3px rgba(249,115,22,.08);
    }
    .nl-card .form-check-input:checked { background-color: #F97316; border-color: #F97316; }

    .amenity-chip {
        display: inline-flex; align-items: center; gap: .3rem;
        padding: .4rem .8rem; border-radius: 8px; font-size: .82rem; font-weight: 500;
        border: 1px solid #e2e8f0; background: #fff; color: #64748b;
        cursor: pointer; transition: all .15s;
    }
    .amenity-chip.selected { background: #0f172a; color: #fff; border-color: #0f172a; }

    .btn-publish {
        background: #F97316; color: #fff; border: none; border-radius: 10px;
        font-weight: 600; font-size: .95rem; padding: .75rem;
        transition: all .2s;
    }
    .btn-publish:hover { background: #ea6c10; color: #fff; }

    #nl-map { border-radius: 12px; }

    .photo-thumb {
        position: relative; width: 80px; height: 80px; border-radius: 8px;
        overflow: hidden; border: 1px solid #e2e8f0;
    }
    .photo-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .photo-thumb .remove-btn {
        position: absolute; top: 2px; right: 2px; width: 20px; height: 20px;
        border-radius: 50%; background: rgba(0,0,0,.6); color: #fff;
        border: none; font-size: .65rem; display: flex; align-items: center;
        justify-content: center; cursor: pointer; line-height: 1;
    }
</style>
}

<div class="nl-header mb-4">
    <h3>New Listing</h3>
    <p>Tell students about the place.</p>
</div>
<div>
    <div class="nl-card">
        <div class="alert alert-danger d-none" id="nl-error" style="border-radius:8px"></div>
        <form id="nl-form" novalidate>
            @Html.AntiForgeryToken()
            <h6 class="nl-section">Basics</h6>
            <div class="mb-3"><label class="form-label">Title</label><input type="text" class="form-control" id="nl-title" required /></div>
            <div class="mb-3"><label class="form-label">Description <span class="text-danger">*</span></label><textarea class="form-control" id="nl-description" rows="3" required minlength="20" placeholder="At least 20 characters"></textarea></div>
            <div class="row g-3 mb-4">
                <div class="col-sm-4"><label class="form-label">City</label>
                    <select class="form-select" id="nl-city" required>
                        <option value="">—</option>
                        @foreach (var c in Enum.GetValues<City>())
                        {
                            <option value="@((int)c)">@c</option>
                        }
                    </select></div>
                <div class="col-sm-4"><label class="form-label">Neighborhood</label><input type="text" class="form-control" id="nl-neighborhood" required /></div>
                <div class="col-sm-4"><label class="form-label">Address Detail <span class="text-danger">*</span></label><input type="text" class="form-control" id="nl-address" required /></div>
            </div>

            <h6 class="nl-section">Location</h6>
            <div class="row g-3 mb-3">
                <div class="col-sm-6"><label class="form-label">Nearest University</label>
                    <select class="form-select" id="nl-university">
                        <option value="">—</option>
                        @foreach (var u in Enum.GetValues<University>())
                        {
                            <option value="@((int)u)">@u</option>
                        }
                    </select></div>
                <div class="col-sm-6"><label class="form-label">Walking Minutes</label><input type="number" class="form-control" id="nl-distance" min="1" /></div>
            </div>
            <div id="nl-map" style="height:200px;background:#f1f5f9" class="mb-4"></div>
            <input type="hidden" id="nl-lat" /><input type="hidden" id="nl-lng" />

            <h6 class="nl-section">Pricing & Spots</h6>
            <div class="row g-3 mb-4">
                <div class="col-sm-4"><label class="form-label">Full Rent (JOD)</label><input type="number" class="form-control" id="nl-rent" min="0" required /></div>
                <div class="col-sm-4"><label class="form-label">Total Spots</label><input type="number" class="form-control" id="nl-totalSpots" min="1" required /></div>
                <div class="col-sm-4"><label class="form-label">Available</label><input type="number" class="form-control" id="nl-availableSpots" min="0" required /></div>
            </div>

            <h6 class="nl-section">House Rules</h6>
            <div class="row g-3 mb-3">
                <div class="col-sm-4"><label class="form-label">Gender Policy</label>
                    <select class="form-select" id="nl-gender" required>
                        @foreach (var g in Enum.GetValues<GenderType>())
                        {
                            <option value="@((int)g)">@g</option>
                        }
                    </select></div>
                <div class="col-sm-4"><label class="form-label">Smoking</label>
                    <select class="form-select" id="nl-smoking">
                        @foreach (var s in Enum.GetValues<SmokingRule>())
                        {
                            <option value="@((int)s)">@s</option>
                        }
                    </select></div>
                <div class="col-sm-4"><label class="form-label">Guests</label>
                    <select class="form-select" id="nl-guests">
                        @foreach (var g in Enum.GetValues<GuestsRule>())
                        {
                            <option value="@((int)g)">@g</option>
                        }
                    </select></div>
            </div>
            <div class="form-check mb-4">
                <input type="checkbox" class="form-check-input" id="nl-furnished" />
                <label class="form-check-label" for="nl-furnished" style="font-size:.88rem">Furnished</label>
            </div>

            <h6 class="nl-section">Amenities</h6>
            <div class="d-flex flex-wrap gap-2 mb-4" id="nl-amenities">
                @foreach (var a in Enum.GetValues<AmenityType>())
                {
                    <div class="amenity-chip" data-key="@((int)a)" onclick="this.classList.toggle('selected')">@a</div>
                }
            </div>

            <h6 class="nl-section">Photos</h6>
            <div id="nl-photo-zone" style="border:2px dashed #e2e8f0;border-radius:12px;padding:2rem;text-align:center;cursor:pointer;transition:border-color .2s;margin-bottom:1rem"
                 ondragover="event.preventDefault();this.style.borderColor='#F97316'"
                 ondragleave="this.style.borderColor='#e2e8f0'"
                 ondrop="event.preventDefault();this.style.borderColor='#e2e8f0';addFiles(event.dataTransfer.files)"
                 onclick="document.getElementById('nl-photo-input').click()">
                <i class="bi bi-cloud-arrow-up" style="font-size:2rem;color:#94a3b8"></i>
                <p style="color:#64748b;font-size:.85rem;margin:.5rem 0 0">Click or drag photos here (max 10, jpg/png/webp)</p>
            </div>
            <input type="file" id="nl-photo-input" accept="image/jpeg,image/png,image/webp" multiple style="display:none" onchange="addFiles(this.files)" />
            <div id="nl-photo-preview" class="d-flex flex-wrap gap-2 mb-4"></div>

            @if (requiresFee)
            {
                <div id="fee-banner" class="mb-3" style="background:rgba(249,115,22,.06);border:1px solid rgba(249,115,22,.2);border-radius:10px;padding:1rem;display:flex;align-items:center;gap:.75rem">
                    <div style="width:40px;height:40px;border-radius:10px;background:rgba(249,115,22,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#F97316;font-size:1.1rem"><i class="bi bi-credit-card"></i></div>
                    <div><span class="fw-bold" style="font-size:.88rem;color:#1e293b">Listing fee required</span><br/><span style="font-size:.8rem;color:#64748b">A 10 JOD fee is required for additional listings. Your first listing was free.</span></div>
                </div>
            }
            <button type="submit" class="btn-publish w-100" id="nl-submit">Publish Listing</button>
        </form>
    </div>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
var feeRequired = @(requiresFee ? "true" : "false");
var csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

var selectedFiles = [];
function addFiles(fileList) {
    for (var i = 0; i < fileList.length; i++) {
        if (selectedFiles.length >= 10) break;
        var f = fileList[i];
        if (!f.type.match(/^image\/(jpeg|png|webp)$/)) continue;
        selectedFiles.push(f);
    }
    renderPreviews();
}
function removeFile(idx) {
    selectedFiles.splice(idx, 1);
    renderPreviews();
}
function renderPreviews() {
    var container = document.getElementById('nl-photo-preview');
    container.innerHTML = selectedFiles.map(function (f, i) {
        var url = URL.createObjectURL(f);
        return '<div class="photo-thumb">' +
            '<img src="' + url + '" alt="" />' +
            '<button type="button" class="remove-btn" onclick="removeFile(' + i + ')">&times;</button>' +
            '</div>';
    }).join('');
}

setTimeout(function () {
    var el = document.getElementById('nl-map');
    if (!el || !window.L) return;
    var mapInstance = L.map(el).setView([31.95, 35.93], 10);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OSM' }).addTo(mapInstance);
    var marker = null;
    mapInstance.on('click', function (e) {
        if (marker) mapInstance.removeLayer(marker);
        marker = L.marker(e.latlng).addTo(mapInstance);
        document.getElementById('nl-lat').value = e.latlng.lat;
        document.getElementById('nl-lng').value = e.latlng.lng;
    });
}, 300);

document.getElementById('nl-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var errBox = document.getElementById('nl-error');
    errBox.classList.add('d-none');

    var body = {
        title: document.getElementById('nl-title').value.trim(),
        description: document.getElementById('nl-description').value.trim(),
        city: parseInt(document.getElementById('nl-city').value),
        neighborhood: document.getElementById('nl-neighborhood').value.trim(),
        addressDetail: document.getElementById('nl-address').value.trim(),
        fullRent: parseFloat(document.getElementById('nl-rent').value),
        totalSpots: parseInt(document.getElementById('nl-totalSpots').value),
        availableSpots: parseInt(document.getElementById('nl-availableSpots').value),
        genderType: parseInt(document.getElementById('nl-gender').value),
        smokingRule: parseInt(document.getElementById('nl-smoking').value),
        guestsRule: parseInt(document.getElementById('nl-guests').value),
        isFurnished: document.getElementById('nl-furnished').checked,
        amenities: []
    };

    document.querySelectorAll('.amenity-chip.selected').forEach(function (el) { body.amenities.push(parseInt(el.dataset.key)); });

    var uni = document.getElementById('nl-university').value;
    if (uni) body.nearestUniversity = parseInt(uni);
    var dist = document.getElementById('nl-distance').value;
    if (dist) body.distanceMinutes = parseInt(dist);
    var lat = document.getElementById('nl-lat').value;
    var lng = document.getElementById('nl-lng').value;
    if (lat && lng) { body.latitude = parseFloat(lat); body.longitude = parseFloat(lng); }

    var errors = [];
    if (!body.title || body.title.length < 5) errors.push('Title must be at least 5 characters.');
    if (!body.description || body.description.length < 20) errors.push('Description must be at least 20 characters.');
    if (isNaN(body.city)) errors.push('Please select a city.');
    if (!body.neighborhood) errors.push('Neighborhood is required.');
    if (!body.addressDetail) errors.push('Address detail is required.');
    if (isNaN(body.fullRent) || body.fullRent <= 0) errors.push('Rent must be greater than 0.');
    if (isNaN(body.totalSpots) || body.totalSpots < 1) errors.push('Total spots must be at least 1.');
    if (isNaN(body.availableSpots)) errors.push('Available spots is required.');
    if (errors.length) {
        errBox.innerHTML = errors.join('<br>');
        errBox.classList.remove('d-none');
        return;
    }

    var btn = document.getElementById('nl-submit');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Publishing...';

    try {
        if (feeRequired) {
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing 10 JOD listing fee...';
            var payRes = await fetch('/Payment/Checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'type=1&__RequestVerificationToken=' + encodeURIComponent(csrfToken),
                redirect: 'manual'
            });
            if (payRes.status === 0 || payRes.type === 'opaqueredirect' || (payRes.status >= 300 && payRes.status < 400)) {
                sessionStorage.setItem('pendingListing', JSON.stringify(body));
                var loc = payRes.headers.get('Location');
                if (loc) { window.location.href = loc; return; }
            }
            feeRequired = false;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Creating listing...';
        }

        var res = await fetch('/OwnerListings/Create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
            body: JSON.stringify(body)
        });
        if (!res.ok) {
            var err = await res.json().catch(function () { return {}; });
            throw { message: err.error?.message || 'Failed to create listing.', details: err.error?.details };
        }
        var result = await res.json();

        if (selectedFiles.length > 0) {
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Uploading photos...';
            for (var i = 0; i < selectedFiles.length; i++) {
                var fd = new FormData();
                fd.append('file', selectedFiles[i]);
                fd.append('__RequestVerificationToken', csrfToken);
                await fetch('/OwnerListings/' + result.id + '/Photos', { method: 'POST', body: fd });
            }
        }
        window.location.href = '/Apartment/Detail/' + result.id;
    } catch (err) {
        var msg = err.message || 'Something went wrong. Please try again.';
        if (err.details && Array.isArray(err.details)) msg = err.details.map(function(d) { return d.message || d; }).join('<br>');
        errBox.innerHTML = msg;
        errBox.classList.remove('d-none');
        btn.disabled = false;
        btn.textContent = 'Publish Listing';
    }
});
</script>
}
