@using Dorm.Domain.Enums
@using Dorm.Application.DTOs.Apartments
@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "My Listings";
    var listings = (IReadOnlyList<ApartmentListItemDto>)(ViewBag.Listings ?? Array.Empty<ApartmentListItemDto>());
    var idMissing = (bool)(ViewBag.IdMissing ?? false);
    var idPending = (bool)(ViewBag.IdPending ?? false);
}

@section Styles {
<style>
    .ol-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .ol-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: .15rem; }
    .ol-header p { color: #64748b; font-size: .9rem; margin: 0; }
    .btn-new {
        background: #F97316; color: #fff; border: none; border-radius: 8px;
        padding: .55rem 1.1rem; font-weight: 600; font-size: .85rem;
        text-decoration: none; display: inline-flex; align-items: center; gap: .3rem;
        transition: all .2s;
    }
    .btn-new:hover { background: #ea6c10; color: #fff; }

    .ol-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }
    .listing-thumb {
        width: 52px; height: 52px; border-radius: 10px; background: #f1f5f9;
        overflow: hidden; flex-shrink: 0;
    }
    .listing-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .listing-thumb-placeholder {
        width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    }
    .spots-badge { font-size: .78rem; font-weight: 600; padding: .2rem .5rem; border-radius: 5px; }
    .spots-open { background: rgba(16,185,129,.1); color: #10b981; }
    .spots-full { background: #f1f5f9; color: #94a3b8; }
    .gender-badge { font-size: .75rem; font-weight: 500; padding: .2rem .5rem; border-radius: 5px; background: #f1f5f9; color: #64748b; }

    .btn-view, .btn-edit {
        border-radius: 6px; padding: .3rem .7rem; font-size: .78rem; font-weight: 600;
        text-decoration: none; transition: all .15s; display: inline-flex; align-items: center; gap: .25rem;
    }
    .btn-view { background: #fff; color: #475569; border: 1px solid #e2e8f0; }
    .btn-view:hover { background: #f8fafc; color: #1e293b; border-color: #cbd5e1; }
    .btn-edit { background: #fff; color: #F97316; border: 1px solid #fed7aa; }
    .btn-edit:hover { background: #fff7ed; color: #ea6c10; border-color: #F97316; }

    .empty-ol { text-align: center; padding: 3.5rem 1rem; }
    .empty-ol i { font-size: 2.5rem; color: #cbd5e1; }
    .empty-ol h5 { font-weight: 700; color: #1e293b; margin-top: .75rem; }
    .empty-ol p { color: #94a3b8; font-size: .88rem; }
</style>
}

@if (idMissing)
{
    <div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:12px;padding:1rem 1.25rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
        <div style="font-size:1.4rem">🪪</div>
        <div style="flex:1;min-width:0">
            <div style="font-weight:700;font-size:.9rem;color:#9a3412">Identity document required</div>
            <div style="font-size:.82rem;color:#c2410c;margin-top:.1rem">You must upload a national ID or property ownership document before you can post a listing. This helps students trust that you're a real owner.</div>
        </div>
        <a href="/Profile" style="background:#F97316;color:#fff;text-decoration:none;border-radius:8px;padding:.45rem 1rem;font-size:.82rem;font-weight:600;white-space:nowrap;flex-shrink:0">Upload ID →</a>
    </div>
}
else if (idPending)
{
    <div style="background:#fefce8;border:1px solid #fde68a;border-radius:12px;padding:1rem 1.25rem;margin-bottom:1.25rem;display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
        <div style="font-size:1.4rem">⏳</div>
        <div style="flex:1;min-width:0">
            <div style="font-weight:700;font-size:.9rem;color:#92400e">ID under review</div>
            <div style="font-size:.82rem;color:#b45309;margin-top:.1rem">Your document has been submitted and is awaiting admin review. You can post listings in the meantime — your verified badge will appear once approved.</div>
        </div>
    </div>
}

<div class="ol-header">
    <div>
        <h3>My Listings</h3>
        <p>Manage the apartments you've listed.</p>
    </div>
    <a href="/OwnerListings/New" class="btn-new"><i class="bi bi-plus-lg"></i> New Listing</a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="border-radius:8px">@success</div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger" style="border-radius:8px">@err</div>
}

<div class="ol-card">
    @if (listings.Count == 0)
    {
        <div class="empty-ol">
            <i class="bi bi-building"></i>
            <h5>No listings yet</h5>
            <p>List your first apartment to start receiving applications.</p>
            <a href="/OwnerListings/New" class="btn-new"><i class="bi bi-plus-lg"></i> New Listing</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8">
                        <th>Apartment</th><th>Location</th><th class="text-center">Rent</th><th class="text-center">Spots</th><th class="text-center">Gender</th><th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var apt in listings)
                {
                    var genderLabel = apt.GenderType switch { GenderType.MaleOnly => "Male Only", GenderType.FemaleOnly => "Female Only", _ => "Mixed" };
                    var spotsOpen = apt.AvailableSpots > 0;
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="listing-thumb">
                                    @if (!string.IsNullOrEmpty(apt.MainPhotoUrl))
                                    {
                                        <img src="@apt.MainPhotoUrl" alt="" />
                                    }
                                    else
                                    {
                                        <div class="listing-thumb-placeholder"><i class="bi bi-building" style="color:#94a3b8"></i></div>
                                    }
                                </div>
                                <span class="fw-semibold" style="font-size:.88rem">@apt.Title</span>
                            </div>
                        </td>
                        <td style="color:#94a3b8;font-size:.82rem">@apt.Neighborhood</td>
                        <td class="text-center"><span class="fw-bold" style="font-size:.92rem;color:#1e293b">@apt.FullRent JOD</span></td>
                        <td class="text-center"><span class="spots-badge @(spotsOpen ? "spots-open" : "spots-full")">@apt.AvailableSpots / @apt.TotalSpots</span></td>
                        <td class="text-center"><span class="gender-badge">@genderLabel</span></td>
                        <td class="text-end d-flex align-items-center justify-content-end gap-1 flex-wrap">
                            <a href="/OwnerListings/Edit/@apt.Id" class="btn-edit"><i class="bi bi-pencil"></i>Edit</a>
                            <a href="/Apartment/Detail/@apt.Id" class="btn-view"><i class="bi bi-eye"></i>View</a>
                            <form method="post" asp-action="Delete" asp-controller="OwnerListings" asp-route-id="@apt.Id"
                                  style="margin:0" onsubmit="return confirm('Delete «@apt.Title»? This cannot be undone.')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-view" style="color:#ef4444;border-color:#fecaca;background:#fff">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
