@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "Contact";
    var isAuth = User.Identity?.IsAuthenticated == true;
    var userName = isAuth ? User.FindFirstValue("FullName") ?? "" : "";
    var userEmail2 = isAuth ? User.FindFirstValue(ClaimTypes.Email) ?? "" : "";
}

@section Styles {
<style>
    .contact-hero {
        background: #0f172a; padding: 4rem 0 3rem; color: #fff; text-align: center;
    }
    .contact-hero h1 { font-size: 2rem; font-weight: 800; color: #f8fafc; margin-bottom: .4rem; }
    .contact-hero p { color: #64748b; font-size: 1rem; margin: 0; }

    .contact-body { padding: 3rem 0 5rem; }

    .info-card {
        background: #fff; border-radius: 12px; border: 1px solid #e2e8f0;
        padding: 1.2rem 1.4rem; display: flex; align-items: center; gap: .9rem;
        transition: transform .2s, box-shadow .2s;
    }
    .info-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.07); }
    .info-icon {
        width: 42px; height: 42px; border-radius: 10px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center; font-size: 1rem;
    }
    .info-label { font-size: .72rem; color: #94a3b8; margin-bottom: .1rem; }
    .info-value { font-size: .88rem; font-weight: 600; color: #1e293b; }
    .info-card a { color: #F97316; text-decoration: none; font-weight: 600; font-size: .88rem; }
    .info-card a:hover { text-decoration: underline; }

    .form-card {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 2rem;
    }
    .form-card h4 { font-size: 1.05rem; font-weight: 800; color: #1e293b; margin-bottom: 1.25rem; }
    .form-card label { font-size: .82rem; font-weight: 600; color: #475569; margin-bottom: .3rem; }
    .form-card .form-control, .form-card .form-select {
        padding: .65rem .9rem; border-radius: 8px; font-size: .88rem;
    }
    .btn-send {
        background: #F97316; color: #fff; border: none; border-radius: 8px;
        padding: .65rem 1.5rem; font-weight: 600; font-size: .88rem;
        display: inline-flex; align-items: center; gap: .4rem; transition: background .2s;
    }
    .btn-send:hover { background: #ea6c0a; }
</style>
}

<div class="contact-hero">
    <div class="container">
        <h1>Contact Us</h1>
        <p>Have a question, feedback, or need help? We'd love to hear from you.</p>
    </div>
</div>

<div class="contact-body">
    <div class="container">
        <div class="row g-4">

            <!-- Info column -->
            <div class="col-lg-4 d-flex flex-column gap-3">
                <div class="info-card">
                    <div class="info-icon" style="background:rgba(249,115,22,.1);color:#F97316">
                        <i class="bi bi-envelope-fill"></i>
                    </div>
                    <div>
                        <div class="info-label">Email</div>
                        <a href="mailto:support@dorm.jo">support@dorm.jo</a>
                    </div>
                </div>
                <div class="info-card">
                    <div class="info-icon" style="background:rgba(59,130,246,.1);color:#3b82f6">
                        <i class="bi bi-telephone-fill"></i>
                    </div>
                    <div>
                        <div class="info-label">Phone</div>
                        <div class="info-value">+962 6 000 0000</div>
                    </div>
                </div>
                <div class="info-card">
                    <div class="info-icon" style="background:rgba(16,185,129,.1);color:#10b981">
                        <i class="bi bi-geo-alt-fill"></i>
                    </div>
                    <div>
                        <div class="info-label">Location</div>
                        <div class="info-value">Amman, Jordan</div>
                    </div>
                </div>
                <div class="info-card">
                    <div class="info-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <div>
                        <div class="info-label">Working Hours</div>
                        <div class="info-value">Sun – Thu, 9 AM – 5 PM</div>
                    </div>
                </div>
            </div>

            <!-- Form column -->
            <div class="col-lg-8">
                <div class="form-card">
                    <h4>Send a Message</h4>

                    @if (TempData["Success"] is string)
                    {
                        <div class="alert alert-success" style="border-radius:8px;font-size:.88rem">
                            <i class="bi bi-check-circle-fill me-1"></i> Your message was sent. We'll get back to you soon!
                        </div>
                    }
                    @if (TempData["Error"] is string err)
                    {
                        <div class="alert alert-danger" style="border-radius:8px;font-size:.88rem">@err</div>
                    }

                    <form method="post" asp-action="Send" asp-controller="Contact">
                        @Html.AntiForgeryToken()
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Your Name</label>
                                <input type="text" class="form-control" name="name" placeholder="Full name" required value="@userName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="email" placeholder="you@example.com" required value="@userEmail2" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <select class="form-select" name="subject">
                                <option value="General Inquiry">General Inquiry</option>
                                <option value="Technical Support">Technical Support</option>
                                <option value="Feedback">Feedback</option>
                                <option value="Report an Issue">Report an Issue</option>
                                <option value="Partnership">Partnership</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" name="message" rows="5" placeholder="How can we help?" required style="resize:none"></textarea>
                        </div>
                        <button type="submit" class="btn-send">
                            <i class="bi bi-send"></i> Send Message
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
