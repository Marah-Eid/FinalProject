@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "About & Contact";
}

@section Styles {
<style>
    /* Hero banner */
    .about-hero {
        background: #0f172a; padding: 4.5rem 0 3.5rem; text-align: center;
        position: relative; overflow: hidden;
    }
    .about-hero::before {
        content: '';
        position: absolute; top: -120px; right: -80px;
        width: 350px; height: 350px; border-radius: 50%;
        background: radial-gradient(circle, rgba(249,115,22,.08) 0%, transparent 70%);
        pointer-events: none;
    }
    .about-hero::after {
        content: '';
        position: absolute; bottom: -100px; left: -60px;
        width: 280px; height: 280px; border-radius: 50%;
        background: radial-gradient(circle, rgba(59,130,246,.06) 0%, transparent 70%);
        pointer-events: none;
    }
    .about-hero h1 {
        font-size: 2rem; font-weight: 800; color: #f8fafc;
        margin-bottom: .5rem; position: relative;
    }
    .about-hero p {
        color: #64748b; font-size: 1rem; max-width: 440px;
        margin: 0 auto; position: relative;
    }

    /* Content area */
    .about-content { padding: 3rem 0 4rem; }

    /* Feature-style cards */
    .about-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 3rem; }
    .about-card {
        background: #fff; border-radius: 14px; padding: 1.6rem;
        border: 1px solid #e2e8f0;
        transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s;
    }
    .about-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,.07);
        border-color: transparent;
    }
    .about-card-icon {
        width: 44px; height: 44px; border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem; margin-bottom: .9rem;
    }
    .about-card h4 { font-size: .95rem; font-weight: 700; color: #1e293b; margin-bottom: .35rem; }
    .about-card p { font-size: .84rem; color: #64748b; line-height: 1.65; margin: 0; }

    /* Steps row */
    .steps-banner {
        background: #f8fafc; border-radius: 16px; border: 1px solid #f1f5f9;
        padding: 2rem 1.5rem; margin-bottom: 3rem; text-align: center;
    }
    .steps-banner h3 {
        font-size: 1.1rem; font-weight: 800; color: #1e293b; margin-bottom: 1.5rem;
    }
    .steps-grid { display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap; }
    .step-item { flex: 1; min-width: 140px; max-width: 180px; }
    .step-num {
        width: 36px; height: 36px; border-radius: 50%;
        background: #F97316; color: #fff; font-weight: 700; font-size: .85rem;
        display: inline-flex; align-items: center; justify-content: center;
        margin-bottom: .5rem;
    }
    .step-item h5 { font-size: .82rem; font-weight: 700; color: #1e293b; margin-bottom: .15rem; }
    .step-item p { font-size: .76rem; color: #94a3b8; line-height: 1.5; margin: 0; }

    /* Contact section */
    .contact-section h3 {
        font-size: 1.1rem; font-weight: 800; color: #1e293b;
        margin-bottom: .35rem; text-align: center;
    }
    .contact-section .contact-sub {
        color: #94a3b8; font-size: .88rem; text-align: center; margin-bottom: 1.5rem;
    }
    .contact-grid {
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;
        max-width: 560px; margin: 0 auto;
    }
    .contact-card {
        background: #fff; border-radius: 12px; border: 1px solid #e2e8f0;
        padding: 1.2rem; display: flex; align-items: center; gap: .8rem;
        transition: transform .2s, box-shadow .2s;
    }
    .contact-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.06); }
    .contact-icon {
        width: 40px; height: 40px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; flex-shrink: 0;
    }
    .contact-card .c-label { font-size: .72rem; color: #94a3b8; margin-bottom: .1rem; }
    .contact-card .c-value { font-size: .85rem; font-weight: 600; color: #1e293b; }
    .contact-card a {
        color: #F97316; text-decoration: none; font-weight: 600; font-size: .85rem;
    }
    .contact-card a:hover { text-decoration: underline; }

    @@media (max-width: 767px) {
        .about-cards { grid-template-columns: 1fr; }
        .contact-grid { grid-template-columns: 1fr; }
        .about-hero h1 { font-size: 1.5rem; }
    }
</style>
}

<!-- Hero -->
<div class="about-hero">
    <div class="container">
        <h1>About Dorm</h1>
        <p>Helping Jordanian university students find compatible housing near campus.</p>
    </div>
</div>

<div class="about-content">
    <div class="container">

        <!-- What we offer — 3 cards -->
        <div class="about-cards">
            <div class="about-card">
                <div class="about-card-icon" style="background:rgba(249,115,22,.1);color:#F97316">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h4>Roommate Matching</h4>
                <p>An 8-question lifestyle quiz generates a compatibility score with every apartment's current tenants.</p>
            </div>
            <div class="about-card">
                <div class="about-card-icon" style="background:rgba(16,185,129,.1);color:#10b981">
                    <i class="bi bi-geo-alt-fill"></i>
                </div>
                <h4>Near Your Campus</h4>
                <p>Filter by university, city, price, and distance. We cover 20 universities across 8 cities in Jordan.</p>
            </div>
            <div class="about-card">
                <div class="about-card-icon" style="background:rgba(59,130,246,.1);color:#3b82f6">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h4>Verified & Transparent</h4>
                <p>University-email badges, real reviews, and private addresses released only after acceptance.</p>
            </div>
        </div>

        <!-- How it works — mini steps -->
        <div class="steps-banner">
            <h3>How It Works</h3>
            <div class="steps-grid">
                <div class="step-item">
                    <div class="step-num">1</div>
                    <h5>Sign Up</h5>
                    <p>Create a free account as a student or owner.</p>
                </div>
                <div class="step-item">
                    <div class="step-num">2</div>
                    <h5>Take the Quiz</h5>
                    <p>Answer 8 lifestyle questions about your habits.</p>
                </div>
                <div class="step-item">
                    <div class="step-num">3</div>
                    <h5>Browse & Match</h5>
                    <p>See your compatibility with each apartment's tenants.</p>
                </div>
                <div class="step-item">
                    <div class="step-num">4</div>
                    <h5>Apply & Move In</h5>
                    <p>Apply, chat with the owner, and get accepted.</p>
                </div>
            </div>
        </div>

        <!-- Contact -->
        <div class="contact-section">
            <h3>Get in Touch</h3>
            <p class="contact-sub">Have a question or need help? Reach out to us.</p>
            <div class="contact-grid">
                <div class="contact-card">
                    <div class="contact-icon" style="background:rgba(249,115,22,.1);color:#F97316">
                        <i class="bi bi-envelope-fill"></i>
                    </div>
                    <div>
                        <div class="c-label">Email</div>
                        <a href="mailto:support@dorm.jo">support@dorm.jo</a>
                    </div>
                </div>
                <div class="contact-card">
                    <div class="contact-icon" style="background:rgba(59,130,246,.1);color:#3b82f6">
                        <i class="bi bi-telephone-fill"></i>
                    </div>
                    <div>
                        <div class="c-label">Phone</div>
                        <div class="c-value">+962 6 000 0000</div>
                    </div>
                </div>
                <div class="contact-card">
                    <div class="contact-icon" style="background:rgba(16,185,129,.1);color:#10b981">
                        <i class="bi bi-geo-alt-fill"></i>
                    </div>
                    <div>
                        <div class="c-label">Location</div>
                        <div class="c-value">Amman, Jordan</div>
                    </div>
                </div>
                <div class="contact-card">
                    <div class="contact-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6">
                        <i class="bi bi-clock-fill"></i>
                    </div>
                    <div>
                        <div class="c-label">Hours</div>
                        <div class="c-value">Sun — Thu, 9 — 5 PM</div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
