@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Dashboard";

    var fullName = User.FindFirstValue("FullName") ?? "User";
    var unreadMessages = (int)(ViewBag.UnreadMessages ?? 0);
}

@section Styles {
<style>
    .welcome-card {
        border-radius: 14px; padding: 1.5rem; border: none;
        display: flex; align-items: center; gap: 1rem;
        background: #0f172a; color: #f8fafc;
    }
    .welcome-avatar {
        width: 48px; height: 48px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; flex-shrink: 0;
        background: rgba(249,115,22,.2); color: #F97316;
    }
    .welcome-card h4 { font-size: 1.1rem; font-weight: 700; margin-bottom: .15rem; }
    .welcome-card p { margin: 0; opacity: .6; font-size: .88rem; }

    .stat-card {
        background: #fff; border-radius: 12px; border: 1px solid #f1f5f9;
        padding: 1rem; display: flex; align-items: center; gap: .75rem;
    }
    .stat-icon {
        width: 44px; height: 44px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem; flex-shrink: 0;
    }
    .stat-label { font-size: .75rem; color: #94a3b8; font-weight: 500; }
    .stat-value { font-size: 1.2rem; font-weight: 800; color: #1e293b; }

    .section-card {
        background: #fff; border-radius: 12px; border: 1px solid #f1f5f9;
        overflow: hidden; height: 100%;
    }
    .section-card-header {
        padding: 1rem 1.25rem; border-bottom: 1px solid #f8fafc;
        display: flex; justify-content: space-between; align-items: center;
    }
    .section-card-header h6 { font-weight: 700; font-size: .9rem; color: #1e293b; margin: 0; }
    .btn-view-all {
        font-size: .78rem; font-weight: 600; color: #F97316;
        text-decoration: none; display: inline-flex; align-items: center; gap: .2rem;
    }

    .shortcut-item {
        display: flex; align-items: center; gap: .75rem; padding: .65rem 1.25rem;
        text-decoration: none; color: #475569; border-bottom: 1px solid #f8fafc;
    }
    .shortcut-item:hover { background: #f8fafc; color: #1e293b; }
    .shortcut-icon {
        width: 32px; height: 32px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center; font-size: .9rem;
    }
    .shortcut-item span { font-weight: 600; font-size: .85rem; }
    .shortcut-item .bi-chevron-right { margin-left: auto; font-size: .7rem; color: #cbd5e1; }

    .empty-section { text-align: center; padding: 2rem 1rem; }
    .empty-section i { font-size: 2rem; color: #cbd5e1; }
    .empty-section p { color: #94a3b8; font-size: .85rem; margin-top: .5rem; }

    .btn-new-listing {
        background: #F97316; color: #fff; border: none; border-radius: 8px;
        padding: .5rem 1rem; font-weight: 600; font-size: .85rem;
        text-decoration: none; display: inline-flex; align-items: center; gap: .3rem;
        margin-left: auto;
    }
    .btn-new-listing:hover { background: #ea6c10; color: #fff; }
</style>
}

@using Dorm.Domain.Entities
@using Dorm.Domain.Enums
@{
    var listings = (IReadOnlyList<Dorm.Application.DTOs.Apartments.ApartmentListItemDto>)(ViewBag.OwnerListings ?? Array.Empty<Dorm.Application.DTOs.Apartments.ApartmentListItemDto>());
    var received = (IReadOnlyList<Dorm.Application.DTOs.Applications.ApplicationReceivedDto>)(ViewBag.ReceivedApps ?? Array.Empty<Dorm.Application.DTOs.Applications.ApplicationReceivedDto>());
    var pendingApps = (int)(ViewBag.PendingApps ?? 0);
    var acceptedApps = (int)(ViewBag.AcceptedApps ?? 0);
    var pending = received.Where(a => a.Status == Dorm.Domain.Enums.ApplicationStatus.Pending).ToList();
    var notifications = (IReadOnlyList<Notification>)(ViewBag.Notifications ?? Array.Empty<Notification>());
    var unreadNotifs = (int)(ViewBag.UnreadNotifications ?? 0);
}

<div class="welcome-card mb-4">
        <div class="welcome-avatar"><i class="bi bi-house-door-fill"></i></div>
        <div class="flex-grow-1">
            <h4>Welcome back, @fullName</h4>
            <p>Manage your listings and review applications.</p>
        </div>
        <a href="/OwnerListings/New" class="btn-new-listing"><i class="bi bi-plus-lg"></i> New listing</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:#f1f5f9;color:#475569"><i class="bi bi-building"></i></div>
                <div><div class="stat-label">Active Listings</div><div class="stat-value">@listings.Count</div></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(234,179,8,.1);color:#eab308"><i class="bi bi-clock-history"></i></div>
                <div><div class="stat-label">Pending Apps</div><div class="stat-value">@pendingApps</div></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(16,185,129,.1);color:#10b981"><i class="bi bi-check-circle"></i></div>
                <div><div class="stat-label">Accepted</div><div class="stat-value">@acceptedApps</div></div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6"><i class="bi bi-chat-dots"></i></div>
                <div><div class="stat-label">Unread</div><div class="stat-value">@unreadMessages</div></div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            @if (pending.Count > 0)
            {
                <div class="section-card">
                    <div class="section-card-header">
                        <h6>Pending Applications</h6>
                        <a href="/OwnerApps" class="btn-view-all">View all <i class="bi bi-chevron-right"></i></a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <tbody>
                            @foreach (var a in pending.Take(5))
                            {
                                var init = string.Join("", (a.StudentFullName ?? "U").Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : "")).ToUpper();
                                if (init.Length > 2) init = init.Substring(0, 2);
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width:32px;height:32px;border-radius:50%;background:#f1f5f9;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.7rem;color:#64748b">@init</div>
                                            <div>
                                                <span class="fw-semibold" style="font-size:.85rem">@a.StudentFullName</span><br />
                                                <span style="color:#94a3b8;font-size:.75rem">@a.ApartmentTitle</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <span class="badge bg-warning bg-opacity-10 text-warning" style="font-size:.72rem"><i class="bi bi-clock me-1"></i>Pending</span>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="section-card">
                    <div class="empty-section"><i class="bi bi-inbox"></i><p>No pending applications</p></div>
                </div>
            }
        </div>
        <div class="col-lg-4 d-flex flex-column gap-3">
            <div class="section-card">
                <div class="section-card-header"><h6>Quick Links</h6></div>
                <a href="/OwnerListings/New" class="shortcut-item"><div class="shortcut-icon" style="background:rgba(249,115,22,.1);color:#F97316"><i class="bi bi-plus-circle"></i></div><span>New listing</span><i class="bi bi-chevron-right"></i></a>
                <a href="/OwnerListings" class="shortcut-item"><div class="shortcut-icon" style="background:#f1f5f9;color:#475569"><i class="bi bi-building"></i></div><span>My listings</span><i class="bi bi-chevron-right"></i></a>
                <a href="/OwnerApps" class="shortcut-item"><div class="shortcut-icon" style="background:rgba(234,179,8,.1);color:#eab308"><i class="bi bi-people"></i></div><span>Applications</span><i class="bi bi-chevron-right"></i></a>
                <a href="/Chat" class="shortcut-item"><div class="shortcut-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6"><i class="bi bi-chat-dots"></i></div><span>Messages</span><i class="bi bi-chevron-right"></i></a>
                <a href="/Payment" class="shortcut-item"><div class="shortcut-icon" style="background:rgba(6,182,212,.1);color:#06B6D4"><i class="bi bi-credit-card"></i></div><span>Payments</span><i class="bi bi-chevron-right"></i></a>
            </div>

            <!-- Notifications -->
            <div class="section-card">
                <div class="section-card-header">
                    <h6>
                        Notifications
                        @if (unreadNotifs > 0)
                        {
                            <span style="background:#ef4444;color:#fff;border-radius:999px;font-size:.65rem;font-weight:700;padding:1px 6px;margin-left:4px;vertical-align:middle">@unreadNotifs</span>
                        }
                    </h6>
                    @if (unreadNotifs > 0)
                    {
                        <form method="post" asp-action="MarkNotificationsRead" asp-controller="Dashboard" style="margin:0">
                            @Html.AntiForgeryToken()
                            <button type="submit" style="background:none;border:none;color:#F97316;font-size:.75rem;font-weight:600;cursor:pointer;padding:0">Mark all read</button>
                        </form>
                    }
                </div>
                @if (notifications.Count == 0)
                {
                    <div class="empty-section"><i class="bi bi-bell"></i><p>No notifications yet</p></div>
                }
                else
                {
                    @foreach (var n in notifications.Take(8))
                    {
                        var (icon, color) = n.Type switch {
                            NotificationType.IdVerified  => ("bi-shield-fill-check", "#10b981"),
                            NotificationType.IdRejected  => ("bi-shield-x", "#ef4444"),
                            NotificationType.NewApplicationReceived => ("bi-person-plus-fill", "#3b82f6"),
                            NotificationType.ApplicationAccepted   => ("bi-check-circle-fill", "#10b981"),
                            NotificationType.ApplicationRejected   => ("bi-x-circle-fill", "#ef4444"),
                            NotificationType.ListingSuspended       => ("bi-exclamation-triangle-fill", "#eab308"),
                            _ => ("bi-bell-fill", "#94a3b8")
                        };
                        <div style="padding:.75rem 1.25rem;border-bottom:1px solid #f8fafc;display:flex;gap:.75rem;align-items:flex-start;@(!n.IsRead ? "background:#fefce8;" : "")">
                            <i class="bi @icon" style="color:@color;font-size:1rem;flex-shrink:0;margin-top:.1rem"></i>
                            <div style="flex:1;min-width:0">
                                <div style="font-weight:700;font-size:.82rem;color:#1e293b">@n.Title</div>
                                <div style="font-size:.76rem;color:#64748b;line-height:1.5;margin-top:.1rem">@n.Content</div>
                                <div style="font-size:.7rem;color:#94a3b8;margin-top:.2rem">@n.CreatedAt.ToString("MMM d, h:mm tt")</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
