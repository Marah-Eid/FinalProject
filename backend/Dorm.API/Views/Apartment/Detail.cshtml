@using Dorm.Domain.Enums
@using Dorm.Application.DTOs.Apartments
@{
    Layout = "_BrowseLayout";
    var apt = (ApartmentDetailDto)ViewBag.Apartment;
    ViewData["Title"] = apt.Title;
    var isAuth = User.Identity?.IsAuthenticated == true;
    var role = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = isAuth && role == "Owner" && apt.Owner != null && userId == apt.Owner.Id.ToString();
    var compat = ViewBag.Compatibility as Dorm.Application.DTOs.Compatibility.CompatibilityBreakdownDto;
    var isSaved = (bool?)ViewBag.IsSaved ?? false;
    var photos = apt.Photos ?? new List<ApartmentPhotoDto>();
    var mainPhoto = photos.Count > 0 ? photos[0].PhotoUrl : "/property/images/img_1.jpg";

    var genderLabel = apt.GenderType switch { GenderType.MaleOnly => "Male Only", GenderType.FemaleOnly => "Female Only", _ => "Mixed" };
    var smokingLabel = apt.SmokingRule switch { SmokingRule.Yes => "Yes", SmokingRule.No => "No", SmokingRule.Outside => "Outside Only", _ => "No" };
    var guestsLabel = apt.GuestsRule switch { GuestsRule.Yes => "Yes", GuestsRule.No => "No", GuestsRule.Limited => "Limited", _ => "No" };

    var amenityLabels = new Dictionary<AmenityType, string> {
        { AmenityType.WiFi, "WiFi" }, { AmenityType.AC, "AC" }, { AmenityType.Heating, "Heating" },
        { AmenityType.WashingMachine, "Washing Machine" }, { AmenityType.Parking, "Parking" },
        { AmenityType.Furnished, "Furnished" }, { AmenityType.Elevator, "Elevator" },
        { AmenityType.Balcony, "Balcony" }, { AmenityType.Kitchen, "Kitchen" },
        { AmenityType.PrivateBathroom, "Private Bathroom" }
    };
    var amenityIcons = new Dictionary<AmenityType, string> {
        { AmenityType.WiFi, "bi-wifi" }, { AmenityType.AC, "bi-snow" }, { AmenityType.Heating, "bi-thermometer-sun" },
        { AmenityType.WashingMachine, "bi-droplet" }, { AmenityType.Parking, "bi-car-front" },
        { AmenityType.Furnished, "bi-lamp" }, { AmenityType.Elevator, "bi-arrow-up-square" },
        { AmenityType.Balcony, "bi-sun" }, { AmenityType.Kitchen, "bi-cup-hot" },
        { AmenityType.PrivateBathroom, "bi-droplet-half" }
    };
}

@section Styles {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    .detail-hero { background: #0f172a; padding: 5rem 0 0; }
    .detail-body { background: #f8fafc; padding: 2rem 0 4rem; margin-top: -2rem; position: relative; z-index: 2; }

    .gallery-wrap { border-radius: 16px; overflow: hidden; background: #1e293b; }
    .gallery-main { width: 100%; height: 360px; object-fit: cover; display: block; cursor: pointer; transition: transform .3s; }
    .gallery-main:hover { transform: scale(1.02); }
    .gallery-thumbs { display: flex; gap: 4px; margin-top: 4px; }
    .gallery-thumb {
        flex: 1; height: 80px; object-fit: cover; cursor: pointer; opacity: .6;
        transition: opacity .2s;
    }
    .gallery-thumb:hover, .gallery-thumb.active { opacity: 1; }

    .detail-card {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 1.5rem; margin-bottom: 1.25rem;
    }
    .detail-card h5 {
        font-size: .85rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .06em; color: #94a3b8; margin-bottom: 1rem;
    }

    .detail-title { font-size: 1.6rem; font-weight: 800; color: #1e293b; margin-bottom: .25rem; }
    .detail-loc { font-size: .9rem; color: #64748b; display: flex; align-items: center; gap: .3rem; margin-bottom: 1rem; }
    .detail-desc { font-size: .92rem; color: #475569; line-height: 1.7; }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
    .info-item { display: flex; align-items: center; gap: .6rem; font-size: .88rem; color: #475569; }
    .info-item .ii-icon {
        width: 36px; height: 36px; border-radius: 8px; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        color: #64748b; font-size: .9rem; flex-shrink: 0;
    }
    .info-item strong { color: #1e293b; font-weight: 600; }

    .amenity-badge {
        display: inline-flex; align-items: center; gap: .3rem;
        background: #f1f5f9; color: #475569; border-radius: 8px;
        padding: .4rem .7rem; font-size: .8rem; font-weight: 500;
    }

    .tenant-row {
        display: flex; align-items: center; gap: .6rem;
        padding: .6rem 0; border-bottom: 1px solid #f8fafc;
    }
    .tenant-avatar {
        width: 36px; height: 36px; border-radius: 50%; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .75rem; color: #64748b; flex-shrink: 0;
    }
    .tenant-name { font-weight: 600; color: #1e293b; font-size: .88rem; }
    .tenant-info { font-size: .78rem; color: #94a3b8; }

    .price-card {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 1.5rem; position: sticky; top: 100px;
    }
    .price-card .price { font-size: 1.8rem; font-weight: 800; color: #1e293b; }
    .price-card .price span { font-size: .85rem; font-weight: 400; color: #94a3b8; }
    .price-card .gender-tag {
        display: inline-flex; align-items: center; gap: .3rem;
        background: #f1f5f9; color: #475569; border-radius: 6px;
        padding: .3rem .6rem; font-size: .78rem; font-weight: 600;
    }

    .compat-ring {
        width: 80px; height: 80px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 1rem auto; font-size: 1.2rem; font-weight: 800;
    }
    .compat-high { border: 4px solid #10b981; color: #10b981; background: rgba(16,185,129,.06); }
    .compat-mid  { border: 4px solid #eab308; color: #eab308; background: rgba(234,179,8,.06); }
    .compat-low  { border: 4px solid #94a3b8; color: #94a3b8; background: rgba(148,163,184,.06); }

    .compat-breakdown { margin-top: .75rem; }
    .compat-pill {
        display: inline-flex; align-items: center; gap: .25rem;
        padding: .2rem .55rem; border-radius: 6px;
        font-size: .72rem; font-weight: 600; margin: .15rem .1rem;
    }
    .compat-pill-match { background: rgba(16,185,129,.08); color: #10b981; }
    .compat-pill-diff { background: rgba(239,68,68,.08); color: #ef4444; }
    .compat-label { font-size: .72rem; font-weight: 600; color: #94a3b8; margin-bottom: .25rem; text-transform: uppercase; letter-spacing: .04em; }

    .btn-apply {
        background: #F97316; color: #fff; border: none; border-radius: 10px;
        font-weight: 600; font-size: .95rem; padding: .75rem; width: 100%;
        transition: all .2s;
    }
    .btn-apply:hover { background: #ea6c10; color: #fff; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(249,115,22,.25); }

    .btn-back {
        color: #94a3b8; text-decoration: none; font-size: .85rem; font-weight: 500;
        display: inline-flex; align-items: center; gap: .3rem;
        transition: color .2s;
    }
    .btn-back:hover { color: #fff; }

    .btn-save-detail {
        display: inline-flex; align-items: center; gap: .4rem;
        background: rgba(239,68,68,.06); color: #94a3b8; border: 1px solid #e2e8f0;
        border-radius: 8px; padding: .45rem .9rem; font-size: .82rem; font-weight: 600;
        cursor: pointer; transition: all .2s;
    }
    .btn-save-detail:hover { border-color: #ef4444; color: #ef4444; }
    .btn-save-detail.saved { background: rgba(239,68,68,.08); color: #ef4444; border-color: #ef4444; }

    #apt-map { border-radius: 12px; }
</style>
}

<div class="detail-hero">
    <div class="container">
        <a href="/Browse" class="btn-back"><i class="bi bi-arrow-left"></i> Back to Browse</a>
    </div>
</div>

<div class="detail-body">
    <div class="container">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success" style="border-radius:8px">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger" style="border-radius:8px">@error</div>
        }

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="gallery-wrap">
                    <img src="@mainPhoto" alt="@apt.Title" class="gallery-main" id="gallery-main" />
                    @if (photos.Count > 1)
                    {
                        <div class="gallery-thumbs">
                            @foreach (var p in photos)
                            {
                                <img src="@p.PhotoUrl" alt="" class="gallery-thumb @(p == photos[0] ? "active" : "")" onclick="switchPhoto(this,'@p.PhotoUrl')" />
                            }
                        </div>
                    }
                </div>

                <div class="mt-4">
                    <h1 class="detail-title">@apt.Title</h1>
                    <div class="detail-loc"><i class="bi bi-geo-alt-fill"></i> @apt.Neighborhood</div>
                    @if (!string.IsNullOrEmpty(apt.Description))
                    {
                        <p class="detail-desc">@apt.Description</p>
                    }
                </div>

                <div class="detail-card">
                    <h5>Details</h5>
                    <div class="info-grid">
                        <div class="info-item"><div class="ii-icon"><i class="bi bi-door-open"></i></div><div><strong>@apt.AvailableSpots / @apt.TotalSpots</strong> spots</div></div>
                        <div class="info-item"><div class="ii-icon"><i class="bi bi-gender-ambiguous"></i></div><div><strong>@genderLabel</strong></div></div>
                        <div class="info-item"><div class="ii-icon"><i class="bi bi-wind"></i></div><div>Smoking: <strong>@smokingLabel</strong></div></div>
                        <div class="info-item"><div class="ii-icon"><i class="bi bi-people"></i></div><div>Guests: <strong>@guestsLabel</strong></div></div>
                        <div class="info-item"><div class="ii-icon"><i class="bi bi-mortarboard"></i></div><div>Near: <strong>@apt.NearestUniversity</strong></div></div>
                        @{
                            var distLabel = apt.DistanceRange switch { Dorm.Domain.Enums.DistanceRange.NearCampus => "Near Campus", Dorm.Domain.Enums.DistanceRange.MediumDistance => "Medium Distance", _ => "Far from Campus" };
                        }
                        <div class="info-item"><div class="ii-icon"><i class="bi bi-signpost-2"></i></div><div><strong>@distLabel</strong></div></div>
                    </div>
                </div>

                <div class="detail-card">
                    <h5>Amenities</h5>
                    <div class="d-flex flex-wrap gap-2">
                        @if (apt.Amenities.Count == 0)
                        {
                            <span style="color:#94a3b8;font-size:.88rem">None listed</span>
                        }
                        else
                        {
                            @foreach (var a in apt.Amenities)
                            {
                                <span class="amenity-badge"><i class="bi @(amenityIcons.GetValueOrDefault(a, "bi-check"))"></i> @(amenityLabels.GetValueOrDefault(a, a.ToString()))</span>
                            }
                        }
                    </div>
                </div>

                <div class="detail-card">
                    <h5>Current Tenants</h5>
                    @if (apt.CurrentTenants.Count == 0)
                    {
                        <p style="color:#94a3b8;font-size:.88rem">No tenants yet — be the first!</p>
                    }
                    else
                    {
                        @foreach (var tn in apt.CurrentTenants)
                        {
                            var init = !string.IsNullOrEmpty(tn.FirstName) ? tn.FirstName[0].ToString().ToUpper() : "U";
                            <div class="tenant-row">
                                <div class="tenant-avatar">@init</div>
                                <div>
                                    <div class="tenant-name">@tn.FirstName</div>
                                    <div class="tenant-info">@tn.Major @(tn.Year > 0 ? $" · Year {tn.Year}" : "")</div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="detail-card">
                    <h5>Location</h5>
                    <p style="color:#94a3b8;font-size:.8rem;margin-bottom:.75rem">Approximate location shown for privacy.</p>
                    <div id="apt-map" style="height:240px"></div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="price-card">
                    <div class="price">@apt.FullRent <span>JOD / month</span></div>
                    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
                        <span class="gender-tag"><i class="bi bi-person"></i> @genderLabel</span>
                        @if (isAuth && role == "Student")
                        {
                            <form method="post" asp-action="ToggleSave" asp-controller="Apartment" asp-route-id="@apt.Id" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-save-detail @(isSaved ? "saved" : "")">
                                    <i class="bi @(isSaved ? "bi-heart-fill" : "bi-heart")"></i> @(isSaved ? "Saved" : "Save")
                                </button>
                            </form>
                        }
                    </div>

                    @if (compat != null && compat.Score > 0)
                    {
                        var cls = compat.Score >= 75 ? "compat-high" : compat.Score >= 50 ? "compat-mid" : "compat-low";
                        var qNames = new Dictionary<Dorm.Domain.Enums.QuizQuestionKey, string> {
                            { Dorm.Domain.Enums.QuizQuestionKey.SleepSchedule, "Sleep" },
                            { Dorm.Domain.Enums.QuizQuestionKey.Cleanliness, "Cleanliness" },
                            { Dorm.Domain.Enums.QuizQuestionKey.Smoking, "Smoking" },
                            { Dorm.Domain.Enums.QuizQuestionKey.StudyHabits, "Study" },
                            { Dorm.Domain.Enums.QuizQuestionKey.SocialStyle, "Social" },
                            { Dorm.Domain.Enums.QuizQuestionKey.Guests, "Guests" },
                            { Dorm.Domain.Enums.QuizQuestionKey.Cooking, "Cooking" },
                            { Dorm.Domain.Enums.QuizQuestionKey.PetTolerance, "Pets" },
                        };
                        var qIcons = new Dictionary<Dorm.Domain.Enums.QuizQuestionKey, string> {
                            { Dorm.Domain.Enums.QuizQuestionKey.SleepSchedule, "bi-moon-stars" },
                            { Dorm.Domain.Enums.QuizQuestionKey.Cleanliness, "bi-sparkle" },
                            { Dorm.Domain.Enums.QuizQuestionKey.Smoking, "bi-wind" },
                            { Dorm.Domain.Enums.QuizQuestionKey.StudyHabits, "bi-book" },
                            { Dorm.Domain.Enums.QuizQuestionKey.SocialStyle, "bi-people" },
                            { Dorm.Domain.Enums.QuizQuestionKey.Guests, "bi-person-plus" },
                            { Dorm.Domain.Enums.QuizQuestionKey.Cooking, "bi-cup-hot" },
                            { Dorm.Domain.Enums.QuizQuestionKey.PetTolerance, "bi-emoji-smile" },
                        };
                        <div class="text-center mb-3">
                            <div class="compat-ring @cls">@(compat.Score)%</div>
                            <p style="font-size:.82rem;color:#64748b;margin:0">
                                @if (compat.TenantsCount == 0)
                                {
                                    <text>No tenants yet — you'd be the first!</text>
                                }
                                else
                                {
                                    <text>Compatibility with @compat.TenantsCount tenant@(compat.TenantsCount > 1 ? "s" : "")</text>
                                }
                            </p>
                        </div>
                        @if (compat.MatchedOn.Count > 0 || compat.DifferedOn.Count > 0)
                        {
                            <div class="compat-breakdown mb-3">
                                @if (compat.MatchedOn.Count > 0)
                                {
                                    <div class="compat-label"><i class="bi bi-check-circle me-1" style="color:#10b981"></i> You match on</div>
                                    <div class="mb-2">
                                        @foreach (var q in compat.MatchedOn)
                                        {
                                            <span class="compat-pill compat-pill-match"><i class="bi @(qIcons.GetValueOrDefault(q, "bi-check"))"></i> @(qNames.GetValueOrDefault(q, q.ToString()))</span>
                                        }
                                    </div>
                                }
                                @if (compat.DifferedOn.Count > 0)
                                {
                                    <div class="compat-label"><i class="bi bi-x-circle me-1" style="color:#ef4444"></i> You differ on</div>
                                    <div>
                                        @foreach (var q in compat.DifferedOn)
                                        {
                                            <span class="compat-pill compat-pill-diff"><i class="bi @(qIcons.GetValueOrDefault(q, "bi-x"))"></i> @(qNames.GetValueOrDefault(q, q.ToString()))</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }

                    @if (!isAuth)
                    {
                        <a href="/Identity/Account/Login" class="btn-apply d-block text-center text-decoration-none"><i class="bi bi-box-arrow-in-right me-1"></i> Log in to Apply</a>
                    }
                    else if (role == "Student")
                    {
                        <form method="post" asp-action="Apply" asp-controller="Apartment" asp-route-id="@apt.Id">
                            @Html.AntiForgeryToken()
                            <textarea class="form-control mb-2" name="message" rows="3" placeholder="Write a short message to the owner (20–500 chars)..." style="border-radius:10px;font-size:.88rem;resize:none" required minlength="20" maxlength="500"></textarea>
                            <button type="submit" class="btn-apply"><i class="bi bi-send me-1"></i> Apply Now</button>
                        </form>
                    }
                    else if (role == "Owner")
                    {
                        <p class="text-center" style="font-size:.85rem;color:#94a3b8;margin:0">Owners cannot apply to apartments.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
function switchPhoto(thumb, url) {
    document.getElementById('gallery-main').src = url
    document.querySelectorAll('.gallery-thumb').forEach(function(t) { t.classList.remove('active') })
    thumb.classList.add('active')
}

var lat = @(apt.Latitude != 0 ? apt.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")
var lng = @(apt.Longitude != 0 ? apt.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")
if (lat && lng) {
    var map = L.map('apt-map').setView([lat, lng], 14)
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OSM' }).addTo(map)
    L.marker([lat, lng]).addTo(map)
}
</script>
}
