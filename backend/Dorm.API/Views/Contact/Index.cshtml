@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "Contact Us";
    var isAuth = User.Identity?.IsAuthenticated == true;
    var userName = isAuth ? User.FindFirstValue("FullName") ?? "" : "";
    var userEmail = isAuth ? User.FindFirstValue(ClaimTypes.Email) ?? "" : "";
}

@section Styles {
<style>
    .contact-hero {
        background: #0f172a; padding: 5rem 0 3rem; color: #fff;
    }
    .contact-hero h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -.02em; }
    .contact-hero p { color: #64748b; font-size: 1.05rem; }

    .contact-body { padding: 3rem 0 4rem; }

    .contact-card {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 2rem;
    }

    .contact-info-item {
        display: flex; align-items: flex-start; gap: .85rem; margin-bottom: 1.5rem;
    }
    .contact-info-icon {
        width: 44px; height: 44px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; flex-shrink: 0;
    }
    .contact-info-item h6 { font-weight: 700; font-size: .9rem; color: #1e293b; margin-bottom: .15rem; }
    .contact-info-item p { font-size: .85rem; color: #64748b; margin: 0; }
    .contact-info-item a { color: #F97316; text-decoration: none; font-weight: 500; }
    .contact-info-item a:hover { text-decoration: underline; }

    .contact-form label {
        font-size: .82rem; font-weight: 600; color: #475569; margin-bottom: .3rem;
    }
    .contact-form .form-control, .contact-form .form-select {
        padding: .65rem .9rem; border-radius: 8px; font-size: .9rem;
    }
    .btn-send-msg {
        background: #0f172a; color: #fff; border: none; border-radius: 8px;
        padding: .65rem 1.5rem; font-weight: 600; font-size: .88rem;
        display: inline-flex; align-items: center; gap: .4rem;
        transition: all .2s;
    }
    .btn-send-msg:hover { background: #1e293b; }
</style>
}

<div class="contact-hero">
    <div class="container">
        <h1>Contact Us</h1>
        <p>Have a question, feedback, or need help? We'd love to hear from you.</p>
    </div>
</div>

<div class="contact-body">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="contact-card h-100">
                    <h4 style="font-weight:700;font-size:1.1rem;color:#1e293b;margin-bottom:1.5rem">Get in Touch</h4>

                    <div class="contact-info-item">
                        <div class="contact-info-icon" style="background:rgba(249,115,22,.1);color:#F97316"><i class="bi bi-envelope-fill"></i></div>
                        <div>
                            <h6>Email</h6>
                            <p><a href="mailto:support@dorm.jo">support@dorm.jo</a></p>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon" style="background:rgba(59,130,246,.1);color:#3b82f6"><i class="bi bi-telephone-fill"></i></div>
                        <div>
                            <h6>Phone</h6>
                            <p>+962 6 000 0000</p>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon" style="background:rgba(16,185,129,.1);color:#10b981"><i class="bi bi-geo-alt-fill"></i></div>
                        <div>
                            <h6>Location</h6>
                            <p>Amman, Jordan</p>
                        </div>
                    </div>

                    <div class="contact-info-item">
                        <div class="contact-info-icon" style="background:rgba(139,92,246,.1);color:#8b5cf6"><i class="bi bi-clock-fill"></i></div>
                        <div>
                            <h6>Working Hours</h6>
                            <p>Sunday – Thursday, 9 AM – 5 PM</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="contact-card">
                    <h4 style="font-weight:700;font-size:1.1rem;color:#1e293b;margin-bottom:1.25rem">Send a Message</h4>

                    @if (TempData["Success"] is string)
                    {
                        <div class="alert alert-success" style="border-radius:8px;font-size:.88rem">
                            <i class="bi bi-check-circle-fill me-1"></i> Your message has been sent to our team. We'll get back to you soon!
                        </div>
                    }
                    @if (TempData["Error"] is string err)
                    {
                        <div class="alert alert-danger" style="border-radius:8px;font-size:.88rem">@err</div>
                    }

                    <form class="contact-form" method="post" asp-action="Send" asp-controller="Contact">
                        @Html.AntiForgeryToken()
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Your Name</label>
                                <input type="text" class="form-control" name="name" placeholder="Full name" required value="@userName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="email" placeholder="you@example.com" required value="@userEmail" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <select class="form-select" name="subject">
                                <option value="General Inquiry">General Inquiry</option>
                                <option value="Technical Support">Technical Support</option>
                                <option value="Feedback">Feedback</option>
                                <option value="Report an Issue">Report an Issue</option>
                                <option value="Partnership">Partnership</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" name="message" rows="5" placeholder="How can we help?" required style="resize:none"></textarea>
                        </div>
                        <button type="submit" class="btn-send-msg">
                            <i class="bi bi-send"></i> Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

