@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Applications Received";
    var apps = (IReadOnlyList<Dorm.Application.DTOs.Applications.ApplicationReceivedDto>)(ViewBag.Applications ?? Array.Empty<Dorm.Application.DTOs.Applications.ApplicationReceivedDto>());
}

@section Styles {
<style>
    .oa-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: .15rem; }
    .oa-header p { color: #64748b; font-size: .9rem; }
    .oa-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }
    .applicant-avatar {
        width: 36px; height: 36px; border-radius: 50%; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .75rem; color: #64748b; flex-shrink: 0;
    }
    .match-ring {
        width: 38px; height: 38px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: .7rem; font-weight: 800;
    }
    .match-ring.high { border: 2.5px solid #10b981; color: #10b981; background: rgba(16,185,129,.06); }
    .match-ring.mid  { border: 2.5px solid #eab308; color: #eab308; background: rgba(234,179,8,.06); }
    .match-ring.low  { border: 2.5px solid #94a3b8; color: #94a3b8; background: rgba(148,163,184,.06); }
    .btn-accept {
        background: #10b981; color: #fff; border: none; border-radius: 6px;
        padding: .3rem .7rem; font-size: .78rem; font-weight: 600;
    }
    .btn-accept:hover { background: #059669; color: #fff; }
    .btn-reject {
        background: #fff; color: #ef4444; border: 1px solid #fecaca; border-radius: 6px;
        padding: .3rem .7rem; font-size: .78rem; font-weight: 600;
    }
    .btn-reject:hover { background: #fef2f2; border-color: #ef4444; }
    .compat-pill { display: inline-flex; align-items: center; gap: .2rem; padding: .15rem .45rem; border-radius: 5px; font-size: .68rem; font-weight: 600; margin: .1rem .05rem; }
    .compat-pill-match { background: rgba(16,185,129,.08); color: #10b981; }
    .compat-pill-diff { background: rgba(239,68,68,.08); color: #ef4444; }
    .empty-oa { text-align: center; padding: 3.5rem 1rem; }
    .empty-oa i { font-size: 2.5rem; color: #cbd5e1; }
    .empty-oa h5 { font-weight: 700; color: #1e293b; margin-top: .75rem; }
    .empty-oa p { color: #94a3b8; font-size: .88rem; }
</style>
}

<div class="oa-header mb-4">
    <h3>Applications Received</h3>
    <p>Review applicants and accept the best fit for each spot.</p>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success" style="border-radius:8px">@success</div>
}

<div class="oa-card">
    @if (apps.Count == 0)
    {
        <div class="empty-oa"><i class="bi bi-people"></i><h5>No applications</h5><p>No applications to show.</p></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8">
                        <th>Applicant</th><th>Apartment</th><th class="text-center">Match</th><th class="text-center">Status</th><th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var app in apps)
                {
                    var statusText = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "Pending", Dorm.Domain.Enums.ApplicationStatus.Accepted => "Accepted", Dorm.Domain.Enums.ApplicationStatus.Rejected => "Rejected", _ => "Pending" };
                    var statusColor = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "warning", Dorm.Domain.Enums.ApplicationStatus.Accepted => "success", Dorm.Domain.Enums.ApplicationStatus.Rejected => "danger", _ => "secondary" };
                    var statusIcon = app.Status switch { Dorm.Domain.Enums.ApplicationStatus.Pending => "bi-clock", Dorm.Domain.Enums.ApplicationStatus.Accepted => "bi-check-circle-fill", Dorm.Domain.Enums.ApplicationStatus.Rejected => "bi-x-circle-fill", _ => "bi-clock" };
                    var init = string.Join("", (app.StudentFullName ?? "U").Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : "")).ToUpper();
                    if (init.Length > 2) init = init.Substring(0, 2);
                    var matchCls = app.CompatibilityScore >= 75 ? "high" : app.CompatibilityScore >= 50 ? "mid" : "low";
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="applicant-avatar">@init</div>
                                <div>
                                    <span class="fw-semibold" style="font-size:.88rem">@app.StudentFullName</span>
                                    @if (!string.IsNullOrEmpty(app.Message))
                                    {
                                        <br /><span style="color:#94a3b8;font-size:.75rem;font-style:italic">"@(app.Message.Length > 40 ? app.Message.Substring(0, 40) + "..." : app.Message)"</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td style="color:#94a3b8;font-size:.82rem">@app.ApartmentTitle</td>
                        <td class="text-center">
                            @if (app.CompatibilityScore > 0)
                            {
                                <div class="match-ring @matchCls">@(app.CompatibilityScore)%</div>
                                @if (app.MatchedOn?.Count > 0 || app.DifferedOn?.Count > 0)
                                {
                                    var qn = new Dictionary<Dorm.Domain.Enums.QuizQuestionKey, string> {
                                        {Dorm.Domain.Enums.QuizQuestionKey.SleepSchedule,"Sleep"},{Dorm.Domain.Enums.QuizQuestionKey.Cleanliness,"Clean"},
                                        {Dorm.Domain.Enums.QuizQuestionKey.Smoking,"Smoke"},{Dorm.Domain.Enums.QuizQuestionKey.StudyHabits,"Study"},
                                        {Dorm.Domain.Enums.QuizQuestionKey.SocialStyle,"Social"},{Dorm.Domain.Enums.QuizQuestionKey.Guests,"Guests"},
                                        {Dorm.Domain.Enums.QuizQuestionKey.Cooking,"Cook"},{Dorm.Domain.Enums.QuizQuestionKey.PetTolerance,"Pets"},
                                    };
                                    <div style="margin-top:.25rem">
                                        @if (app.MatchedOn != null) { foreach (var q in app.MatchedOn) { <span class="compat-pill compat-pill-match"><i class="bi bi-check"></i>@(qn.GetValueOrDefault(q, q.ToString()))</span> } }
                                        @if (app.DifferedOn != null) { foreach (var q in app.DifferedOn) { <span class="compat-pill compat-pill-diff"><i class="bi bi-x"></i>@(qn.GetValueOrDefault(q, q.ToString()))</span> } }
                                    </div>
                                }
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge bg-@statusColor bg-opacity-10 text-@statusColor" style="font-size:.72rem"><i class="bi @statusIcon me-1"></i>@statusText</span>
                        </td>
                        <td class="text-end">
                            @if (app.Status == Dorm.Domain.Enums.ApplicationStatus.Pending)
                            {
                                <div class="d-flex gap-1 justify-content-end">
                                    <form method="post" asp-action="Accept" asp-controller="OwnerApps" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@app.Id" />
                                        <button type="submit" class="btn-accept"><i class="bi bi-check-lg me-1"></i>Accept</button>
                                    </form>
                                    <form method="post" asp-action="Reject" asp-controller="OwnerApps" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@app.Id" />
                                        <button type="submit" class="btn-reject"><i class="bi bi-x-lg me-1"></i>Reject</button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
