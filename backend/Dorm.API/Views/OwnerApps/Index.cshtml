@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Applications Received";
}

@section Styles {
<style>
    .oa-header h3 { font-size: 1.4rem; font-weight: 800; color: #1e293b; margin-bottom: .15rem; }
    .oa-header p { color: #64748b; font-size: .9rem; }

    .oa-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; overflow: hidden; }
    .oa-toolbar { padding: 1rem 1.25rem; border-bottom: 1px solid #f8fafc; display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; }
    .oa-tab {
        padding: .35rem .8rem; border-radius: 6px; font-size: .78rem; font-weight: 600;
        border: 1px solid #e2e8f0; background: #fff; color: #64748b;
        cursor: pointer; transition: all .15s;
    }
    .oa-tab:hover { border-color: #cbd5e1; color: #1e293b; }
    .oa-tab.active { background: #0f172a; color: #fff; border-color: #0f172a; }
    .oa-count { font-size: .78rem; color: #94a3b8; font-weight: 500; margin-left: auto; }

    .applicant-avatar {
        width: 36px; height: 36px; border-radius: 50%; background: #f1f5f9;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .75rem; color: #64748b; flex-shrink: 0;
    }
    .match-ring {
        width: 38px; height: 38px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: .7rem; font-weight: 800;
    }
    .match-ring.high { border: 2.5px solid #10b981; color: #10b981; background: rgba(16,185,129,.06); }
    .match-ring.mid  { border: 2.5px solid #eab308; color: #eab308; background: rgba(234,179,8,.06); }
    .match-ring.low  { border: 2.5px solid #94a3b8; color: #94a3b8; background: rgba(148,163,184,.06); }

    .btn-accept {
        background: #10b981; color: #fff; border: none; border-radius: 6px;
        padding: .3rem .7rem; font-size: .78rem; font-weight: 600; transition: all .15s;
    }
    .btn-accept:hover { background: #059669; color: #fff; }
    .btn-reject {
        background: #fff; color: #ef4444; border: 1px solid #fecaca; border-radius: 6px;
        padding: .3rem .7rem; font-size: .78rem; font-weight: 600; transition: all .15s;
    }
    .btn-reject:hover { background: #fef2f2; border-color: #ef4444; }

    .empty-oa { text-align: center; padding: 3.5rem 1rem; }
    .empty-oa i { font-size: 2.5rem; color: #cbd5e1; }
    .empty-oa h5 { font-weight: 700; color: #1e293b; margin-top: .75rem; }
    .empty-oa p { color: #94a3b8; font-size: .88rem; }
</style>
}

<div class="oa-header mb-4">
    <h3>Applications Received</h3>
    <p>Review applicants and accept the best fit for each spot.</p>
</div>
<div>
    <div class="oa-card">
        <div class="oa-toolbar" id="oa-filters">
            <button class="oa-tab active" onclick="filterApps('all',this)">All</button>
            <button class="oa-tab" onclick="filterApps('pending',this)">Pending</button>
            <button class="oa-tab" onclick="filterApps('accepted',this)">Accepted</button>
            <button class="oa-tab" onclick="filterApps('rejected',this)">Rejected</button>
            <span class="oa-count" id="app-count"></span>
        </div>
        <div id="oa-list">
            <div class="text-center py-5"><div class="spinner-border" style="color:#94a3b8"></div></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var allApps = []
var currentFilter = 'all'

auth.initAuth().then(loadOwnerApps)

async function loadOwnerApps() {
    try {
        allApps = await api.get('/applications/received')
        allApps = allApps || []
        renderApps()
    } catch (e) {
        document.getElementById('oa-list').innerHTML = '<div class="text-center py-5"><p style="color:#ef4444">Failed to load applications.</p></div>'
    }
}

function filterApps(f, btn) {
    currentFilter = f
    document.querySelectorAll('#oa-filters .oa-tab').forEach(function (b) { b.classList.remove('active') })
    btn.classList.add('active')
    renderApps()
}

function renderApps() {
    var statusMap = { 0: 'pending', 1: 'accepted', 2: 'rejected' }
    var items = currentFilter === 'all' ? allApps : allApps.filter(function (a) { return statusMap[a.status] === currentFilter })
    var container = document.getElementById('oa-list')
    document.getElementById('app-count').textContent = items.length + ' ' + currentFilter

    if (items.length === 0) {
        container.innerHTML = '<div class="empty-oa"><i class="bi bi-people"></i><h5>No applications</h5><p>No ' + currentFilter + ' applications to show.</p></div>'
        return
    }

    var SK = { 0:'Pending', 1:'Accepted', 2:'Rejected' }
    var SC = { 0:'warning', 1:'success', 2:'danger' }
    var SI = { 0:'bi-clock', 1:'bi-check-circle-fill', 2:'bi-x-circle-fill' }

    container.innerHTML = '<div class="table-responsive"><table class="table table-hover align-middle mb-0">' +
        '<thead><tr style="font-size:.75rem;text-transform:uppercase;letter-spacing:.04em;color:#94a3b8">' +
        '<th>Applicant</th><th>Apartment</th><th class="text-center">Match</th><th class="text-center">Status</th><th class="text-end">Actions</th>' +
        '</tr></thead><tbody>' +
        items.map(function (app) {
            var init = (app.studentFullName || 'U').split(' ').map(function(n){return n[0]}).join('').substring(0,2).toUpperCase()
            var matchHtml = '—'
            if (app.compatibilityScore != null) {
                var cls = app.compatibilityScore >= 75 ? 'high' : app.compatibilityScore >= 50 ? 'mid' : 'low'
                matchHtml = '<div class="match-ring ' + cls + '">' + app.compatibilityScore + '%</div>'
            }
            return '<tr><td><div class="d-flex align-items-center gap-2">' +
                '<div class="applicant-avatar">' + init + '</div>' +
                '<div><span class="fw-semibold" style="font-size:.88rem">' + escapeHtml(app.studentFullName || '') + '</span>' +
                (app.message ? '<br/><span style="color:#94a3b8;font-size:.75rem;font-style:italic">"' + escapeHtml(app.message.substring(0,40)) + (app.message.length>40?'…':'') + '"</span>' : '') +
                '</div></div></td>' +
                '<td style="color:#94a3b8;font-size:.82rem">' + escapeHtml(app.apartmentTitle || '') + '</td>' +
                '<td class="text-center">' + matchHtml + '</td>' +
                '<td class="text-center"><span class="badge bg-' + (SC[app.status]||'secondary') + ' bg-opacity-10 text-' + (SC[app.status]||'secondary') + '" style="font-size:.72rem"><i class="bi ' + (SI[app.status]||'bi-clock') + ' me-1"></i>' + (SK[app.status]||'Pending') + '</span></td>' +
                '<td class="text-end">' +
                (app.status === 0
                    ? '<div class="d-flex gap-1 justify-content-end">' +
                      '<button class="btn-accept" onclick="acceptApp(\'' + app.id + '\',this)"><i class="bi bi-check-lg me-1"></i>Accept</button>' +
                      '<button class="btn-reject" onclick="rejectApp(\'' + app.id + '\',this)"><i class="bi bi-x-lg me-1"></i>Reject</button></div>'
                    : '') +
                '</td></tr>'
        }).join('') +
        '</tbody></table></div>'
}

async function acceptApp(id, btn) {
    btn.disabled = true
    try { await api.put('/applications/' + id + '/accept'); loadOwnerApps() } catch (e) { btn.disabled = false }
}
async function rejectApp(id, btn) {
    btn.disabled = true
    try { await api.put('/applications/' + id + '/reject'); loadOwnerApps() } catch (e) { btn.disabled = false }
}
</script>
}
