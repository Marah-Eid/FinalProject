@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "Write a Review";
    var alreadySubmitted = (bool)(ViewBag.AlreadySubmitted ?? false);
    var isApproved = (bool)(ViewBag.IsApproved ?? false);
}

@section Styles {
<style>
    .review-page { max-width: 520px; margin: 0 auto; padding: 3rem 1rem 4rem; }
    .review-page h1 { font-size: 1.5rem; font-weight: 800; color: #1e293b; margin-bottom: .25rem; }
    .review-page .sub { color: #64748b; font-size: .9rem; margin-bottom: 2rem; }

    .review-card {
        background: #fff; border-radius: 14px; border: 1px solid #e2e8f0;
        padding: 1.5rem; position: relative;
    }

    .star-row { display: flex; gap: .3rem; font-size: 1.6rem; cursor: pointer; margin-bottom: 1rem; }
    .star-row i { color: #e2e8f0; transition: color .15s; }
    .star-row i.active { color: #F97316; }
    .star-row i:hover { color: #F97316; }

    .review-textarea {
        width: 100%; border: 1px solid #e2e8f0; border-radius: 8px;
        padding: .7rem .9rem; font-size: .9rem; resize: none;
        font-family: 'Inter', sans-serif; min-height: 120px;
    }
    .review-textarea:focus { outline: none; border-color: #F97316; box-shadow: 0 0 0 .15rem rgba(249,115,22,.12); }

    .char-count { text-align: right; font-size: .72rem; color: #94a3b8; margin-top: .25rem; }

    .btn-submit-review {
        background: #0f172a; color: #fff; border: none; border-radius: 8px;
        padding: .65rem 1.5rem; font-weight: 600; font-size: .88rem;
        display: inline-flex; align-items: center; gap: .4rem;
        transition: background .2s; cursor: pointer; margin-top: 1rem;
    }
    .btn-submit-review:hover { background: #1e293b; }

    .review-success {
        text-align: center; padding: 2rem 1rem;
    }
    .review-success i { font-size: 2rem; color: #10b981; }
    .review-success h3 { font-weight: 700; font-size: 1.1rem; color: #1e293b; margin: .6rem 0 .25rem; }
    .review-success p { color: #64748b; font-size: .88rem; margin: 0; }
</style>
}

<div class="review-page">
    <h1>Write a Review</h1>
    <p class="sub">Share your experience with Dorm. Your review will appear on the homepage after approval.</p>

    @if (TempData["Success"] is string success || alreadySubmitted)
    {
        <div class="review-card">
            <div class="review-success">
                <i class="bi bi-check-circle-fill"></i>
                <h3>@(TempData["Success"] is string ? "Thank you!" : "Review submitted")</h3>
                <p>
                    @if (TempData["Success"] is string s) { @s }
                    else if (isApproved) { <text>Your review is live on the homepage.</text> }
                    else { <text>Your review is awaiting admin approval before it appears on the homepage.</text> }
                </p>
                <a href="/" style="display:inline-block;margin-top:1rem;color:#F97316;font-weight:600;text-decoration:none;font-size:.88rem">
                    <i class="bi bi-arrow-left"></i> Back to Home
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="review-card">
            @if (ViewData["Error"] is string error)
            {
                <div class="alert alert-danger" style="border-radius:8px;font-size:.85rem">@error</div>
            }

            <form method="post" asp-action="Submit" asp-controller="WriteReview" id="review-form">
                @Html.AntiForgeryToken()

                <label style="font-size:.82rem;font-weight:600;color:#475569;display:block;margin-bottom:.35rem">Rating <span class="text-danger">*</span></label>
                <div class="star-row" id="review-stars">
                    <i class="bi bi-star" data-star="1"></i>
                    <i class="bi bi-star" data-star="2"></i>
                    <i class="bi bi-star" data-star="3"></i>
                    <i class="bi bi-star" data-star="4"></i>
                    <i class="bi bi-star" data-star="5"></i>
                </div>
                <div id="star-error" style="color:#ef4444;font-size:.78rem;margin-bottom:.5rem;display:none">Please select a star rating.</div>
                <input type="hidden" name="stars" id="stars-input" value="0" />

                <label style="font-size:.82rem;font-weight:600;color:#475569;display:block;margin-bottom:.35rem">Your review <span class="text-danger">*</span></label>
                <textarea class="review-textarea" name="text" id="review-text" placeholder="How has Dorm helped you? (10-500 characters)" required minlength="10" maxlength="500"></textarea>
                <div class="char-count" id="review-chars">0 / 500</div>

                <button type="submit" class="btn-submit-review">
                    <i class="bi bi-send"></i> Submit Review
                </button>
            </form>
        </div>
    }
</div>

@section Scripts {
<script>
var reviewStars = 0;
document.querySelectorAll('#review-stars i').forEach(function (star) {
    star.addEventListener('click', function () {
        reviewStars = parseInt(this.getAttribute('data-star'));
        document.getElementById('stars-input').value = reviewStars;
        document.getElementById('star-error').style.display = 'none';
        document.querySelectorAll('#review-stars i').forEach(function (s) {
            var v = parseInt(s.getAttribute('data-star'));
            s.className = v <= reviewStars ? 'bi bi-star-fill active' : 'bi bi-star';
        });
    });
});
var textEl = document.getElementById('review-text');
if (textEl) {
    textEl.addEventListener('input', function () {
        document.getElementById('review-chars').textContent = this.value.length + ' / 500';
    });
}
var form = document.getElementById('review-form');
if (form) {
    form.addEventListener('submit', function (e) {
        if (reviewStars === 0) {
            e.preventDefault();
            document.getElementById('star-error').style.display = 'block';
            document.getElementById('review-stars').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });
}
</script>
}
