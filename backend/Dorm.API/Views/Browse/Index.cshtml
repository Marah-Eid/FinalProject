@using Dorm.Domain.Enums
@using Dorm.Application.DTOs.Apartments
@{
    Layout = "_BrowseLayout";
    ViewData["Title"] = "Browse";
    var result = (Dorm.Application.Common.PaginatedResult<ApartmentListItemDto>)ViewBag.Apartments;
    var query = (ApartmentListQuery)ViewBag.Query;
    var savedIds = (List<Guid>?)ViewBag.SavedIds ?? new List<Guid>();
    var isAuth = User.Identity?.IsAuthenticated == true;
    var role = User.FindFirstValue(ClaimTypes.Role) ?? "";
}

@section Styles {
<style>
    .browse-hero {
        background: #0f172a; padding: 6rem 0 3rem; color: #fff;
    }
    .browse-hero h1 { font-size: 2rem; font-weight: 800; letter-spacing: -.02em; }
    .browse-hero p { color: #64748b; font-size: 1rem; }

    .browse-body { background: #f8fafc; padding: 2rem 0 4rem; }

    .filter-panel {
        background: #fff; border-radius: 14px; padding: 1.5rem;
        border: 1px solid #e2e8f0; position: sticky; top: 100px;
    }
    .filter-panel h5 { font-size: .95rem; font-weight: 700; color: #1e293b; }
    .filter-panel label { font-size: .8rem; font-weight: 600; color: #475569; }
    .filter-panel .form-control,
    .filter-panel .form-select {
        font-size: .85rem; border-color: #e2e8f0; border-radius: 8px;
    }
    .filter-panel .form-control:focus,
    .filter-panel .form-select:focus {
        border-color: #F97316; box-shadow: 0 0 0 3px rgba(249,115,22,.1);
    }
    .filter-panel .form-check-input:checked { background-color: #F97316; border-color: #F97316; }
    .btn-filter {
        background: #0f172a; color: #fff; border: none; border-radius: 8px;
        font-weight: 600; font-size: .85rem; padding: .55rem 1rem;
        transition: all .2s;
    }
    .btn-filter:hover { background: #1e293b; color: #fff; }

    .sort-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
    .sort-bar .results-text { font-size: .85rem; color: #64748b; font-weight: 500; }
    .sort-bar .form-select { width: auto; font-size: .82rem; border-radius: 8px; border-color: #e2e8f0; }

    .apt-card {
        background: #fff; border-radius: 14px; overflow: hidden;
        border: 1px solid #e2e8f0;
        transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s;
        height: 100%; display: flex; flex-direction: column;
    }
    .apt-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0,0,0,.08);
        border-color: transparent;
    }
    .apt-card-img { width: 100%; height: 180px; object-fit: cover; display: block; }
    .apt-card-body { padding: 1rem 1.1rem; flex: 1; display: flex; flex-direction: column; }
    .apt-card-title {
        font-size: .95rem; font-weight: 700; color: #1e293b; margin-bottom: .25rem;
        text-decoration: none;
    }
    .apt-card-title:hover { color: #F97316; }
    .apt-card-loc {
        font-size: .78rem; color: #94a3b8; display: flex; align-items: center; gap: .25rem;
        margin-bottom: .6rem;
    }
    .apt-card-pills { display: flex; flex-wrap: wrap; gap: .35rem; margin-bottom: .75rem; }
    .apt-pill {
        font-size: .68rem; font-weight: 600; padding: .2rem .5rem; border-radius: 5px;
        background: #f1f5f9; color: #64748b;
    }
    .apt-card-footer {
        display: flex; justify-content: space-between; align-items: center;
        border-top: 1px solid #f1f5f9; padding-top: .75rem; margin-top: auto;
    }
    .apt-price { font-size: 1.05rem; font-weight: 800; color: #1e293b; }
    .apt-price span { font-size: .72rem; font-weight: 400; color: #94a3b8; }
    .apt-match {
        width: 42px; height: 42px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: .68rem; font-weight: 800;
    }
    .match-high { border: 2.5px solid #10b981; color: #10b981; background: rgba(16,185,129,.06); }
    .match-mid  { border: 2.5px solid #eab308; color: #eab308; background: rgba(234,179,8,.06); }
    .match-low  { border: 2.5px solid #94a3b8; color: #94a3b8; background: rgba(148,163,184,.06); }

    .pagination .page-link { border-radius: 8px; font-size: .85rem; font-weight: 500; border: 1px solid #e2e8f0; color: #475569; margin: 0 2px; }
    .pagination .page-item.active .page-link { background: #0f172a; border-color: #0f172a; color: #fff; }

    .empty-state { text-align: center; padding: 4rem 1rem; }
    .empty-state i { font-size: 3rem; color: #cbd5e1; }
    .empty-state h5 { font-weight: 700; color: #1e293b; margin-top: 1rem; }
    .empty-state p { color: #94a3b8; }

    .apt-card-img-wrap { position: relative; }
    .btn-heart {
        position: absolute; top: .6rem; right: .6rem;
        width: 34px; height: 34px; border-radius: 50%;
        background: rgba(255,255,255,.85); border: none;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; color: #cbd5e1; cursor: pointer;
        transition: all .2s; backdrop-filter: blur(4px); z-index: 2;
    }
    .btn-heart:hover { background: #fff; transform: scale(1.1); }
    .btn-heart.saved { color: #ef4444; }
</style>
}

<div class="browse-hero">
    <div class="container">
        <h1>Browse Apartments</h1>
        <p>Find your next home near campus. Filter by university, price, and more.</p>
    </div>
</div>

<div class="browse-body">
    <div class="container">
        <div class="row">
            <div class="col-lg-3 mb-4">
                <form class="filter-panel" method="get" asp-action="Index" asp-controller="Browse">
                    <h5 class="mb-3"><i class="bi bi-sliders2 me-2"></i>Filters</h5>
                    <div class="mb-3">
                        <label class="form-label">City</label>
                        <select class="form-select" name="city">
                            <option value="">Any</option>
                            @foreach (var c in Enum.GetValues<City>())
                            {
                                if (query.City == c) { <option value="@((int)c)" selected>@c</option> }
                                else { <option value="@((int)c)">@c</option> }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nearest University</label>
                        <select class="form-select" name="university">
                            <option value="">Any</option>
                            @foreach (var u in Enum.GetValues<University>())
                            {
                                if (query.University == u) { <option value="@((int)u)" selected>@u</option> }
                                else { <option value="@((int)u)">@u</option> }
                            }
                        </select>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label">Min (JOD)</label>
                            <input type="number" class="form-control" name="minPrice" min="0" placeholder="0" value="@query.MinPrice" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Max (JOD)</label>
                            <input type="number" class="form-control" name="maxPrice" min="0" placeholder="Any" value="@query.MaxPrice" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Spots Available</label>
                        <select class="form-select" name="spotsAvailable">
                            <option value="">Any</option>
                            @if (query.SpotsAvailable == 1) { <option value="1" selected>1+</option> } else { <option value="1">1+</option> }
                            @if (query.SpotsAvailable == 2) { <option value="2" selected>2+</option> } else { <option value="2">2+</option> }
                            @if (query.SpotsAvailable == 3) { <option value="3" selected>3+</option> } else { <option value="3">3+</option> }
                        </select>
                    </div>
                    <div class="form-check mb-3">
                        <input type="checkbox" class="form-check-input" name="furnished" value="true" id="f-furnished" @(query.Furnished == true ? "checked" : "") />
                        <label class="form-check-label" for="f-furnished" style="font-size:.85rem">Furnished only</label>
                    </div>
                    <input type="hidden" name="sort" value="@(query.Sort ?? "newest")" id="sort-val" />
                    <button type="submit" class="btn btn-filter w-100">
                        <i class="bi bi-search me-1"></i> Search
                    </button>
                </form>
            </div>

            <div class="col-lg-9">
                <div class="sort-bar">
                    <span class="results-text">@result.Total apartment@(result.Total != 1 ? "s" : "") found</span>
                    <select class="form-select" id="f-sort" onchange="document.getElementById('sort-val').value=this.value;this.closest('.browse-body').querySelector('form').submit()">
                        @if (query.Sort == "newest" || query.Sort == null) { <option value="newest" selected>Newest first</option> } else { <option value="newest">Newest first</option> }
                        @if (query.Sort == "price_asc") { <option value="price_asc" selected>Price: low to high</option> } else { <option value="price_asc">Price: low to high</option> }
                        @if (query.Sort == "price_desc") { <option value="price_desc" selected>Price: high to low</option> } else { <option value="price_desc">Price: high to low</option> }
                    </select>
                </div>

                <div class="row g-3">
                    @if (result.Items.Count == 0)
                    {
                        <div class="col-12">
                            <div class="empty-state">
                                <i class="bi bi-building"></i>
                                <h5>No apartments found</h5>
                                <p>Try adjusting your filters to see more results.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @for (var i = 0; i < result.Items.Count; i++)
                        {
                            var apt = result.Items[i];
                            var photo = apt.MainPhotoUrl ?? $"/property/images/img_{(i % 8) + 1}.jpg";
                            var genderLabel = apt.GenderType switch { GenderType.MaleOnly => "Male Only", GenderType.FemaleOnly => "Female Only", _ => "Mixed" };
                            var isSaved = savedIds.Contains(apt.Id);

                            <div class="col-md-6 col-xl-4">
                                <a href="/Apartment/Detail/@apt.Id" class="text-decoration-none">
                                    <div class="apt-card">
                                        <div class="apt-card-img-wrap">
                                            <img src="@photo" alt="@apt.Title" class="apt-card-img" />
                                            @if (isAuth && role == "Student")
                                            {
                                                <form method="post" asp-action="ToggleSave" asp-controller="Apartment" asp-route-id="@apt.Id" style="position:absolute;top:.6rem;right:.6rem;z-index:2" onclick="event.stopPropagation()">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn-heart @(isSaved ? "saved" : "")">
                                                        <i class="bi @(isSaved ? "bi-heart-fill" : "bi-heart")"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                        <div class="apt-card-body">
                                            <div class="apt-card-title">@apt.Title</div>
                                            <div class="apt-card-loc"><i class="bi bi-geo-alt-fill"></i> @apt.Neighborhood</div>
                                            <div class="apt-card-pills">
                                                <span class="apt-pill">@genderLabel</span>
                                                <span class="apt-pill">@apt.AvailableSpots of @apt.TotalSpots spots</span>
                                                @if (apt.IsFurnished)
                                                {
                                                    <span class="apt-pill">Furnished</span>
                                                }
                                            </div>
                                            <div class="apt-card-footer">
                                                <div class="apt-price">@apt.FullRent <span>JOD/mo</span></div>
                                                @if (apt.CompatibilityScore.HasValue)
                                                {
                                                    var cls = apt.CompatibilityScore >= 75 ? "match-high" : apt.CompatibilityScore >= 50 ? "match-mid" : "match-low";
                                                    <div class="text-center" style="line-height:1">
                                                        <div class="apt-match @cls">@(apt.CompatibilityScore)%</div>
                                                        <span style="font-size:.6rem;color:#94a3b8;font-weight:500">Match</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    }
                </div>

                @if (result.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @if (result.Page > 1)
                            {
                                <li class="page-item"><a class="page-link" href="@Url.Action("Index", "Browse", new { city = query.City, university = query.University, minPrice = query.MinPrice, maxPrice = query.MaxPrice, spotsAvailable = query.SpotsAvailable, furnished = query.Furnished, sort = query.Sort, page = result.Page - 1 })"><i class="bi bi-chevron-left"></i></a></li>
                            }
                            @for (var p = 1; p <= result.TotalPages; p++)
                            {
                                <li class="page-item @(p == result.Page ? "active" : "")"><a class="page-link" href="@Url.Action("Index", "Browse", new { city = query.City, university = query.University, minPrice = query.MinPrice, maxPrice = query.MaxPrice, spotsAvailable = query.SpotsAvailable, furnished = query.Furnished, sort = query.Sort, page = p })">@p</a></li>
                            }
                            @if (result.Page < result.TotalPages)
                            {
                                <li class="page-item"><a class="page-link" href="@Url.Action("Index", "Browse", new { city = query.City, university = query.University, minPrice = query.MinPrice, maxPrice = query.MaxPrice, spotsAvailable = query.SpotsAvailable, furnished = query.Furnished, sort = query.Sort, page = result.Page + 1 })"><i class="bi bi-chevron-right"></i></a></li>
                            }
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>
