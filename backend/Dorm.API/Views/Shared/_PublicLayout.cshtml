@{
    var isAuth = User.Identity?.IsAuthenticated == true;
    var role = User.FindFirstValue(ClaimTypes.Role) ?? "";
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Dorm</title>

    <link rel="shortcut icon" href="~/property/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/property/fonts/icomoon/style.css" />
    <link rel="stylesheet" href="~/property/fonts/flaticon/font/flaticon.css" />
    <link rel="stylesheet" href="~/property/css/tiny-slider.css" />
    <link rel="stylesheet" href="~/property/css/aos.css" />
    <link rel="stylesheet" href="~/property/css/style.css" />
    <link rel="stylesheet" href="~/css/dorm-public.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="site-mobile-menu site-navbar-target">
        <div class="site-mobile-menu-header">
            <div class="site-mobile-menu-close">
                <span class="icofont-close js-menu-toggle"></span>
            </div>
        </div>
        <div class="site-mobile-menu-body"></div>
    </div>

    <nav class="site-nav">
        <div class="container">
            <div class="menu-bg-wrap">
                <div class="site-navigation">
                    <a href="/" class="logo m-0 float-start">Dorm</a>

                    <ul class="js-clone-nav d-none d-lg-inline-block text-start site-menu float-end">
                        <li><a href="/">Home</a></li>
                        <li><a href="/Browse">Browse</a></li>
                        <li><a href="/About">Contact</a></li>

                        @if (isAuth)
                        {
                            @if (role == "Admin")
                            {
                                <li><a href="/Admin">Admin</a></li>
                            }
                            else if (role == "Owner")
                            {
                                <li><a href="/Dashboard">Dashboard</a></li>
                            }
                            <li>
                                <form method="post" asp-area="Identity" asp-controller="Account" asp-action="Logout" style="display:inline;margin:0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" style="background:rgba(239,68,68,.15);color:#ef4444 !important;border-radius:6px;padding:6px 14px !important;border:none;cursor:pointer;font-size:inherit;font-family:inherit">Log out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li><a href="/Identity/Account/Login">Log in</a></li>
                            <li><a href="/Identity/Account/Register">Sign up</a></li>
                        }
                    </ul>

                    <a href="#" class="burger light me-auto float-end mt-1 site-menu-toggle js-menu-toggle d-inline-block d-lg-none" data-toggle="collapse" data-target="#main-navbar">
                        <span></span>
                    </a>
            </div>
        </div>
    </nav>

    @RenderBody()

    <div style="background:#0f172a;padding:1.4rem 0;line-height:1;border-top:1px solid rgba(255,255,255,.07)">
        <div class="container" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:.5rem">
            <span style="font-size:.95rem;font-weight:800;color:#F97316">Dorm</span>
            <div style="display:flex;gap:1.25rem">
                <a href="/" style="color:#94a3b8;text-decoration:none;font-size:.78rem">Home</a>
                <a href="/Browse" style="color:#94a3b8;text-decoration:none;font-size:.78rem">Browse</a>
                <a href="/About" style="color:#94a3b8;text-decoration:none;font-size:.78rem">Contact</a>
            </div>
            <span style="font-size:.78rem;color:#64748b">&copy; 2026 Dorm. All rights reserved.</span>
        </div>
    </div>

    <div id="overlayer"></div>
    <div class="loader">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <script src="~/property/js/bootstrap.bundle.min.js"></script>
    <script src="~/property/js/tiny-slider.js"></script>
    <script src="~/property/js/aos.js"></script>
    <script src="~/property/js/navbar.js"></script>
    <script src="~/property/js/counter.js"></script>
    <script src="~/property/js/custom.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
