@{
    var isAuth = User.Identity?.IsAuthenticated == true;
    var role = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var fullName = User.FindFirstValue("FullName") ?? "User";
    var email = User.FindFirstValue(ClaimTypes.Email) ?? "";
    var initials = string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(n => n[0])).ToUpper();
    if (initials.Length > 2) initials = initials.Substring(0, 2);
    if (initials.Length == 0) initials = "U";
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Dorm</title>

    <link rel="shortcut icon" href="~/property/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        * { font-family: 'Inter', sans-serif; }
        html, body { margin: 0; min-height: 100vh; }
        body { background: #f8fafc; display: flex; flex-direction: column; }
        .site-footer { margin-top: auto; }

        /* Navbar */
        .top-nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            background: #0f172a; border-bottom: 1px solid rgba(255,255,255,.06);
            padding: .6rem 0;
        }
        .top-nav .container { display: flex; align-items: center; justify-content: space-between; }
        .top-nav .brand { font-size: 1.3rem; font-weight: 800; color: #F97316; text-decoration: none; }
        .top-nav .nav-links { display: flex; gap: 1.5rem; align-items: center; }
        .top-nav .nav-links a {
            color: #94a3b8; text-decoration: none; font-size: .88rem; font-weight: 500;
            transition: color .15s;
        }
        .top-nav .nav-links a:hover { color: #f8fafc; }
        .top-nav .nav-links a.active { color: #f8fafc; }
        .btn-nav-login {
            background: rgba(255,255,255,.08); color: #f8fafc; border: 1px solid rgba(255,255,255,.12);
            padding: .4rem .9rem; border-radius: 7px; font-size: .82rem; font-weight: 600;
            text-decoration: none; transition: all .15s;
        }
        .btn-nav-login:hover { background: rgba(255,255,255,.12); color: #fff; }

        /* Profile dropdown */
        .profile-dropdown { position: relative; }
        .profile-toggle {
            display: flex; align-items: center; gap: .5rem; cursor: pointer;
            padding: .25rem; border-radius: 10px; transition: background .15s;
            border: none; background: transparent;
        }
        .profile-toggle:hover { background: rgba(255,255,255,.08); }
        .profile-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: #F97316; color: #fff; font-weight: 700; font-size: .8rem;
            display: flex; align-items: center; justify-content: center;
            border: 2px solid rgba(249,115,22,.3);
        }
        .profile-toggle .chevron {
            color: #94a3b8; font-size: .6rem; transition: transform .2s;
        }
        .profile-toggle.open .chevron { transform: rotate(180deg); }
        .profile-menu {
            position: absolute; top: calc(100% + 8px); right: 0;
            background: #fff; border-radius: 12px; min-width: 220px;
            box-shadow: 0 10px 40px rgba(0,0,0,.15), 0 2px 8px rgba(0,0,0,.06);
            border: 1px solid #e2e8f0;
            opacity: 0; visibility: hidden; transform: translateY(-6px);
            transition: all .2s cubic-bezier(.22,1,.36,1);
            overflow: hidden; z-index: 1001;
        }
        .profile-menu.show {
            opacity: 1; visibility: visible; transform: translateY(0);
        }
        .profile-menu-header {
            padding: .85rem 1rem; border-bottom: 1px solid #f1f5f9;
        }
        .profile-menu-header .pm-name { font-weight: 700; font-size: .88rem; color: #1e293b; }
        .profile-menu-header .pm-email { font-size: .75rem; color: #94a3b8; margin-top: 1px; }
        .profile-menu a, .profile-menu button {
            display: flex; align-items: center; gap: .65rem;
            width: 100%; padding: .6rem 1rem; border: none; background: transparent;
            color: #475569 !important; font-size: .85rem; font-weight: 500;
            text-decoration: none !important; cursor: pointer; transition: background .15s;
            text-align: left;
        }
        .profile-menu a:hover, .profile-menu button:hover { background: #f8fafc; color: #1e293b !important; }
        .profile-menu a i, .profile-menu button i { width: 18px; text-align: center; font-size: .95rem; color: #94a3b8; }
        .profile-menu .pm-divider { height: 1px; background: #f1f5f9; margin: .25rem 0; }
        .profile-menu .pm-logout { color: #ef4444 !important; }
        .profile-menu .pm-logout:hover { background: #fef2f2; color: #ef4444 !important; }
        .profile-menu .pm-logout i { color: #ef4444; }

        /* Hamburger */
        .nav-hamburger {
            display: none; flex-direction: column; justify-content: center; gap: 5px;
            width: 36px; height: 36px; border: none; background: transparent;
            cursor: pointer; padding: 4px; border-radius: 8px; transition: background .15s;
        }
        .nav-hamburger:hover { background: rgba(255,255,255,.08); }
        .nav-hamburger span {
            display: block; height: 2px; border-radius: 2px;
            background: #94a3b8; transition: all .25s;
        }
        .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .nav-hamburger.open span:nth-child(2) { opacity: 0; }
        .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

        /* Mobile drawer */
        .mobile-nav {
            display: none; position: fixed; top: 49px; left: 0; right: 0;
            background: #0f172a; border-bottom: 1px solid rgba(255,255,255,.08);
            z-index: 999; padding: .5rem 0 1rem; flex-direction: column;
        }
        .mobile-nav.show { display: flex; }
        .mobile-nav a {
            color: #94a3b8; text-decoration: none; font-size: .9rem; font-weight: 500;
            padding: .65rem 1.25rem; transition: color .15s, background .15s;
        }
        .mobile-nav a:hover, .mobile-nav a.active { color: #f8fafc; background: rgba(255,255,255,.05); }
        .mobile-nav .mn-divider { height: 1px; background: rgba(255,255,255,.07); margin: .4rem 1rem; }
        .mobile-nav .mn-user {
            padding: .65rem 1.25rem .3rem; font-size: .75rem;
            color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: .05em;
        }
        .mobile-nav .mn-logout {
            color: #ef4444; background: transparent; border: none; width: 100%;
            text-align: left; font-size: .9rem; font-weight: 500;
            padding: .65rem 1.25rem; cursor: pointer; transition: background .15s;
            display: flex; align-items: center; gap: .5rem;
        }
        .mobile-nav .mn-logout:hover { background: rgba(239,68,68,.08); }

        @@media (max-width: 767px) {
            .nav-links { display: none !important; }
            .nav-hamburger { display: flex; }
        }

        /* Footer */
        .site-footer {
            background: #0f172a; padding: 1.4rem 0; color: #94a3b8; line-height: 1;
            border-top: 1px solid rgba(255,255,255,.07);
        }
        .site-footer * { margin: 0; padding: 0; box-sizing: border-box; }
        .site-footer .brand { font-size: .95rem; font-weight: 800; color: #F97316; }
        .site-footer p { font-size: .78rem; color: #64748b; }
        .site-footer a { color: #94a3b8; text-decoration: none; font-size: .78rem; line-height: 1; }
        .site-footer a:hover { color: #f8fafc; }

        .form-control:focus, .form-select:focus {
            border-color: #F97316;
            box-shadow: 0 0 0 .2rem rgba(249,115,22,.12);
        }
        .form-check-input:checked { background-color: #F97316; border-color: #F97316; }

        /* #10 Page fade-in */
        body { opacity: 0; transition: opacity .22s ease; }

        /* #8 Toast system */
        .toast-stack {
            position: fixed; bottom: 1.5rem; right: 1.5rem;
            z-index: 9999; display: flex; flex-direction: column; gap: .5rem;
            pointer-events: none;
        }
        .dorm-toast {
            display: flex; align-items: center; gap: .75rem;
            background: #1e293b; color: #f8fafc;
            padding: .75rem 1.1rem; border-radius: 12px; min-width: 260px; max-width: 360px;
            box-shadow: 0 8px 32px rgba(0,0,0,.22);
            pointer-events: all;
            animation: toastIn .3s cubic-bezier(.22,1,.36,1) forwards;
        }
        .dorm-toast.hiding { animation: toastOut .25s ease forwards; }
        .dorm-toast .t-icon { font-size: 1.1rem; flex-shrink: 0; }
        .dorm-toast .t-msg { font-size: .85rem; font-weight: 500; flex: 1; }
        .dorm-toast .t-close { background: none; border: none; color: #64748b; cursor: pointer; padding: 0; font-size: .9rem; line-height: 1; }
        .dorm-toast.t-success { border-left: 3px solid #10b981; }
        .dorm-toast.t-success .t-icon { color: #10b981; }
        .dorm-toast.t-error { border-left: 3px solid #ef4444; }
        .dorm-toast.t-error .t-icon { color: #ef4444; }
        .dorm-toast.t-info { border-left: 3px solid #3b82f6; }
        .dorm-toast.t-info .t-icon { color: #3b82f6; }
        @@keyframes toastIn {
            from { opacity: 0; transform: translateY(12px) scale(.96); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        @@keyframes toastOut {
            from { opacity: 1; transform: translateY(0); }
            to   { opacity: 0; transform: translateY(8px); }
        }

        /* #9 Consistent button tokens */
        .btn-dorm  { background: #F97316; color: #fff; border: none; border-radius: 8px; font-weight: 600; padding: .6rem 1.25rem; font-size: .88rem; transition: all .18s; cursor: pointer; display: inline-flex; align-items: center; gap: .35rem; }
        .btn-dorm:hover { background: #ea6c10; color: #fff; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(249,115,22,.3); }
        .btn-dorm-dark { background: #0f172a; color: #fff; border: none; border-radius: 8px; font-weight: 600; padding: .6rem 1.25rem; font-size: .88rem; transition: all .18s; cursor: pointer; display: inline-flex; align-items: center; gap: .35rem; }
        .btn-dorm-dark:hover { background: #1e293b; color: #fff; transform: translateY(-1px); }
        .btn-dorm-ghost { background: transparent; color: #475569; border: 1.5px solid #e2e8f0; border-radius: 8px; font-weight: 600; padding: .55rem 1.2rem; font-size: .88rem; transition: all .18s; cursor: pointer; display: inline-flex; align-items: center; gap: .35rem; }
        .btn-dorm-ghost:hover { border-color: #cbd5e1; background: #f8fafc; color: #1e293b; }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="top-nav">
        <div class="container">
            <a href="/" class="brand">Dorm</a>
            <button class="nav-hamburger" id="nav-hamburger" onclick="toggleMobileNav()" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/Browse">Browse</a>
                <a href="/About">Contact</a>

                @if (isAuth)
                {
                    <a href="/Chat">Messages</a>

                    <div class="profile-dropdown" id="nav-profile">
                        <button class="profile-toggle" id="profile-toggle" onclick="toggleProfileMenu()">
                            <div class="profile-avatar">@initials</div>
                            <i class="bi bi-chevron-down chevron"></i>
                        </button>
                        <div class="profile-menu" id="profile-menu">
                            <div class="profile-menu-header">
                                <div class="pm-name">@fullName</div>
                                <div class="pm-email">@email</div>
                            </div>

                            @if (role == "Student")
                            {
                                <a href="/StudentApps"><i class="bi bi-file-text"></i> My Applications</a>
                                <a href="/Quiz"><i class="bi bi-clipboard-check"></i> Lifestyle Quiz</a>
                                <a href="/Saved"><i class="bi bi-heart"></i> Saved</a>
                            }
                            else if (role == "Owner")
                            {
                                <a href="/OwnerListings"><i class="bi bi-building"></i> My Listings</a>
                                <a href="/OwnerApps"><i class="bi bi-people"></i> Applications</a>
                                <a href="/WriteReview"><i class="bi bi-star"></i> Write a Review</a>
                            }

                            <div class="pm-divider"></div>
                            <a href="/Profile"><i class="bi bi-person-gear"></i> Edit Profile</a>
                            <div class="pm-divider"></div>
                            <form method="post" asp-area="Identity" asp-controller="Account" asp-action="Logout" style="margin:0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="pm-logout"><i class="bi bi-box-arrow-left"></i> Log out</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Identity/Account/Login" class="btn-nav-login">Log in</a>
                }
            </div>
        </div>
    </nav>

    <!-- Mobile nav drawer -->
    <div class="mobile-nav" id="mobile-nav">
        <a href="/">Home</a>
        <a href="/Browse">Browse</a>
        <a href="/About">Contact</a>
        @if (isAuth)
        {
            <a href="/Chat"><i class="bi bi-chat-dots me-1"></i>Messages</a>
            <div class="mn-divider"></div>
            <div class="mn-user">@fullName</div>
            @if (role == "Student")
            {
                <a href="/StudentApps"><i class="bi bi-file-text me-1"></i>My Applications</a>
                <a href="/Quiz"><i class="bi bi-clipboard-check me-1"></i>Lifestyle Quiz</a>
                <a href="/Saved"><i class="bi bi-heart me-1"></i>Saved</a>
            }
            else if (role == "Owner")
            {
                <a href="/OwnerListings"><i class="bi bi-building me-1"></i>My Listings</a>
                <a href="/OwnerApps"><i class="bi bi-people me-1"></i>Applications</a>
            }
            <a href="/Profile"><i class="bi bi-person-gear me-1"></i>Edit Profile</a>
            <div class="mn-divider"></div>
            <form method="post" asp-area="Identity" asp-controller="Account" asp-action="Logout" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="mn-logout"><i class="bi bi-box-arrow-left"></i> Log out</button>
            </form>
        }
        else
        {
            <div class="mn-divider"></div>
            <a href="/Identity/Account/Login">Log in</a>
        }
    </div>

    <div style="padding-top:56px">
        @RenderBody()
    </div>

    <footer class="site-footer">
        <div class="container d-flex flex-wrap align-items-center justify-content-between gap-2">
            <span class="brand">Dorm</span>
            <div class="d-flex gap-3 align-items-center flex-wrap">
                <a href="/">Home</a>
                <a href="/Browse">Browse</a>
                <a href="/About">Contact</a>
                @if (!isAuth) { <a href="/Identity/Account/Login">Log in</a> }
            </div>
            <p>&copy; 2026 Dorm. All rights reserved.</p>
        </div>
    </footer>

    <!-- Toast container -->
    <div class="toast-stack" id="toast-stack"></div>

    @* TempData → toast triggers *@
    @if (TempData["Success"] is string toastSuccess)
    {
        <div id="td-success" class="d-none">@toastSuccess</div>
    }
    @if (TempData["Error"] is string toastError)
    {
        <div id="td-error" class="d-none">@toastError</div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
    // #10 Page fade-in
    document.addEventListener('DOMContentLoaded', function () { document.body.style.opacity = 1; });

    // #8 Toast system
    function showToast(msg, type) {
        type = type || 'info';
        var icons = { success: 'bi-check-circle-fill', error: 'bi-exclamation-circle-fill', info: 'bi-info-circle-fill' };
        var t = document.createElement('div');
        t.className = 'dorm-toast t-' + type;
        t.innerHTML = '<i class="bi ' + icons[type] + ' t-icon"></i><span class="t-msg">' + msg + '</span>' +
            '<button class="t-close" onclick="dismissToast(this.parentElement)"><i class="bi bi-x"></i></button>';
        document.getElementById('toast-stack').appendChild(t);
        setTimeout(function () { dismissToast(t); }, 4000);
    }
    function dismissToast(el) {
        if (!el || el.classList.contains('hiding')) return;
        el.classList.add('hiding');
        setTimeout(function () { el.remove(); }, 260);
    }
    // Auto-fire TempData toasts
    document.addEventListener('DOMContentLoaded', function () {
        var s = document.getElementById('td-success');
        var e = document.getElementById('td-error');
        if (s) showToast(s.textContent.trim() === 'true' ? 'Done! Your changes were saved.' : s.textContent.trim(), 'success');
        if (e) showToast(e.textContent.trim(), 'error');
    });

    // Highlight active nav link
    var currentPath = window.location.pathname.toLowerCase()
    document.querySelectorAll('.top-nav .nav-links > a').forEach(function (link) {
        var href = (link.getAttribute('href') || '').toLowerCase()
        if (href && currentPath === href) link.classList.add('active')
    })

    function toggleMobileNav() {
        var nav = document.getElementById('mobile-nav')
        var btn = document.getElementById('nav-hamburger')
        nav.classList.toggle('show')
        btn.classList.toggle('open')
    }

    // Close mobile nav when a link is tapped
    document.querySelectorAll('.mobile-nav a').forEach(function(a) {
        a.addEventListener('click', function() {
            document.getElementById('mobile-nav').classList.remove('show')
            document.getElementById('nav-hamburger').classList.remove('open')
        })
    })

    // Highlight active link in mobile nav too
    document.querySelectorAll('.mobile-nav > a').forEach(function(link) {
        var href = (link.getAttribute('href') || '').toLowerCase()
        if (href && window.location.pathname.toLowerCase() === href) link.classList.add('active')
    })

    function toggleProfileMenu() {
        var menu = document.getElementById('profile-menu')
        var toggle = document.getElementById('profile-toggle')
        menu.classList.toggle('show')
        toggle.classList.toggle('open')
    }

    document.addEventListener('click', function (e) {
        var dropdown = document.getElementById('nav-profile')
        if (dropdown && !dropdown.contains(e.target)) {
            document.getElementById('profile-menu').classList.remove('show')
            document.getElementById('profile-toggle').classList.remove('open')
        }
    })
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
