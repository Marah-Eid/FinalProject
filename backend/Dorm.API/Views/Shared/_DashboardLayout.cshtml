@{
    var isAuth = User.Identity?.IsAuthenticated == true;
    var role = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var fullName = User.FindFirstValue("FullName") ?? "User";
    var email = User.FindFirstValue(ClaimTypes.Email) ?? "";
    var initial = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "U";
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Dorm</title>

    <link rel="shortcut icon" href="~/property/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f1f5f9; margin: 0; }

        .dash-sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            top: 0; left: 0;
            background: #fff;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: transform .3s;
        }
        .dash-sidebar .brand {
            padding: 1.25rem;
            border-bottom: 1px solid #f1f5f9;
        }
        .dash-sidebar .brand a {
            font-size: 1.4rem; font-weight: 700; color: #F97316;
            text-decoration: none;
        }
        .dash-sidebar .nav-section {
            padding: .5rem 0;
            flex: 1; overflow-y: auto;
        }
        .dash-sidebar .nav-label {
            font-size: .65rem; text-transform: uppercase; letter-spacing: .08em;
            color: #94a3b8; padding: .75rem 1.25rem .25rem; font-weight: 600;
        }
        .dash-sidebar .nav-item a {
            display: flex; align-items: center; gap: .75rem;
            padding: .6rem 1.25rem;
            color: #475569; text-decoration: none;
            font-size: .875rem; font-weight: 500;
            border-left: 3px solid transparent;
            transition: all .15s;
        }
        .dash-sidebar .nav-item a:hover {
            background: #f8fafc;
            color: #1e293b;
        }
        .dash-sidebar .nav-item a.active {
            background: rgba(249,115,22,.06);
            color: #F97316;
            border-left-color: #F97316;
            font-weight: 600;
        }
        .dash-sidebar .nav-item a i { font-size: 1.1rem; width: 20px; text-align: center; }

        .dash-main {
            margin-left: 260px;
            min-height: 100vh;
        }

        .dash-topbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: .75rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 100;
        }
        .dash-topbar .page-title { font-weight: 700; font-size: 1.1rem; color: #1e293b; margin: 0; }

        .dash-content { padding: 1.5rem; }

        .card { border: none; border-radius: .75rem; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
        .card-header { background: transparent; border-bottom: 1px solid #f1f5f9; }

        .btn-dorm { background: #F97316; border-color: #F97316; color: #fff; }
        .btn-dorm:hover { background: #ea6c10; border-color: #ea6c10; color: #fff; }

        .table th { font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: #64748b; border-bottom-width: 1px; }
        .table td { vertical-align: middle; }

        .form-control:focus, .form-select:focus {
            border-color: #F97316;
            box-shadow: 0 0 0 .2rem rgba(249,115,22,.15);
        }
        .form-check-input:checked { background-color: #F97316; border-color: #F97316; }

        .nav-section::-webkit-scrollbar { width: 4px; }
        .nav-section::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

        body { opacity: 0; transition: opacity .22s ease; }

        .toast-stack { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; display: flex; flex-direction: column; gap: .5rem; pointer-events: none; }
        .dorm-toast { display: flex; align-items: center; gap: .75rem; background: #1e293b; color: #f8fafc; padding: .75rem 1.1rem; border-radius: 12px; min-width: 260px; max-width: 360px; box-shadow: 0 8px 32px rgba(0,0,0,.22); pointer-events: all; animation: toastIn .3s cubic-bezier(.22,1,.36,1) forwards; }
        .dorm-toast.hiding { animation: toastOut .25s ease forwards; }
        .dorm-toast .t-icon { font-size: 1.1rem; flex-shrink: 0; }
        .dorm-toast .t-msg { font-size: .85rem; font-weight: 500; flex: 1; }
        .dorm-toast .t-close { background: none; border: none; color: #64748b; cursor: pointer; padding: 0; font-size: .9rem; line-height: 1; }
        .dorm-toast.t-success { border-left: 3px solid #10b981; } .dorm-toast.t-success .t-icon { color: #10b981; }
        .dorm-toast.t-error   { border-left: 3px solid #ef4444; } .dorm-toast.t-error .t-icon   { color: #ef4444; }
        .dorm-toast.t-info    { border-left: 3px solid #3b82f6; } .dorm-toast.t-info .t-icon    { color: #3b82f6; }
        @@keyframes toastIn  { from { opacity:0; transform:translateY(12px) scale(.96); } to { opacity:1; transform:translateY(0) scale(1); } }
        @@keyframes toastOut { from { opacity:1; transform:translateY(0); } to { opacity:0; transform:translateY(8px); } }

        .sidebar-toggle { display: none; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.3); z-index: 999; }
        @@media (max-width: 991px) {
            .dash-sidebar { transform: translateX(-100%); }
            .dash-sidebar.show { transform: translateX(0); }
            .sidebar-overlay.show { display: block; }
            .dash-main { margin-left: 0; }
            .sidebar-toggle { display: inline-flex; }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>
    <aside class="dash-sidebar" id="dash-sidebar">
        <div class="brand">
            <a href="/">Dorm</a>
        </div>
        <div class="nav-section">
            <div class="nav-label">Menu</div>
            <div class="nav-item">
                <a href="/Dashboard"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
            </div>

            @if (role == "Owner")
            {
                <div class="nav-item"><a href="/OwnerListings"><i class="bi bi-building"></i> My Listings</a></div>
                <div class="nav-item"><a href="/OwnerApps"><i class="bi bi-people"></i> Applications</a></div>
            }

            <div class="nav-item"><a href="/Chat"><i class="bi bi-chat-dots"></i> Messages</a></div>
            @if (role != "Admin")
            {
                <div class="nav-item"><a href="/Payment"><i class="bi bi-credit-card"></i> Payments</a></div>
            }

            @if (role == "Admin")
            {
                <div class="nav-item"><a href="/Admin"><i class="bi bi-shield-check"></i> Admin Panel</a></div>
                <div class="nav-item"><a href="/Admin#testimonials"><i class="bi bi-chat-square-text"></i> Testimonials</a></div>
            }

            <div class="nav-item"><a href="/WriteReview"><i class="bi bi-star"></i> Write a Review</a></div>
            <div class="nav-label">Account</div>
            <div class="nav-item"><a href="/Profile"><i class="bi bi-person-gear"></i> Edit Profile</a></div>
            <div class="nav-item"><a href="/"><i class="bi bi-house"></i> Back to site</a></div>
            <div class="nav-item">
                <form method="post" asp-area="Identity" asp-controller="Account" asp-action="Logout" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" style="display:flex;align-items:center;gap:.75rem;padding:.6rem 1.25rem;color:#475569;background:none;border:none;font-size:.875rem;font-weight:500;width:100%;cursor:pointer;border-left:3px solid transparent;transition:all .15s">
                        <i class="bi bi-box-arrow-left" style="font-size:1.1rem;width:20px;text-align:center"></i> Logout
                    </button>
                </form>
            </div>
        </div>
        <div style="padding:1rem 1.25rem;border-top:1px solid #f1f5f9">
            <div class="d-flex align-items-center gap-2">
                <div style="width:32px;height:32px;border-radius:50%;background:#F97316;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:.75rem">@initial</div>
                <div>
                    <div style="font-size:.8rem;font-weight:600;color:#1e293b">@fullName</div>
                    <div style="font-size:.7rem;color:#94a3b8">@email</div>
                </div>
            </div>
        </div>
    </aside>

    <div class="dash-main">
        <div class="dash-topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-light sidebar-toggle" onclick="toggleSidebar()"><i class="bi bi-list fs-5"></i></button>
                <h6 class="page-title">@ViewData["Title"]</h6>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-success bg-opacity-10 text-success"><i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i> Online</span>
            </div>
        </div>
        <div class="dash-content">
            @RenderBody()
        </div>
        <div style="padding:1.4rem 1.5rem;color:#94a3b8;font-size:.78rem;border-top:1px solid #e2e8f0">&copy; 2026 Dorm. All rights reserved.</div>
    </div>

    <div class="toast-stack" id="toast-stack"></div>
    @if (TempData["Success"] is string ds) { <div id="td-success" class="d-none">@ds</div> }
    @if (TempData["Error"]   is string de) { <div id="td-error"   class="d-none">@de</div> }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
    document.addEventListener('DOMContentLoaded', function () { document.body.style.opacity = 1; });
    function showToast(msg, type) {
        type = type || 'info';
        var icons = { success: 'bi-check-circle-fill', error: 'bi-exclamation-circle-fill', info: 'bi-info-circle-fill' };
        var t = document.createElement('div');
        t.className = 'dorm-toast t-' + type;
        t.innerHTML = '<i class="bi ' + icons[type] + ' t-icon"></i><span class="t-msg">' + msg + '</span><button class="t-close" onclick="dismissToast(this.parentElement)"><i class="bi bi-x"></i></button>';
        document.getElementById('toast-stack').appendChild(t);
        setTimeout(function () { dismissToast(t); }, 4000);
    }
    function dismissToast(el) { if (!el || el.classList.contains('hiding')) return; el.classList.add('hiding'); setTimeout(function () { el.remove(); }, 260); }
    document.addEventListener('DOMContentLoaded', function () {
        var s = document.getElementById('td-success'), e = document.getElementById('td-error');
        if (s) showToast(s.textContent.trim() === 'true' ? 'Saved successfully.' : s.textContent.trim(), 'success');
        if (e) showToast(e.textContent.trim(), 'error');
    });

    // Highlight active nav
    var path = window.location.pathname.toLowerCase()
    document.querySelectorAll('.nav-item a').forEach(function (link) {
        var href = (link.getAttribute('href') || '').toLowerCase()
        if (href && path === href) link.classList.add('active')
    })

    function toggleSidebar() {
        document.getElementById('dash-sidebar').classList.toggle('show')
        document.getElementById('sidebar-overlay').classList.toggle('show')
    }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
